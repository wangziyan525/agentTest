<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
          name="viewport" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>西安银行</title>
    <script src="../../common/js/vue.min.js"></script>
    <script src="../../common/js/vant-2.12.min.js"></script>
    <script type="text/javascript" src="../../common/js/jquery-2.1.3.min.js"></script>
    <script type="text/javascript" src="../../common/js/jquery-weui.min.js"></script>
    <script type="text/javascript" src="../../common/js/jquery.cookie_jq.js"></script>
    <link rel="stylesheet" href="../../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../../common/css/weui.min.css">
    <link rel="stylesheet" href="../../common/css/weui.min.css">
    <link rel="stylesheet" href="../../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="../css/common.css?v=1.0.1">
    <link rel="stylesheet" href="../css/randomCheck/checkRegisterZH.css?v=1.0.1">
</head>
<body>
<!--经营支行、一级机构自查情况登记-->
<div id="app" v-cloak style="height: 100%;overflow-y: auto">
    <div>
        <div class="contentPart">
            <div class="contentLine">
                <div>抽查对象</div>
                <div class="selectState display" style="position: relative;display: flex;align-items: center">
                    <input class="weui-input" type="text" placeholder="请选择抽查对象" v-model='submitInfo.spotCheckObjectTxt' @click="showTap('3')" readonly>
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>
            <div class="contentLine">
                <div>一级机构</div>
                <div class="selectState display" style="position: relative;display: flex;align-items: center">
                    <input class="weui-input" type="text" placeholder="请选择一级机构" v-model='submitInfo.checkFirstOrgName' @click="showTap('5')" readonly>
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>
            <div class="contentLine" v-if="secondOrgFlag">
                <div>经营支行</div>
                <div class="selectState display" style="position: relative;display: flex;align-items: center">
                    <input class="weui-input" type="text" placeholder="请选择经营支行" v-model='submitInfo.checkSecondOrgName' @click="showTap('6')" readonly>
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>
        </div>
        <div class="contentPart" style="padding-bottom: 0px">
            <div class="contentLine">
                <div>检查类别</div>
                <div class="selectState display" style="position: relative;display: flex;align-items: center">
                    <input class="weui-input" type="text" placeholder="请选择检查类别" v-model='submitInfo.checkCategoryTxt' @click="showTap('4')" readonly>
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>
            <div class="contentLine">
                <div>检查时间</div>
                <div class="selectState display" style="position: relative;display: flex;align-items: center">
                    <input class="weui-input" type="text" placeholder="请选择检查时间" v-model='submitInfo.checkDate' @click="pickerdate('checkDate')" readonly>
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>
            <div class="session-item-container" style="display: flex;align-items: center;justify-content: space-between">
                <div class="session-item-title color999999">检查对象(多选)</div>
                <div class="session-item-text color333333">
                    <div>
                        <van-checkbox-group v-model="submitInfo.checkObject" style="display: flex;align-items: center;flex-wrap: wrap">
                            <van-checkbox class="checkbox-flex" name="1" @click="chooseCheckObject('1')">
                                厅堂
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-checkbox>
                            <van-checkbox class="checkbox-flex" name="2" @click="chooseCheckObject('2')">
                                双录
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-checkbox>
                            <van-checkbox class="checkbox-flex" name="3" @click="chooseCheckObject('3')">
                                监控
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-checkbox>

                        </van-checkbox-group>
                    </div>
                </div>
            </div>
        </div>
        <div>
            <div v-for="(item, index) in businessInfoList">
                <div style="padding: 12px;color: #999;display: flex;align-items: center;justify-content: space-between"><p>业务信息{{index+1}}</p><p v-if="businessInfoList.length>1" class="deleteBtn" @click="deleteInfo(index)"><img src="../image/delete.png">删除</p></div>
                <div class="session-item-container display" style="padding: 12px;background: #fff">
                    <div class="session-item-title display align-item-center color999999">业务发生时间</div>
                    <div class="session-item-text flex display color333333 justify-content-right"  style="position: relative;display: flex;align-items: center">
                        <input v-if="checkObjectFlag==false" class="v-test" placeholder="请选择(选填)" v-model='item.occurrenceDate' style="width: 100%" readonly @click="pickerdateD(index)">
                        <input v-if="checkObjectFlag==true" class="v-test" placeholder="请选择(必填)" v-model='item.occurrenceDate' style="width: 100%" readonly @click="pickerdateD(index)">
                        <img src="../image/arrow.png" class="year">
                    </div>
                </div>
                <div class="session-item-container display border-top" style="padding: 12px;background: #fff" >
                    <div class="session-item-title display align-item-center color999999">业务种类</div>
                    <div class="session-item-text flex display color333333 justify-content-right"  style="position: relative;display: flex;align-items: center">
                        <input v-if="checkObjectFlag==false" class="v-test" placeholder="请选择(选填)" v-model='item.businessTypeTxt' style="width: 100%" readonly @click="showTap(1,index)">
                        <input v-if="checkObjectFlag==true" class="v-test" placeholder="请选择(必填)" v-model='item.businessTypeTxt' style="width: 100%" readonly @click="showTap(1,index)">
                        <img src="../image/arrow.png" class="year">
                    </div>
                </div>
                <div class="session-item-container display border-top" style="padding: 12px;background: #fff">
                    <div class="session-item-title display align-item-center color999999">业务流水号</div>
                    <div class="session-item-text flex display color333333 justify-content-right">
                        <input v-if="checkObjectFlag==false" class="v-test" placeholder="请填写(选填)" v-model='item.businessNumber' style="width: 100%"  @blur="updateInput">
                        <input v-if="checkObjectFlag==true" class="v-test" placeholder="请填写(必填)" v-model='item.businessNumber' style="width: 100%"  @blur="updateInput">
                    </div>
                </div>
            </div>
            <div style="padding: 12px;">
                <div class="addBtn" @click="addInfo()">+ 添加业务信息</div>
            </div>
        </div>
        <div class="contentPart">
            <div class="session-item-container" style="display: flex;align-items: center;justify-content: space-between">
                <div class="session-item-title color999999">是否为专项检查</div>
                <div class="session-item-text color333333">
                    <div>
                        <van-radio-group v-model="submitInfo.specialCheck" style="display: flex;align-items: center;flex-wrap: wrap">
                            <van-radio class="checkbox-flex" name="1" @click="chooseSpecialCheck('1')">
                                是
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-radio>
                            <van-radio class="checkbox-flex" name="2" @click="chooseSpecialCheck('2')">
                                否
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-radio>
                        </van-radio-group>
                    </div>
                </div>
            </div>
            <div class="session-item-container display border-top" v-if="specialCheckFlag">
                <div class="session-item-title display align-item-center color999999">专项检查名称</div>
                <div class="session-item-text flex display color333333 justify-content-right">
                    <input class="v-test" placeholder="请输入" v-model='submitInfo.specialCheckIdTxt' style="width: 100%" readonly @click="showTap(7)">
                </div>
            </div>
        </div>
        <div class="contentPart">
            <div class="session-item-container" style="display: flex;align-items: center;justify-content: space-between">
                <div class="session-item-title color999999">是否存在问题</div>
                <div class="session-item-text color333333">
                    <div>
                        <van-radio-group v-model="submitInfo.anyProblem" style="display: flex;align-items: center;flex-wrap: wrap">
                            <van-radio class="checkbox-flex" name="1" @click="chooseAnyProblem('1')">
                                是
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-radio>
                            <van-radio class="checkbox-flex" name="2" @click="chooseAnyProblem('2')">
                                否
                                <img class="checkbox-img" slot="icon" slot-scope="props" :src="props.checked ? icon.activeIcon : icon.inactiveIcon" />
                            </van-radio>
                        </van-radio-group>
                    </div>
                </div>
            </div>
            <div  style="display: block;padding: 0 12px" v-if="anyProblemFlag" class="border-top">
                <div style="color: #666;padding: 5px 0">问题记录</div>
                <div style=" background:rgba(255,255,255,1); border-radius:4px; padding: 5px 0px;">
                        <textarea style="width:96%; height:70px; padding: 10px 2%; background:rgba(243,244,248,1); border-radius:4px; font-size:16px; font-family:PingFangSC-Regular,PingFang SC;
                        border:none; " rows="5" v-model='submitInfo.problemRecord' maxlength='500' placeholder="请输入"></textarea>
                </div>
            </div>
           <!-- <div  style="display: block;padding: 0 12px" v-if="anyProblemFlag" class="border-top">
                <div style="color: #666;padding: 5px 0">整改措施</div>
                <div style=" background:rgba(255,255,255,1); border-radius:4px; padding: 5px 0px;">
                        <textarea style="width:96%; height:70px; padding: 10px 2%; background:rgba(243,244,248,1); border-radius:4px; font-size:16px; font-family:PingFangSC-Regular,PingFang SC;
                        border:none; " rows="5" v-model='submitInfo.rectificationMeasures' maxlength='500' placeholder="请输入"></textarea>
                </div>
            </div>
            <div  style="display: flex;align-items: center;justify-content: space-between;padding: 12px 12px" v-if="anyProblemFlag" class="border-top">
                <div>整改完成时间</div>
                <div class="selectState"  style="position: relative;display: flex;align-items: center">
                    <input class="weui-input" type="text" placeholder="请选择" v-model='submitInfo.rectificationFinishDate' readonly  @click="pickerdate('rectificationFinishDate')">
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>-->
            <div  style="display: block;padding: 0 12px" class="border-top">
                <div style="color: #666;padding: 5px 0">备注</div>
                <div style=" background:rgba(255,255,255,1); border-radius:4px; padding: 5px 0px;">
                        <textarea style="width:96%; height:70px; padding: 10px 2%; background:rgba(243,244,248,1); border-radius:4px; font-size:16px; font-family:PingFangSC-Regular,PingFang SC;
                        border:none; " rows="5" v-model='submitInfo.remark' maxlength='500' placeholder="请输入(选填)"></textarea>
                </div>
            </div>
        </div>
        <div class="contentPart">
            <div class="session-item-container display">
                <div class="session-item-title display align-item-center color999999">下一步审核人</div>
                <div class="session-item-text flex display color333333 justify-content-right"  style="position: relative;display: flex;align-items: center">
                    <input class="v-test" placeholder="请选择" v-model='submitInfo.nextApproveUserName' style="width: 100%" readonly @click="showTap(2)">
                    <img src="../image/arrow.png" class="year">
                </div>
            </div>
        </div>

        <div class="contentPart">
            <div class="session-item-container display">
                <div class="session-item-title display align-item-center color999999">检查人</div>
                <div class="session-item-text flex display color333333 justify-content-right">
                    <div>{{submitInfo.checkName ? submitInfo.checkName : '--'}}</div>
                </div>
            </div>
            <div class="session-item-container display border-top">
                <div class="session-item-title display align-item-center color999999">检查机构</div>
                <div class="session-item-text flex display color333333 justify-content-right">
                    <div>{{ssbm ? ssbm : '--'}}</div>
                </div>
            </div>
        </div>


        <div class="bottomButton">
            <div class="submitButton" @click="submitBindtap()">提 交</div>
        </div>

    </div>
    <van-popup
            v-model="popupDataShow"
            position="bottom"
            :close-on-click-overlay="false">
        <van-datetime-picker
                v-model="currentDate"
                type="date"
                title="选择日期"
                @confirm="getTime"
                @cancel="closeTime"
                :min-date='minDate'
        >
        </van-datetime-picker>
    </van-popup>

    <van-popup
            v-model="popupDataShowD"
            position="bottom"
            :close-on-click-overlay="false">
        <van-datetime-picker
                v-model="currentDate"
                type="datetime"
                title="选择日期"
                @confirm="getTimeD"
                @cancel="closeTimeD"
        >
        </van-datetime-picker>
    </van-popup>

    <van-popup v-model="popupBottomShow1" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject1.title"
                    :columns="popupObject1.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>

    <van-popup v-model="popupBottomShow2" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject2.title"
                    :columns="popupObject2.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>

    <van-popup v-model="popupBottomShow3" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject3.title"
                    :columns="popupObject3.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>
    <van-popup v-model="popupBottomShow4" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject4.title"
                    :columns="popupObject4.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>

    <van-popup v-model="popupBottomShow5" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject5.title"
                    :columns="popupObject5.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>

    <van-popup v-model="popupBottomShow6" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject6.title"
                    :columns="popupObject6.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>

    <van-popup v-model="popupBottomShow7" @click-overlay="closeOverlayBindtap" :close-on-click-overlay="false"
               position="bottom">
        <van-picker show-toolbar item-height="50px" visible-item-count="5" :title="popupObject7.title"
                    :columns="popupObject7.columns" @cancel="closeOverlayBindtap" @confirm="onConfirm">
        </van-picker>
    </van-popup>
</div>
</body>
<script type="text/javascript" src="../../common/js/base.js"></script>
<script type="text/javascript" src="../../common/js/jssdk.js"></script>
<script src="../../common/js/server.js?v=20211022"></script>
<script src="../../common/js/watermark.js"></script>
<script type="text/javascript" src="../js/randomCheck/checkRegisterZH.js?v=3.2.5"></script>
<script src="../../common/js/vConsole.min.js"></script>
<script>
    //var vConsole = new VConsole();
    //初始化微信社区
    $(function() {
        initJSSDK(['hideAllNonBaseMenuItem','chooseImage','uploadImage','downloadImage', 'startRecord', 'stopRecord', 'translateVoice','closeWindow']);
        wx.ready(function() {
            wx.hideAllNonBaseMenuItem();
        });
    });

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });

    function getUserFinish(){
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }
</script>
<script type="text/javascript" src="../../common/js/getUserInfo.js"></script>

</html>
