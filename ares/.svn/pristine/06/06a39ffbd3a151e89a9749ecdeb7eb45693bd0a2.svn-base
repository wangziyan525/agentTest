[v-cloak]{
    display: none;
}

html, body {
    height: 100vh;
    background-color: #f3f4f6;
    /* overflow: hidden; */
}
.container{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
.topTitle{
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: PingFangSC-Semibold;
    font-size: 19px;
    color: #000000;
    text-align: center;
    font-weight: 600;
    margin: 19px auto; 
}
.midText{
    flex: 1;
    font-family: PingFangSC-Regular;
    font-size: 15px;
    color: #000000;
    line-height: 24px;
    font-weight: 400;
    padding: 0 16px 20px;
    box-sizing: border-box;
    /* height: 600px; */
    overflow-y: auto;

}
.btmBtn{
    display: flex;
    align-items: center;
    justify-content: center;
    background: #267EF0;
    border-radius: 6px;
    font-family: PingFangSC-Regular;
    font-size: 17px;
    color: #FFFFFF;
    text-align: center;
    font-weight: 400;
    padding: 11px 0;
    margin:5px 16px;
    border: none;
}
.btmBtn:disabled{
    background-color: #cbd5e1
}