<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>银⾏承兑汇票在线承兑查询</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../common/css/weui.min.css" />
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/invoiceList.css?v=0.0.1122222">
</head>
<body>

    <div id="app" v-cloak>

        <!-- tab切换 -->
        <div class="tabs">
            <van-tabs v-model="active" @change="changeActive">
                <van-tab title="待审批"></van-tab>
                <van-tab title="已审批"></van-tab>
            </van-tabs>
        </div>

        <!-- 搜索-->
        <div class="search">
            <form action="javascript:true;">
                <div class="searchMain">
                    <img src="./image/search.png" alt="" @click="toSearch">
                    <input type="search" placeholder="请输入企业名称进行搜索" v-model.trim="searchName"  @keyup.enter='toSearch'>
                </div>
            </form>
        </div>

        <!--筛选-->
        <template v-if="active == 1">
            <div class="filter">
            <!--时间筛选-->
            <div class="filterTime" @click="showChooseTimeModel">
                <div class="filterText" v-html="filterTimeText"></div>
                <img src="./image/xuanzhe.png" alt="">
            </div>
            <!--状态筛选-->
            <div class="filterStatus" @click="showChooseStatusModel">
                <div class="filterText">{{filterStatusText}}</div>
                <img src="./image/xuanzhe.png" alt="">
            </div>
        </div>
        </template>

        <!-- 列表-->
        <div class="mainList" ref="main" @scroll="handleScroll">
            <template v-if="isHaveList">
                <template v-for="(it,i) in list">
                    <div class="list">
                        <div class="title">
                            <span>{{it.DRWR_NAME}}</span>
                            <template v-if="active == 1">
                                <em v-if="it.AUTH_FLAG == 0" class="em1">审批通过</em>
                                <em v-if="it.AUTH_FLAG == 1" class="em2">审批拒绝</em>
                            </template>
                        </div>
                        <div class="listDetail">
                            <div class="detail">
                                <!-- <span>业务类型</span><span>{{it.BUSS_TYPE==0?'单笔':it.BUSS_TYPE==1?'批量':'--'}}</span> -->
                                <span>业务类型</span><span>在线承兑开票</span>
                            </div>
                            <div class="detail">
                                <span>票面总金额</span><span>{{numFormat(it.BILL_TOT_AMT)}}<em>元</em></span>
                            </div>
                            <div class="detail">
                                <template v-if="active == 0">
                                    <span>提交时间</span><span>{{it.SUBMIT_TIME}}</span>
                                </template>
                                <template  v-if="active == 1">
                                    <span>审批时间</span><span>{{it.UPDATETIME}}</span>
                                </template>
                            </div>
                        </div>
                        <div class="toDetail" @click="toDetail(it.BATCH_NO)">
                            <template v-if="active == 0">审批</template>
                            <template v-if="active == 1">详情</template>
                        </div>
                    </div>
                </template>
            </template>
            <template v-if="noList">
                <div class="noList">
                    <img src="./image/noList.png" alt="">
                    <span>暂无数据</span>
                </div>
            </template>
            <div class="dataOver" v-if="dataOver">已到最底部了</div>
        </div>

        <!--遮罩层(时间)-->
        <van-action-sheet v-model="isshowChooseTime" title="请选择查询时间">
            <div class="popupContent">
                <div style="width: 100%;height: 30px"></div>
                <div class="title">⾃定义时间</div>
                <div class="diyTime">
                    <div class="startTime" @click="showDiyTime(1)">
                        <input type="text" placeholder="开始时间" readonly v-model="startTime">
                        <i><img src="./image/xuanzhe.png" alt=""></i>
                    </div>
                    <span>至</span>
                    <div class="endTime" @click="showDiyTime(2)">
                        <input type="text" placeholder="结束时间" readonly v-model="endTime">
                        <i><img src="./image/xuanzhe.png" alt=""></i>
                    </div>
                </div>
                <div class="title">时间段</div>
                <div class="daiTime">
                    <span :class="chooseTimeDuan==0?'diyTimeActive':''" @click="changTimeDuan(0)">当日</span>
                    <span :class="chooseTimeDuan==1?'diyTimeActive':''" @click="changTimeDuan(1)">近一周</span>
                    <span :class="chooseTimeDuan==2?'diyTimeActive':''" @click="changTimeDuan(2)">近一月</span>
                    <span :class="chooseTimeDuan==3?'diyTimeActive':''" @click="changTimeDuan(3)">近三月</span>
                </div>
                <div class="searchBtn">
                    <span @click="searchAgin()">重置</span>
                    <span @click="filterTimeSearch()">确认</span>
                </div>
            </div>
        </van-action-sheet>

        <!-- 下拉选择 -->
        <van-popup v-model="showPickerStatus" position="bottom">
            <div class="chooseStatusModel">
                <div class="titles">
                    <span @click="showPickerStatus=false">取消</span>
                    <span>请选择审批状态</span>
                    <span @click="selectStatused">确定</span>
                </div>
                <div class="cts">
                    <template v-for="(it,i) in chooseList">
                        <div class="itemCt" @click="selectStatus(i)">
                            <span>{{it.name}}</span>
                            <template v-if="it.isChoose">
                                <i><img src="./image/selected.png" alt=""></i>
                            </template>
                            <template v-else>
                                <i></i>
                            </template>
                        </div>
                    </template>
                </div>
            </div>
        </van-popup>

        <!--时间选择-->
        <van-popup v-model="chooseTimeShow" position="bottom" style="border-radius: 6px;">
            <van-datetime-picker type="date"
                                 title="按年月筛选"
                                 v-model="currentDate"
                                 :min-date='minDate'
                                 :max-date='maxDate'
                                 :formatter="formatter"
                                 @cancel="chooseTimeShow=false"
                                 @confirm="chooseDate">
            </van-datetime-picker>
        </van-popup>

    </div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/jwxwork.js"></script>
<script type="text/javascript" src="../common/js/watermark.js?v=1.2"></script>
<script type="text/javascript" src="../common/js/vConsole.min.js"></script>
<script type="text/javascript" src="../common/js/newServer.js"></script>
<script type="text/javascript" src="./js/invoiceList.js?v=0.0.22342831260212"></script>
<script>

    // var vConsole = new VConsole();

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });


    //初始化微信社区
    $(function () {
        initJSSDK([ 'hideAllNonBaseMenuItem','invoke','chooseImage','uploadImage','previewImage']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });


    function getUserFinish() {
        action();
    }


</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
