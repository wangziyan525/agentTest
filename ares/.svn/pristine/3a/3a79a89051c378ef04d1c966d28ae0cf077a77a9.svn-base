* {
    font-family: "Arial", "Microsoft YaHei", sans-serif;
}
html,body {
    padding: 0;
    margin: 0;
    /*list-style-type: none;*/
    /*-webkit-overflow-scrolling:touch;*/
    /*-webkit-tap-highlight-color: rgba(0,0,0,0);*/
    width: 100%;
    overflow-x: hidden;
    min-height: 100vh;
    font-size: 15px;
    list-style-type: none;
    background: #F5F6F7;
}
[v-cloak]{
    display: none;
}
.van-picker-column__item--selected, .van-picker-column__item--selected .van-ellipsis {
    color: #267EF0 !important;
}
.van-dialog__confirm, .van-dialog__confirm:active {
    color: #267EF0;
}
.van-dialog__header--isolated {
    padding: 32px 12px;
}
.weui-dialog__hd {
    padding: 2.3em 1.6em 2em;
}
.weui-dialog__btn{
    color: #267EF0 !important;
}
.van-picker__confirm {
    color: #267EF0;
}
.color999 {
    color: #999 !important;
}
/* 
::-webkit-input-placeholder {
    color:  #999 !important;
    font-size: 17px;
}

::-moz-placeholder {
    color:  #999 !important;
    font-size: 17px;
}

::-moz-placeholder {
    color:  #999 !important;
    font-size: 17px;
}

:-ms-input-placeholder {
    color:  #999 !important;
    font-size: 17px;
} */
::placeholder {
    color: #B4B4B4 !important;
    font-size: 14px;
}
.van-cell {
    padding: 0;
}
.van-field__control{
    text-align: right;
    overflow: hidden;
}
.van-field__control:disabled{
    -webkit-text-fill-color:#000 !important;
}
.van-field__control[type=search] {
    text-align: left !important;
}
.van-search__action>div:nth-of-type(1){
    background: #267EF0;
    border-radius: 4px;
    font-size: 15px;
    font-family: PingFangSC-Regular,PingFang SC;
    font-weight: 400;
    color: rgba(255,255,255,1);
    padding: 0 10px;
}
.van-dialog{
    border-radius:6px;
}


.listContent{
    position: relative;
    width: 100%;
    background: #fff;
    padding: 0 10px;
    box-sizing: border-box;
    border-radius: 4px;
    margin: 10px auto;
}
.topLine{
    font-size: 16px;
    color: #3B3B3B;
    font-weight: 500;
    padding: 2px 0 8px;
}

.listCard{
    padding: 10px;
    box-sizing: border-box;
}
.listLine{
    padding: 2px 0;
    display: flex;
    font-size: 15px;
    color: #666666;
    letter-spacing: 0.09px;
    font-weight: 400;
}
.tel{
    color: #2077EF;
    text-decoration: underline;
}



.nodate{
    margin: 20px auto;
    text-align: center;
    color:#888;
    font-size: 16px;
}