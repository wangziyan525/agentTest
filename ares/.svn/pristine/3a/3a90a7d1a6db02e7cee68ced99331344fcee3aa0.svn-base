
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>重置签名</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="./css/weui.min.css" />
    <link rel="stylesheet" href="./css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="./css/weui.min.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/replaceSign.css?v=0.4.6">
    <!-- <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vant@2.12/lib/index.css"/> -->
    <style>
        .weui-dialog__bd{
            color: #000 !important;
        }
    </style>
</head>
<body>

<div id="app" v-cloak>

    <div class="searchDiv">
        <input class="weui-input" id="keywords" type="text" placeholder="请输入员工号">
        <p class="searchBtn" @click="search()">搜索</p>
    </div>

    <div v-if="isShow">
        <!-- 基本信息 -->
        <div class="basis" id="infosDiv" style="border-radius: 0">
            <div class="infos">
                <span>姓名</span><span>{{info.idcardname}}</span>
            </div>
            <div class="infos">
                <span>机构名称</span><span>{{info.bu_descr}}</span>
            </div>
        </div>
        <div @click="reset()" style="font-size:16px;margin-top: 20px;text-align: center;width: 90%;margin-left: 5%;color: #fff;height: 50px;line-height: 50px;background: #0764FF;border-radius: 5px">重置</div>
    </div>
    <div v-else class="nodate">
        暂无签名记录
    </div>
</div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/fastclick.js"></script>
<script src="./../common/js/watermark.js?v=1.2"></script>
<script>
    // var vConsole = new VConsole();
    var appApproal = {
        query: base.context + "misconduct/getMisconductSign.xa",//查询
        reset:base.context + "misconduct/delMisconductSign.xa",  //重置
    };

    // // //初始化微信社区
    $(function() {
        initJSSDK(['hideAllNonBaseMenuItem','translateVoice',]);
        wx.ready(function() {
            wx.hideAllNonBaseMenuItem();
        });
    });

    function getUserFinish() {
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        action();
    }


    function action() {
        new Vue({
            el: "#app",
            data: {

                // 页面信息
                isShow:false, //整体是否显示（未立优化页面）
                //基础信息
                info:{
                    bu_descr:'',  //机构名称
                    idcardname:'',  //姓名
                    id:'',
                },
                functionName:'',
                batch:"",


            },
            created: function () {
                this.functionName=this.getQueryString("functionName");
                this.batch=this.getQueryString("batch");
            },
            mounted: function () {
            },
            updated:function(){
            },
            methods: {
                //根据员工号搜索
                search(){
                    var token = localStorage.getItem("X-Token");
                    let _this = this;
                    let params = {};
                    params.humancode = $('#keywords').val();
                    params.functionName=_this.functionName;
                    params.batch=_this.batch;
                    $.ajax({
                        url: appApproal.query,
                        type: 'POST',
                        beforeSend: function (XMLHttpRequest) {
                            $.showLoading('数据加载中');
                            XMLHttpRequest.setRequestHeader('X-Token', token);
                        },
                        contentType: 'application/json;charset=utf-8;',
                        data: JSON.stringify(params),
                        success: function (data) {
                            if (typeof data === "string") {
                                data = $.parseJSON(data);
                            }
                            if (data.retcode == "success") {
                                
                                if(data.data && data.data.length>0){
                                    _this.isShow = true;
                                //信息显示
                                _this.showInfo(data.data);
                                }
                                else{
                                    _this.isShow = false;
                                }


                            }else{
                                
                                vant.Dialog.alert({
                                    message: data.retmsg
                                }).then(() => {
                                    wx.closeWindow();
                                }); 
                            }
                        },
                        error: function (xhr, status, error) {
                            $.hideLoading();
                        },
                        complete: function (xhr) {
                            $.hideLoading();
                        }
                    })
                },

                //信息展示
                showInfo(data){
                    let res = data[0];
                    //基础信息展示
                    this.info.bu_descr = res.bu_descr+'-'+res.ssbm;
                    this.info.idcardname = res.idcardname;
                    this.info.id = res.id;
                },

                //重置
                reset(){
                    var token = localStorage.getItem("X-Token");
                    let _this = this;
                    let params = {};
                    params.humancode = $('#keywords').val();
                    params.batch=_this.batch;
                    $.ajax({
                        url: appApproal.reset,
                        type: 'POST',
                        beforeSend: function (XMLHttpRequest) {
                            $.showLoading('数据加载中');
                            XMLHttpRequest.setRequestHeader('X-Token', token);
                        },
                        contentType: 'application/json;charset=utf-8;',
                        data: JSON.stringify(params),
                        success: function (data) {
                            if (typeof data === "string") {
                                data = $.parseJSON(data);
                            }
                            if (data.retcode == "success") {
                                vant.Dialog.alert({
                                    message: '重置成功'
                                }).then(() => {
                                    window.location.reload();
                                });
                            }else{
                                vant.Dialog.alert({
                                    message: res.retmsg
                                }).then(() => {
                                    
                                });
                            }
                        },
                        error: function (xhr, status, error) {
                            $.hideLoading();
                        },
                        complete: function (xhr) {
                            $.hideLoading();
                        }
                    });
                },


                //转换转义字符
                decode(str){
                    let s = '';
                    if(str.length == 0){
                        return '';
                    }else {
                        s = str.replace(/&lt;/g,'<');
                        s = str.replace(/&gt;/g,'>');
                        s = str.replace(/&quot;/g,'""');
                        return  s;
                    }
                },

                //获取url参数
                getQueryString(name) {
                    let reg = new RegExp("(^|&)" + name + "=([^&]*)(&|$)", "i");
                    let r = window.location.search.substr(1).match(reg);
                    if (r != null)
                        return (r[2]);
                    return null;
                },
            }
        });

    }


</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script></html>