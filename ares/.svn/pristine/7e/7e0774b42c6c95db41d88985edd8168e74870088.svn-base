[v-cloak]{
    display: none;
}
.hrefPth{
    text-decoration: underline !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color:#f6f6f6;
    overflow:hidden;
}
.weui-dialog{
    border-radius: 12px !important;
}
.weui-dialog .weui-dialog__hd{
    padding: 2em 1.5em 1.5em;
}
*{
    -webkit-overflow-scrolling: touch !important;
    -webkit-tap-highlight-color: rgba(0,0,0,0) !important;
    -webkit-tap-highlight-color: transparent !important;
    font-family: 'Microsoft YaHei', Tahoma, Arial, sans-serif;
}
.nodata{
    font-size: 16px;
    height: 200px;
    line-height: 200px;
    color: #999;
    width: 100%;
    text-align: center;
}
/*--------------------------------------------------------------------------- 基础信息 -----------------------------------------------*/
/****************banner\页签开始****************/
.banner{
    width:100%;
    vertical-align: bottom;
    height: 170px;
}
.tab{
    height: 50px;
    display: flex;
    justify-content: start;
    font-size: 15px;
    border-bottom: 1px solid #e9e9e9;
    align-items: center;
    padding: 0 15px;
}
.tab>div{
    width: 16%;
    height: 25px;
    line-height: 25px;
    background: #f3f3f3;
    color: #999;
    text-align: center;
    border-radius: 15px;
    margin-right: 15px;
}
.selectDate{
    height: 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom-left-radius: 5px;
    border-bottom-right-radius: 5px;
    background: url('../image/right.png') no-repeat right;
    background-size: 2%;
    background-position-x: 97%;
    background-position-y: 51%;
    font-size: 15px;
    padding: 0 15px;
    font-weight: 500;
}
.activeTab{
    background: #3975c6 !important;
    color: #fff !important;
    border-radius: 15px;
}
/****************banner\页签结束****************/

/****************列表查询开始****************/
.listParts{
    background: #fff;
    height: 50px;
    line-height: 50px;
}
.listLine{
    display: flex;
    justify-content: space-between;
    font-size: 15px;
    padding: 0 13px 0 15px;
    border-top: 1px solid #eee;
}
.listLine>div:first-child{
    width: 80%;

}
.containList img{
    width: 11%;
    vertical-align: middle;
}
.listLine>div:last-child{
    width: 20%;
    text-align: right;
}
.rule{
    width: 92%;
    margin-left: 4%;
    background: #fff;
    border-radius: 5px;
    box-sizing: border-box;
    padding: 10px;
    line-height: 2;
    font-size: 14px;
    margin-bottom: 10px;
}
/****************列表查询结束****************/
.listTitle{
    display: flex;
    align-items: center;
    background: #d2e3e4;
    margin-top: 10px;
    padding: 10px 15px;
}
.listInfo{
    display: flex;
    align-items: center;
    background: #fff;
    padding: 10px 15px;
}
.listTitle>p:nth-child(1),.listInfo>p:nth-child(1){
    width: 50%;
    display: flex;
    flex-wrap: wrap;
    margin-right: 15px;
    box-sizing: border-box;
}
.listTitle>p:nth-child(2),.listInfo>p:nth-child(2){
    width: 25%;
}
.listTitle>p:nth-child(3),.listInfo>p:nth-child(3){
    width: 25%;
}
.noBorder{
    border-top: 0 !important;
}
.title{
    height: 20px;
    padding: 5px 15px;
    color: #999;
}