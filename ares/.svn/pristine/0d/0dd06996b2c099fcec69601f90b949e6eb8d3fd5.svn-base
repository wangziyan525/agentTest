[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    overflow-y: auto;
}
/* ------------------------------------------------ 列表 -------------------------------------- */
.datailBox{
    flex: 1;
    overflow-y: auto;
    padding: 0 12px 10px;
    box-sizing: border-box;
}

.datailBox .detail{
    width: 100%;
    background-color: #fff;
    border-radius: 4px;
    margin-top: 10px;
    font-size: 15px;
}
.datailBox .detail .dt{
    width: 100%;
    display: flex;
    justify-content: space-between;
    position: relative;
    padding: 15px 12px;
    box-sizing: border-box;
}
.datailBox .detail .dt:after{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #E6E7E8;
    color: #E6E7E8;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.datailBox .detail .dt:last-child:after{
    display: none;
}

.datailBox .detail .dt span:nth-child(1){
    width: 80px;
    margin-right: 20px;
    color: #666;
}
.datailBox .detail .dt span:nth-child(2){
    flex: 1;
    word-break: break-all;
    display: flex;
    justify-content: flex-end;
    color: #333;
}

.datailBox .detail .filesShow{
    width: 100%;
}
.datailBox .detail .filesShow .title{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    font-size: 15px;
    color: #333;
    line-height: 20px;
    position: relative;
}
.datailBox .detail .filesShow .title:after{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #E6E7E8;
    color: #E6E7E8;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.datailBox .detail .filesShow .files{
    width: 100%;
    padding: 0px 12px;
    box-sizing: border-box;
}
.datailBox .detail .filesShow .files .pngFile{
    width: 50px;
    border-radius: 6px;
}
.datailBox .detail .filesShow .files .pngFile img{
    display: block;
    width: 100%;
    border-radius: 6px;
}
.datailBox .detail .filesShow .files .videoFile{
    width: 100%;
}
.datailBox .detail .filesShow .files .videoFile video{
    width: 100%;
    height: -webkit-calc(100% - 100px);
    height: calc(100% - 10px);
    border-radius: 7px;
    object-fit: fill;
    z-index: 10;
    border-radius: 7px;
}
.datailBox .detail .filesShow .files span{
    display: block;
    padding: 13px 0;
    font-size: 14px;
    line-height: 20px;
    color: #4675c9;
    position: relative;
}
.datailBox .detail .filesShow .files span:after{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px dashed #E6E7E8;
    color: #E6E7E8;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
/* -------------------------------------- 查看视频 --------------------------- */
.main2{
    width: 100%;
    min-height: 70vh;
    max-height: 70vh;
    overflow-y: auto;
    padding: 20px 13px;
    box-sizing: border-box;
}
.main2 .ship{
    width: 100%;
}
.main2 .ship video{
    width: 100%;
    height: -webkit-calc(100% - 100px);
    height: calc(100% - 10px);
    border-radius: 7px;
    object-fit: fill;
    z-index: 10;
    border-radius: 7px;
}
.main2 .videoTitle{
    width: 100%;
    font-size: 15px;
    color: #333;
    line-height: 22px;
    word-break: break-all;
    margin-top: 30px;
}
