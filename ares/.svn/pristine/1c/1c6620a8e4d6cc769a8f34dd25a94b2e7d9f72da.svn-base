<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
    name="viewport" />
  <link rel="stylesheet" href="../common/css/weui.min.css">
  <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
  <link rel="stylesheet" href="../common/css/vant-2.12.css">
  <link rel="stylesheet" href="css/test.css">

  <title>保险资质备案考试</title>
</head>

<body>
  <div id="app"  v-cloak>
    <div class="container">
      <div class="progress-container">
        <span><span style="color: #267EF0;">第{{ currentIndex + 1 }}题</span>/共{{ totalQuestions }}题</span>
        <span style="color: #F02626">剩余时间: {{ formattedTime }}</span>
      </div>

      <div class="question-container" v-if="currentQuestion">
        <div class="question-title">
          <!-- <span class="question-type"></span> -->
          {{ currentIndex + 1 }}、（{{ getQuestionTypeText(currentQuestion.question_type) }}）{{ currentQuestion.question }}
        </div>

        <div v-if="currentQuestion.question_type === 'SINGLE' || currentQuestion.question_type === 'MULTIPLE'">
          <div class="options">
            <div v-for="(option, key) in options" :key="key" class="option" :class="{ selected: isSelected(key) }"
              @click="selectOption(key)">
              <div class="option-text">{{ key.toUpperCase() }}、</div>
              <div class="option-text">{{ option }}</div>
            </div>
          </div>
        </div>

        <div v-else-if="currentQuestion.question_type === 'JUDGE'" class="judge-options">
          <div class="option judge-option" :class="{ selected: isSelected('A') }" @click="selectOption('A')">
            <div class="option-text"><i class="fas fa-check"></i></div>
            <div class="option-text">正确</div>
          </div>
          <div class="option judge-option" :class="{ selected: isSelected('B') }" @click="selectOption('B')">
            <div class="option-text"><i class="fas fa-times"></i></div>
            <div class="option-text">错误</div>
          </div>
        </div>
      </div>

      <div class="navigation">
        <button class="btn-prev" :disabled="currentIndex === 0" @click="prevQuestion">
         上一题
        </button>

        <button v-if="currentIndex < totalQuestions - 1" class="btn-next" @click="nextQuestion">下一题
        </button>

        <button v-else class="btn-submit" @click="submitExam('2')">
          <i class="fas fa-paper-plane"></i> 提交答卷
        </button>
      </div>
    </div>
  </div>

</body>
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="../common/js/watermark.js"></script>
<script src="../common/js/server.js"></script>
<script src="js/test.js"></script>
<script src="../common/js/vConsole.min.js"></script>

<script>
  //var vConsole = new VConsole();
  initJSSDK(['hideAllNonBaseMenuItem', 'invoke', 'selectEnterpriseContact'])
  wx.ready(function () {
    wx.hideAllNonBaseMenuItem();
  });
  function getUserFinish() {
    var username = $.parseJSON($.cookie("user")).name;
    __canvasWM({
      content: username
    });
    initFun()
  }
    // initFun()
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>

</html>