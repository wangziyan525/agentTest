function filiterParam (param1, param2, keys) {
    let newObjs = {};
    for(key1 in param1) {
        for (key2 in param2) {
            if (key2 == key1) {
                newObjs[key1] = param1[key1]
            }
        }
    };

    var newObj=Object.assign(param2,newObjs)
    var text="";
    //全部填写
    //部分填写
    //未填写
    var i=0;
    var Objectlength=Object.keys(newObj).length;

    for (key1 in newObj) {
        if (newObj[key1] != '') 
        ++i;
    }
   
    if(i==Objectlength){
        text= "全部已填写"
    }else if(i==0){
        text= "全部待填写"
    }else{

        if (keys) {
            //必填项
            for (key1 in newObj) {
                for (key2 in keys) {
                    console.log(keys[key2])
                    if (key1 == keys[key2]) {//必填项未完成
                        if (newObj[key1] == '') {
                            text= "必填项未完成"
                            return text;
                        }
                        
                    }
                }
            }
            //必填项已完成
            text= "必填项已完成"
            return text;
        } 

        text= "部分已填写"
    }

    return text;


    
    
}