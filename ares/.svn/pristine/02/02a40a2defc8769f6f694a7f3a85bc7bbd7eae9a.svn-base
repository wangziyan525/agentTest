<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>资本境内付</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../common/css/weui.min.css" />
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/detail.css?v=0.0.7">
</head>
<body>

    <div id="app" v-cloak>


        <!-- 审批信息 -->
        <template v-if="!isApproval && isApproved == 1">
            <div class="baseInfo">
                <div class="info"><span>企业名称</span><span>{{infos.CUST_NAME}}</span></div>
                <div class="info" v-if="approvedInfos.ISPASS == 'Y' || approvedInfos.ISPASS == 'N' " @click="showFlow">
                    <span>审批状态</span>
                    <span v-if="infos.APPROVE_STAT == '4'" class="status1">审批通过</span>
                    <span v-if="infos.APPROVE_STAT == '3'" class="status2">审批拒绝</span>
                    <span v-if="infos.APPROVE_STAT == '2'" class="status3">等待复核</span>
                    <i><img src="./image/jinru.png" alt=""></i>
                </div>
                <div class="info" v-if="infos.TRAN_STATE && infos.TRAN_STATE != ''">
                    <span>转账状态</span>
                    <span :class="infos.TRAN_STATE == 4?'status1':'status2'">{{readTranStatus(infos.TRAN_STATE)}}</span>
                </div>
                <div class="info" v-if=" infos.TRAN_STATE == 5 && infos.ERROR_MSG && infos.ERROR_MSG != ''"><span>失败理由</span><span>{{infos.ERROR_MSG}}</span></div>
                <div class="info" v-if="approvedInfos.ISPASS == 'Y' || approvedInfos.ISPASS == 'N' "><span>审批日期</span><span>{{approvedInfos.SUBMIT_TIME}}</span></div>
            </div>
        </template>
       

        <!-- 基础信息 -->
        <div class="baseInfo">
            <div class="info" v-if="isApproval"><span>企业名称</span><span>{{infos.CUST_NAME}}</span></div>
            <div class="info" v-if="!isApproval && isApproved == 0"><span>企业名称</span><span>{{infos.CUST_NAME}}</span></div>
            <div class="info"><span style="width: 170px;">资本项⽬业务编号</span><span>{{infos.BUSINESS_NUM}}</span></div>
            <div class="info"><span>付款账号</span><span>{{infos.ACCT_NO}}</span></div>
            <div class="info"><span>付款户名</span><span>{{infos.ACCT_NAME}}</span></div>
            <div class="info"><span>付款账号类型</span><span>{{infos.PAY_ACCT_TY==0?'结汇待支付账户':infos.PAY_ACCT_TY==1?'跨境人民币资本项目账户':'--'}}</span></div>
        </div>


        <div class="baseInfo">
            <div class="info"><span>交易⾦额</span><span>{{infos.TRAN_AMT}}</span><em>元</em></div>
            <div class="info"><span>收款账号</span><span>{{infos.RCV_ACCT}}</span></div>
            <div class="info"><span>收款户名</span><span>{{infos.RCV_NAME}}</span></div>
            <div class="info"><span>收款银⾏</span><span>{{infos.RCV_BRANCH_NAME}}</span></div>
        </div>

        <div class="baseInfo">
            <div class="info1" @click="wactchPdf(1)">
                <span>资本项⽬收⼊⽀付（含意愿结汇）命令函</span>
                <span>查看详情</span>
                <i><img src="./image/jinru.png" alt=""></i>
            </div>
            <div class="info1" @click="wactchPdf(2)">
                <span>境内汇款申请书</span>
                <span>查看详情</span>
                <i><img src="./image/jinru.png" alt=""></i>
            </div>
            <div class="info1" @click="wactchPdf(3)" v-if="infos.TRAN_STATE && infos.TRAN_STATE == '4'">
                <span>转账凭证</span>
                <span>查看详情</span>
                <i><img src="./image/jinru.png" alt=""></i>
            </div>
        </div>

        <!-- 审批 -->
        <template v-if="isApproval">
            <div class="baseInfo" v-if="LEVEL == 1">
                <div class="info">
                    <span>复核⼈</span>
                    <input type="text" placeholder="请选择" v-model="choosedName" readonly @click="choosePickerPeople(1)">
                    <i><img src="./image/jinru.png" alt=""></i>
                </div>
            </div>
            <div class="baseInfo" v-if="LEVEL == 2">
                <div class="info">
                    <span>会计主管</span>
                    <input type="text" placeholder="请选择" v-model="choosedName" readonly @click="choosePickerPeople(2)">
                    <i><img src="./image/jinru.png" alt=""></i>
                </div>
            </div>
        </template>
        

        <div style="width: 100%;height: 50px;"></div>


        <!-- 按钮 -->
        <template v-if="isApproval">
            <div class="btn">
                <span class="smallBtn" @click="toRefuse">拒绝</span>
                <span class="smallBtn" @click="toApproval(0)">同意</span>
            </div>
        </template>
        <template v-else>
            <div class="btn">
                <span class="bigBtn" @click="back">返回</span>
            </div>
        </template>

        <!-- 拒绝弹框 -->
        <van-popup v-model="refusePopup">
            <div class="refuseModel">
                <div class="title">审批拒绝</div>
                <div class="refuseCt">
                    <div class="refuseTip"><em>*</em>请输⼊您要拒绝的原因！（必填）</div>
                    <textarea cols="30" rows="4" placeholder="请输⼊拒绝原因" v-model.trim="reason" maxlength="30"></textarea>
                    <div class="refuseBtn">
                        <span @click="refusePopup=false">取消</span>
                        <span @click="toApproval(1)">确定</span>
                    </div>
                </div>
            </div>
        </van-popup>

        <!-- 下拉选人 -->
        <van-popup v-model="showPickerPeople" position="bottom">
            <van-picker
                    show-toolbar
                    :columns="choosePeopleList"
                    @confirm="onPeopleConfirm"
                    @cancel="showPickerPeople=false"
            >
            </van-picker>
        </van-popup>

        <!-- 流转信息弹框 -->
        <van-popup v-model="flowPopup" round position="bottom">
            <div class="flowModel">
                <div class="title">查看审批流程</div>
                <div class="flowCt">
                    <template v-for="(it,i) in flowList">
                        <div class="flow">
                            <div class="left"><i><img src="./image/flow.png" alt=""></i></div>
                            <div class="right">
                                <div class="peopleType">{{i==0?'审批人':i==1?'审批复核':'主管审批'}}</div>
                                <div class="nameTime">
                                    <div class="name">
                                        {{it.TELNAME}} 
                                        (   
                                            <span v-if="it.ISPASS == 'Y'" class="status1">审批通过</span>
                                            <span v-if="it.ISPASS == 'N'" class="status2">审批拒绝</span>
                                            <span v-if="it.ISPASS == ''" class="status3">待审批</span>
                                        )
                                    </div>
                                    <div class="time">{{it.SUBMIT_TIME}}</div>
                                </div>
                                <template v-if="it.REFUSED_MSG && it.REFUSED_MSG != ''">
                                    <div class="reason">拒绝原因：{{it.REFUSED_MSG}}</div>
                                </template>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </van-popup>




    </div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/jwxwork.js"></script>
<script type="text/javascript" src="../common/js/watermark.js?v=1.2"></script>
<script type="text/javascript" src="../common/js/vConsole.min.js"></script>
<script type="text/javascript" src="../common/js/server.js"></script>
<script type="text/javascript" src="./js/detail.js?v=20250814042"></script>
<script>

    // var vConsole = new VConsole();

    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });


    //初始化微信社区
    $(function () {
        initJSSDK([ 'hideAllNonBaseMenuItem','invoke','chooseImage','uploadImage','previewImage']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });


    function getUserFinish() {
        action();
    }


</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
