[v-cloak]{
    display: none;
}

html, body {
    min-height: 100vh;
    background-color: #f3f4f6;
}
.topArea{
    background: #FFFFFF;
    margin: 8px 0px;
}
.listline{
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0px 16px;
    padding: 13px 0px;
    border-bottom: 1px solid rgba(155, 155, 155, 0.5)
}
.listline>div:nth-child(1){
    font-family: PingFangSC-Regular;
    font-size: 17px;
    color: #666666;
    font-weight: 400;

}
.listline>div:nth-child(2){
    font-family: PingFangSC-Regular;
font-size: 17px;
color: #000000;
text-align: right;
font-weight: 400;

}
.topArea .listline:last-child{
    border-bottom:none

}
.midArea{
    background: #FFFFFF;
    margin-bottom: 9px;
}
.midArea .listline:last-child{
    border-bottom:none
}
.btmArea{
    background: #FFFFFF
}

.btmImg{
    width: 79px;
    height: 79px;
    
}
.btmArea .listline{
    border-bottom:none
}
.btmArea .listline:nth-child(2){
    justify-content: flex-start;
    padding-top:0px
}
.imgTitle{
    font-family: PingFangSC-Regular;
font-size: 12px;
color: #A4A4A4;
text-align: center;
font-weight: 400;
text-align: center
}
.testBtn{
    background: #267EF0;
border-radius: 6px;
font-family: PingFangSC-Regular;
font-size: 17px;
color: #FFFFFF;
text-align: center;
font-weight: 400;
padding: 11px 0px;
margin: 25px auto;
width: 90%;
}