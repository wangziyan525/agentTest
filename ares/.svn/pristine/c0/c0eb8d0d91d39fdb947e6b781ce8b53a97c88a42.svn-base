[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    overflow-y: auto;
}
/* ---------------------------- 职务模块 ----------------------- */
.positionModle{
    width: 100%;
    padding: 30px 16px;
    box-sizing: border-box;
    background-color: #fff;
}
.positionModle .title{
    width: 100%;
    font-size: 16px;
    line-height: 24px;
    color: #000;
    margin-bottom: 12px;
    font-weight: bold;
}
.positionModle input{
    display: block;
    width: 100%;
    padding: 13px 14px;
    box-sizing: border-box;
    font-size: 15px;
    color: #9DA0A3;
    line-height: 20px;
    background: #F6F7F9;
    border-radius: 4px;
    border: none;
    outline: none;
}
/* ---------------------------- 职务模块 ----------------------- */
.btn{
    width: 100%;
    padding: 0 16px;
    box-sizing: border-box;
}
.btn .bigBtn{
    width: 100%;
    font-size: 15px;
    line-height: 20px;
    padding: 12px 0;
    box-sizing: border-box;
    text-align: center;
    background: #267EF0;
    border-radius: 6px;
    color: #fff;
}

/* ---------------------------- 选择 ----------------------- */
.examine{
    width: 100%;
    margin-top: 10px;
    background-color: #fff;
    padding: 15px 12px;
    box-sizing: border-box;
    display: flex;
}
.examine span{
    display: block;
    width: 150px;
    font-size: 15px;
    line-height: 20px;
    color: #333;
}
.examine i{
    display: flex;
    width: 12px;
    align-items: center;
    justify-content: flex-end;
}
.examine i img{
    display: block;
    width: 50%;
}
.examine input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    background-color: #fff;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 15px;
    color: #333;
    line-height: 20px;
    border-radius: 6px;
    text-align: right;
}
/* ------------------------------------- 遮罩层 -------------------------------------------- */
.popupContent{
    width: 100%;
    height: 100%;
}
.popupContent .choosePeopleList{
    width: 100%;
    padding: 13px 16px;
    box-sizing: border-box;
    display: flex;
    position: relative;
    justify-content: space-between;
    position: relative;
}
.popupContent .choosePeopleList:before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.popupContent .choosePeopleList .left{
    font-size: 15px;
    color: #000;
    line-height: 20px;
}
.popupContent .choosePeopleList .right{
    display: flex;
    align-items: center;
    justify-content: flex-end;
}
.popupContent .choosePeopleList .right img{
    display: block;
    width: 20px;
}