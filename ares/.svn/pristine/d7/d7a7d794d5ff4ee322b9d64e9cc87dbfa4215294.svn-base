<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover" name="viewport" />
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="css/common.css">
    <link rel="stylesheet" href="css/index.css">
</head>
<body>
    <div class="container" v-cloak>
        <section
          class="section-container main-container">
          <div>
            <div class="session-item-active">
                <div  class="session-active-title display align-item-center color333333 ">基本信息</div>
            </div>
            <div class="session-item-container display border-none line-top">
                <div class="session-item-title display align-item-center color666666">贷款类型</div>
                <div class="session-item-text flex display color333333 justify-content-right">{{ dataInfo.loan_tp || '' }}</div>
            </div>
            <div class="session-item-container display border-none line-top">
                <div class="session-item-title display align-item-center color666666">客户姓名</div>
                <div class="session-item-text flex display color333333 justify-content-right">{{ dataInfo.CustNm || '' }}</div>
            </div>
            <div class="session-item-container display border-none line-top">
                <div class="session-item-title display align-item-center color666666">身份证号</div>
                <div class="session-item-text flex display color333333 justify-content-right">{{ dataInfo.IdentId || '' }}</div>
            </div>
            <div class="session-item-container display border-none line-top">
                <div class="session-item-title display align-item-center color666666">客户手机号</div>
                <div
                    class="session-item-text flex display justify-content-right decoration_3975c6"
                    @click="callPhoneHandle(dataInfo.iphone)">{{ dataInfo.iphone ? dataInfo.iphone.substring(0, 3) + ' **** ' + dataInfo.iphone.substring(7) : '' }}</div>
            </div>
          </div>
        </section>
        <section
          class="section-container main-container">
          <div>
            <div class="session-item-active">
                <div  class="session-active-title display align-item-center color333333 ">风险提示</div>
            </div>
            <div class="session-item-container display border-none line-top">
                <div class="session-item-title display align-item-center color666666 text-align-justify">客户贷后检查存在风险事项</div>
            </div>
            <!-- <div class="session-item-container border-none line-top" v-if="dataInfo.CntnsThrMoIsOdue == '是' || dataInfo.exe_per == '是' || dataInfo.small_loan == '是'">
                <div class="display align-item-center color333333 text-align-justify pad_bottom_10">
                    高风险（建议及时控制授信，并完成贷后现场检查）
                </div>
                <div class="display align-item-center color333333 text-align-justify pad_5" v-if="dataInfo.CntnsThrMoIsOdue == '是'">
                    连续三个月逾期
                </div>
                <div class="display align-item-center color333333 text-align-justify pad_5" v-if="dataInfo.exe_per == '是'">
                    被法院列为失信被执行人
                </div>
                <div class="display align-item-center color333333 text-align-justify pad_5" v-if="dataInfo.small_loan == '是'">
                    小额信贷公司是否有逾期
                </div>
            </div> -->
            <div class="session-item-container border-none line-top" v-if="highRiskList.length > 0">
                <div class="display align-item-center color333333  text-align-justify pad_bottom_10">
                    高风险
                </div>
                <div
                    class="display align-item-center color333333 text-align-justify pad_5"
                    v-for="(item, index) in highRiskList">
                    {{ index + 1 }}.{{ item.lable }}
                </div>
            </div>
            <div class="session-item-container border-none line-top" v-if="mediumRiskList.length > 0">
                <div class="display align-item-center color333333 text-align-justify pad_bottom_10">
                    低风险
                </div>
                <div
                    class="display align-item-center color333333 text-align-justify pad_5"
                    v-for="(item, index) in mediumRiskList">
                    {{ index + 1 }}.{{ item.lable }}
                </div>
                <!-- <div class="display align-item-center color333333 text-align-justify pad_5">
                    1.中风险高风险高风险高风险高风险高风险
                </div>
                <div class="display align-item-center color333333 text-align-justify pad_5">
                    2.中风险高风险高风险高风险高风险高风险
                </div>
                <div class="display align-item-center color333333 text-align-justify pad_5">
                    3.中风险高风险高风险高风险高风险高风险
                </div> -->
            </div>
          </div>
        </section>
    </div>
</body>
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/clipboard.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="../common/js/watermark.js"></script>
<script src="../common/js/server.js"></script>
<script src="./js/index.js?v=20250905"></script>
<script>
    $(function () {
        initJSSDK(['hideAllNonBaseMenuItem']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        })
    });
    function getUserFinish() {
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }
    // initFun()
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>