[v-cloak]{
    display: none;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Microsoft YaHei', sans-serif;
}

body {
  /* background: linear-gradient(135deg, #1a2980, #26d0ce); */
  color: #333;
  padding: 20px;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.container {
  width: 100%;
  max-width: 800px;
  background: white;
  border-radius: 15px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.header {
  background: linear-gradient(90deg, #2c3e50, #4a6491);
  color: white;
  padding: 20px;
  text-align: center;
  position: relative;
}

.header h1 {
  margin-bottom: 10px;
  font-size: 28px;
}

.timer {
  position: absolute;
  top: 20px;
  right: 20px;
  background: rgba(255, 255, 255, 0.2);
  padding: 10px 15px;
  border-radius: 50px;
  font-size: 18px;
  font-weight: bold;
  display: flex;
  align-items: center;
}

.timer i {
  margin-right: 8px;
  font-size: 20px;
}

.timer.warning {
  color: #ff9900;
  animation: pulse 1s infinite;
}

.timer.danger {
  color: #ff4757;
  animation: pulse 0.5s infinite;
}

.progress-container {
  padding: 15px 20px;
  background: #f8f9fa;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #e9ecef;
}

.progress-bar {
  height: 8px;
  flex-grow: 1;
  background: #e9ecef;
  border-radius: 4px;
  margin: 0 15px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3498db, #2ecc71);
  border-radius: 4px;
  transition: width 0.3s ease;
}

.question-container {
  padding: 25px;
}

.question-title {
  font-family: PingFangSC-Semibold;
  font-size: 17px;
  color: #000000;
  text-align: justify;
  line-height: 24px;
  font-weight: 600;
  margin-bottom: 25px; 
  padding: 15px;
  background: #f8f9fa;
  border-left: 5px solid #3498db;
  border-radius: 5px;
}

.question-type {
  display: inline-block;
  padding: 5px 12px;
  background: #3498db;
  color: white;
  border-radius: 20px;
  font-size: 14px;
  margin-right: 12px;
}

.options {
  margin-left: 10px;
}

.option {
  padding: 15px;
  margin-bottom: 12px;
  border: 2px solid #e9ecef;
  border-radius: 10px;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
}

.option:hover {
  background: #f1f8ff;
  border-color: #c4e1ff;
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
}

.option.selected {
  background: #e1f0ff;
  border-color: #3498db;
  font-weight: bold;
}

.option-prefix {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #e9ecef;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 15px;
  font-weight: bold;
  flex-shrink: 0;
}

.option.selected .option-prefix {
  background: #3498db;
  color: white;
}

.navigation {
  display: flex;
  justify-content: space-between;
  padding: 20px;
  border-top: 1px solid #e9ecef;
}

button {
  padding: 12px 25px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 16px;
  font-weight: bold;
  transition: all 0.3s;
  display: flex;
  align-items: center;
}

button i {
  margin-right: 8px;
}

button:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.btn-prev {
  background: #95a5a6;
  color: white;
}

.btn-next {
  background: #267EF0;
  color: white;
}

.btn-submit {
  background: linear-gradient(90deg, #2ecc71, #27ae60);
  color: white;
  padding: 12px 30px;
}

.btn-prev:hover:not(:disabled) {
  background: #7f8c8d;
  transform: translateY(-2px);
}

.btn-next:hover:not(:disabled) {
  background: #2980b9;
  transform: translateY(-2px);
}

.btn-submit:hover:not(:disabled) {
  background: linear-gradient(90deg, #27ae60, #219653);
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(46, 204, 113, 0.4);
}

.judge-options {
  display: flex;
  gap: 15px;
}

.judge-option {
  flex: 1;
  text-align: center;
}

.multiple-hint {
  font-size: 14px;
  color: #7f8c8d;
  margin-bottom: 15px;
  font-style: italic;
  padding-left: 15px;
}

.time-up-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  padding: 40px;
  border-radius: 15px;
  text-align: center;
  max-width: 500px;
  width: 90%;
  animation: scaleIn 0.5s;
}

.modal-content h2 {
  color: #ff4757;
  margin-bottom: 20px;
  font-size: 28px;
}

.modal-content p {
  margin-bottom: 30px;
  font-size: 18px;
  line-height: 1.6;
}

.modal-btn {
  background: #3498db;
  color: white;
  border: none;
  padding: 12px 30px;
  border-radius: 8px;
  font-size: 16px;
  cursor: pointer;
  transition: all 0.3s;
}

.modal-btn:hover {
  background: #2980b9;
  transform: translateY(-2px);
}

@keyframes pulse {
  0% {
    opacity: 1;
  }

  50% {
    opacity: 0.6;
  }

  100% {
    opacity: 1;
  }
}

@keyframes scaleIn {
  from {
    transform: scale(0.9);
    opacity: 0;
  }

  to {
    transform: scale(1);
    opacity: 1;
  }
}

@media (max-width: 600px) {
  .header h1 {
    font-size: 22px;
  }

  .timer {
    position: static;
    margin-top: 10px;
    justify-content: center;
  }

  .judge-options {
    flex-direction: column;
  }

  .navigation {
    flex-direction: column;
    gap: 15px;
  }

  .navigation button {
    width: 100%;
    justify-content: center;
  }
}