[v-cloak]{
    display: none;
}
html,body{
    width: 100%;
    min-height: 100vh;
    background-color:#f6f6f6;
}
*{
    -webkit-overflow-scrolling: touch !important;
    -webkit-tap-highlight-color: rgba(0,0,0,0) !important;
    -webkit-tap-highlight-color: transparent !important;
    font-family: 'Microsoft YaHei', Tahoma, Arial, sans-serif;
}
.weui-dialog{
    border-radius: 8px !important;
    font-size: 17px;
}
.weui-dialog .weui-dialog__hd{
    padding: 20px;
}
.weui-dialog__ft,.weui-dialog__btn{
    font-size: 17px;
    color: #377ae6;
}
textarea{
    -webkit-appearance: none;
    outline: 0;
    border: 0px;
    box-sizing: border-box;
    border-bottom: 1px solid #377ae6;
    color: #377ae6;
    text-align: center;
    resize: none;
    position: relative;
    top: 2px;
    padding: 0 5px;
    max-width: 200px;
    width: 80px;
}
input{
    -webkit-appearance: none;
    outline: 0;
    border: 0px;
    box-sizing: border-box;
    border-bottom: 1px solid #377ae6;
    color: #377ae6;
    text-align: center;
    resize: none;
    position: relative;
    top: 2px;
    max-width: 300px;
    width: 80px;
}
.headContainer{
    display: flex;
    justify-content: space-between;
    background: #fff;
    padding: 15px 12px;
    align-items: center;
}
.headContainer>div:first-child{
    color: #999;
    font-size: 15px;
}
.headContainer>div:last-child{
    font-size: 16px;
}
.exmContainer{
    background: #fff;
    padding: 0px 12px 15px 12px;
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 50px;
}
.listPart{
    font-weight: 500;
    word-break: break-all;
}
.btn{
    position: fixed;
    bottom: 0;
    width: 100%;
}
.btns{
    display: flex;
}
.oneBtn{
    background: #377ae6;
    color: #fff;
    padding: 15px;
    text-align: center;
    box-sizing: border-box;
}
.prveBtn{
    background: #fff;
    color: #999;
    width: 50%;
    padding: 15px;
    text-align: center;
    box-sizing: border-box;
}
.nextBtn{
    background: #377ae6;
    color: #fff;
    width: 50%;
    padding: 15px;
    text-align: center;
    box-sizing: border-box;
}
.submit{
    background: #377ae6;
    color: #fff;
    width: 50%;
    padding: 15px;
    text-align: center;
    box-sizing: border-box;
}