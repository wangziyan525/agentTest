    },
    //经营年限   1、1年以内 2、1—3年 3、3—5年 4、5年以上  111
    'OperatingYears': {
        '1': '1年以内',
        '2': '1—3年',
        '3': '3—5年',
        '4': '5年以上'
    },

    //资金需求    企业：1、50万以内 2、50—100万 3、100—200万 4、200—500万 5、500万以上 11
