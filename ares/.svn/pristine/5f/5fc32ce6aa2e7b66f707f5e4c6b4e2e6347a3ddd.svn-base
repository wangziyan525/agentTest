    'FundingRequFarmer': {
        '1': '5万以内',
        '2': '5—10万',
        '3': '10—20万',
        '4': '20—50万',
        '5': '50万以上',
    },
    // 用途 企业：1原材料或货品采购、2设备更新、3厂房建设、4工资发放、5短期周转、6其他  111 PurposeEnterprise
    'PurposeEnterprise': {
