    },

    'Isindiviual':{
        '1': '是',
        '2': '否',
    }

}
function toOptions(dicName){
    const dict =  DICT[dicName];
    if (!dict) return[];
    return Object.entries(dict).map(([value,label]) => ({value,label})) 
}