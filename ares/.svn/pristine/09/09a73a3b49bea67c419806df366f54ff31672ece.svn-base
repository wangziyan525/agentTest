[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    overflow-y: auto;
}
/* ------------------------------------------------- 评语输入 ------------------------------- */
.scoreReason{
    width: 100%;
    padding: 0 16px;
    box-sizing: border-box;
    background-color: #fff;
}
.scoreReason .title{
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    font-size: 15px;
    line-height: 20px;
    color: #000;
}
.scoreReason textarea{
    resize: none;
    border:none;
    width: 100%;
    padding: 10px;
    box-sizing: border-box;
    background: #F5F5F5;
    border-radius: 4px;
    font-size: 15px;
    color: #333330;
    line-height: 20px;
    outline: none;
    resize: none;
    margin: 0px auto 15px;
}
/* ------------------------------------------------- 评分 ------------------------------- */
.scoreNum{
    width: 100%;
    padding: 15px 16px;
    box-sizing: border-box;
    background-color: #fff;
    margin: 10px 0;
    display: flex;
}
.scoreNum span{
    display: block;
    width: 50%;
    font-size: 15px;
    line-height: 20px;
    color: #333;
}
.scoreNum input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 14px;
    color: #333;
    line-height: 20px;
    text-align: right;
}
