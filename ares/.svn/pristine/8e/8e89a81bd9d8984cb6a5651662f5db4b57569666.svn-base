[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
/* ---------------------------------------- 搜索 --------------------------------------*/
.van-tabs__line{
    background-color: #4675C9 !important;
}
.van-tab--active{
    color: #4675C9 !important;
}
.searchModel{
    width: 100%;
    background-color: #fff;
    padding: 0px 12px 10px;
    box-sizing: border-box;
}
.searchModel .searchName{
    width: 100%;
    display: flex;
    margin-top: 10px;
}
.searchModel .searchName i{
    display: flex;
    width: 34px;
    align-items: center;
    justify-content: center;
    background: #F5F6F7;
    padding: 7px 0px;
    box-sizing: border-box;
    border-radius: 20px 0 0 20px;
}
.searchModel .searchName i img{
    display: block;
    width: 35%;
}
.searchModel .searchName .toSearch{
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 0 20px 20px 0;
    background: #F5F6F7;
    padding: 0 5px;
    box-sizing: border-box;
}
.searchModel .searchName .toSearch span{
    display: block;
    padding: 2px 12px;
    box-sizing: border-box;
    background: #3975C6;
    border-radius: 24px;
    color: #fff;
    font-size: 12px;
    line-height: 20px;
}
.searchModel .searchName input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    background: #F5F6F7;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 14px;
    color: #333;
    line-height: 20px;
    padding: 7px 0px;
    box-sizing: border-box;
}
.searchModel .searchTime{
    width: 100%;
    background-color: #fff;
    display: flex;
    justify-content: space-between;
    margin-top: 10px;
}
.searchModel .searchTime i{
    display: flex;
    width: 34px;
    align-items: center;
    justify-content: center;
    background: #F5F6F7;
    padding: 7px 0px;
    box-sizing: border-box;
    border-radius: 0 20px 20px 0;
}
.searchModel .searchTime i img{
    display: block;
    width: 35%;
}
.searchModel .searchTime input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    background: #F5F6F7;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 14px;
    color: #333;
    line-height: 20px;
    border-radius: 6px;
    padding: 7px 16px;
    box-sizing: border-box;
    border-radius: 20px 0 0 20px;
}
/* ---------------------------------------- tab --------------------------------------*/
.tabs{
    width: 100%;
}
/* ---------------------------------------- 列表 --------------------------------------*/
.mainModel{
    width: 100%;
    flex: 1;
    overflow-y: auto;
    padding: 10px 12px;
    box-sizing: border-box;
}
/* ------- 没有列表 -------- */
.noList img{
    display: block;
    width: 70%;
}
.noList span{
    margin-top: 10px;
    color: #333;
    line-height:32px;
    font-size:15px;
}
.noList{
    width: 94%;
    height: 100px;
    margin: 30% auto 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #000000;
    line-height:32px;
}
.noList img{
    width:55%;
}
/* ------- 有列表 -------- */
.mainModel .list{
    width: 100%;
    padding: 16px;
    box-sizing: border-box;
    border-radius: 6px;
    background: #fff;
    display: flex;
    flex-direction: column;
    margin-bottom: 10px;
}
.mainModel .list span:nth-child(1){
    display: block;
    font-size: 17px;
    line-height: 24px;
    color: #000;
    font-weight: 600;
    margin-bottom: 3px;
}
.mainModel .list span:nth-child(2){
    display: block;
    font-size: 13px;
    line-height: 16px;
    color: #9DA0A3;
}