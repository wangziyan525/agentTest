<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover" name="viewport" />
    <title>详情</title>
    <!-- 建档抽查 -->
    <link rel="stylesheet" href="../../common/css/weui.min.css">
    <link rel="stylesheet" href="../../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="../../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../css/common.css">
    <link rel="stylesheet" href="../css/details.css">
    
</head>
<body>
    <div class="container" v-cloak>
        <div v-if="flag">
            <header class="header_fiexd_container">
                <div  class="header_content" style="height: 110px;" v-if="detail.phjdAlldataDeclare.checkstatus == 0 || detail.phjdAlldataDeclare.checkstatus == 2"></div>
                <div  class="header_content" style="height: 130px;" v-else></div>
            </header>
            <header class="header_container">
                <div class="display align_item_center">
                    <div class="icon_img">
                        <!-- 待抽查 -->
                        <img src="../images/icon_2@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 0"> 
                         <!--抽查被驳回  -->
                        <img src="../images/icon_1@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 1"> 
                        <!--抽查通过  -->
                        <img src="../images/icon_3@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 2">
                        <!--抽查已拒绝  -->
                        <img src="../images/icon_1@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 4">
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 0">
                        {{ detail.phjdAlldataDeclare.batchstatus == 0 ? '待' : '未' }}抽查
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 1">
                        抽查驳回
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 2">
                        抽查通过
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 4">
                        {{ detail.phjdAlldataDeclare.batchstatus == 0 ? '待' : '未' }}抽查（驳回过）
                    </div>
                </div>
                <div class="fs14 header_container_text" v-if="detail.phjdAlldataDeclare.checkcontent">
                    {{ detail.phjdAlldataDeclare.checkstatus == 4 ? '上次' : '' }}驳回时间：{{ detail.phjdAlldataDeclare.checktime }}
                </div>
                <div class="fs14 header_container_text" v-if="detail.phjdAlldataDeclare.checkcontent">
                    {{ detail.phjdAlldataDeclare.checkstatus == 4 ? '上次' : '' }}驳回原因：{{ detail.phjdAlldataDeclare.checkcontent }}
                </div>
            </header>
        </div>
        
        <div v-if="!flag ">
            <header class="header_fiexd_container">
                <div v-if="detail.phjdAlldataDeclare">
                    <div  class="header_content" style="height: 110px;" v-if="detail.phjdAlldataDeclare.checkstatus == 0 || detail.phjdAlldataDeclare.checkstatus == 2"></div>
                    <div  class="header_content" style="height: 130px;" v-else></div>
                </div>
                <div v-else>
                    <div class="header_content" style="height: 50px;"></div>
                    <div style="padding: 10px;"></div>
                </div>
            </header>
            <header class="header_container" v-if="detail.phjdAlldataDeclare">
                <div class="display align_item_center">
                    <div class="icon_img">
                        <img src="../images/icon_2@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 0"> 
                        <img src="../images/icon_1@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 1"> 
                        <img src="../images/icon_3@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 2">
                        <img src="../images/icon_1@2x.png" alt="" v-if="detail.phjdAlldataDeclare.checkstatus == 4">
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 0">
                        {{ detail.phjdAlldataDeclare.batchstatus == 0 ? '待' : '未' }}抽查
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 1">
                        抽查驳回
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 2">
                        抽查通过
                    </div>
                    <div class="fs17" v-if="detail.phjdAlldataDeclare.checkstatus == 4">
                        {{ detail.phjdAlldataDeclare.batchstatus == 0 ? '待' : '未' }}抽查（驳回过）
                    </div>
                </div>
                <div class="fs14 header_container_text" v-if="detail.phjdAlldataDeclare.checkcontent">
                    {{ detail.phjdAlldataDeclare.checkstatus == 4 ? '上次' : '' }}驳回时间：{{ detail.phjdAlldataDeclare.checktime }}
                </div>
                <div class="fs14 header_container_text" v-if="detail.phjdAlldataDeclare.checkcontent">
                    {{ detail.phjdAlldataDeclare.checkstatus == 4 ? '上次' : '' }}驳回原因：{{ detail.phjdAlldataDeclare.checkcontent }}
                </div>
            </header>
        </div>
        <section class="section_container color272727" v-if="detail.EstbDocMnBy == 2">
            <div class="section_container_item" :class="sildeIndex[0] ? 'padding_bottom10' : ''">
                <div class="slide_container">
                    <div class="slide_header display">
                        <div class=" fs17 fw600">基本信息</div>
                        <div
                            class="view_right display flex justify_content_right color1482FF fs15"
                            @click="slideHandle(0)">
                            {{ sildeIndex[0] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[0]">
                        <div class="slide_content fs17">
                            <div class="slide_content_item display">
                                <div class="view_left">首次建档时间</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.cREATETIME }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">联系人姓名</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.EntpCtcManNm }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">身份证号码</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.EstbDocManIdentNum }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">联系人电话</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.EntpCtcManTelNum }}
                                </div>
                            </div>
                            <!-- <div class="slide_content_item display">
                                <div class="view_left">是否是存量客户</div>
                                <div class="view_right display flex justify_content_right">1485239AOQ95488</div>
                            </div> -->
                            <div class="slide_content_item display">
                                <div class="view_left">客户需求</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.AcctMrk, chooseList1) }}{{ detail.AcctMrkDsc ? ':' + detail.AcctMrkDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display" v-if="detail.custtype">
                                <div class="view_left">客群标签</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.custtype, chooseList01) }}{{ detail.custdesc ? ':' + detail.custdesc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">备注</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.Rak }}
                                </div>
                            </div>
                        </div>
                        <div class="slide_content fs17 margin_top10">
                            <div class="slide_content_item display">
                                <div class="view_left">商户名称</div>
                                <div class="view_right flex align_right">
                                    <div class="text_justify">
                                        {{ detail.EntpNm }}<span class="color1482FF" @click="copyHandle(detail.EntpNm)">复制</span>
                                    </div>
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">统⼀社会信⽤代码</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.UnifyUvslCrCd }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">所属⾏业</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.AtchIndus, chooseList2) }}{{ detail.AtchIndusDsc ? ':' + detail.AtchIndusDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">经营年限</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.CorpYr, chooseList3) }}
                                </div>
                            </div>
                            <div class="_slide_content_item">
                                <div class="view_left">建档定位</div>
                                <div class="view_right flex ">
                                    {{ detail.EntpCorpAdr }}
                                    <span class="color1482FF" @click="copyHandle(detail.EntpCorpAdr)">复制</span>
                                </div>
                            </div>
                            <div class="_slide_content_item" v-if="imageLocal1.length > 0">
                                <div class="view_right">招牌照片</div>
                                <div class="photo_container">
                                    <div
                                        class=""
                                        v-for="(item, index) in imageLocal1"
                                        @click="previewHandle(imageLocal1, index)"
                                        :key="index">
                                        <img :src="item" alt="">
                                        <div class="fs13">点击查看大图</div>
                                    </div>
                                </div>
                            </div>
                            <div class="_slide_content_item" v-if="imageLocal3.length > 0">
                                <div class="view_right">个体工商户经营场所照片</div>
                                <div class="photo_container">
                                    <div
                                        class=""
                                        v-for="(item, index) in imageLocal3"
                                        @click="previewHandle(imageLocal3, index)"
                                        :key="index">
                                        <img :src="item" alt="">
                                        <div class="fs13">点击查看大图</div>
                                    </div>
                                </div>
                            </div>
                            <div class="_slide_content_item" v-if="imageLocal2.length > 0">
                                <div class="view_right">营业执照</div>
                                <div class="photo_container">
                                    <div
                                        class=""
                                        v-for="(item, index) in imageLocal2"
                                        @click="previewHandle(imageLocal2, index)"
                                        :key="index">
                                        <img :src="item" alt="">
                                        <div class="fs13">点击查看大图</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                        
                </div>
            </div>
            <div class="section_container_item padding_bottom10">
                <div class="slide_container">
                    <div class="slide_header display">
                        <div class="fs17 fw600">经营情况</div>
                        <!-- <div
                            class="view_right display flex justify_content_right color1482FF"
                            @click="slideHandle(2)">
                            {{ sildeIndex[2] ? '收起' : '展开' }}
                        </div> -->
                    </div>
                    <div class="slide_content fs17 ">
                        <div class="slide_content_item display">
                            <div class="view_left">主营业务</div>
                            <div class="view_right display flex justify_content_right">{{ detail.EntpMnByBsn }}</div>
                        </div>
                        <div class="slide_content_item display">
                            <div class="view_left">经营场所</div>
                            <div class="view_right display flex justify_content_right">
                                {{ formatRadio(detail.CorpPce, chooseList112) }}
                            </div>
                        </div>
                        <div class="slide_content_item display">
                            <div class="view_left">近3个⽉⽉均移动⽀付流⽔</div>
                            <div class="view_right display flex justify_content_right">
                                {{ formatRadio(detail.PrxThreeMoMoyAvMovPytSeq, chooseList122) }}
                            </div>
                        </div>
                        <!-- <div class="slide_content_item display">
                            <div class="view_left">是否是存量客户</div>
                            <div class="view_right">1485239AOQ95488</div>
                        </div> -->
                        <div class="slide_content_item display">
                            <div class="view_left">家庭⽉均⽀出(元)</div>
                            <div class="view_right display flex justify_content_right">
                                {{ detail.FamMoyAvExpn }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="section_container_item" :class="sildeIndex[2] ? 'padding_bottom10' : ''">
                <div class="slide_container">
                    <div class="slide_header display">
                        <div class="fw600 fs17">融资需求及负债情况</div>
                        <div
                            class="view_right display flex justify_content_right color1482FF"
                            @click="slideHandle(2)">
                            {{ sildeIndex[2] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[2]">
                        <div class="slide_content fs17">
                            <div class="slide_content_item display">
                                <div class="view_left">资金用途</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.TchPps, chooseList4) }}{{ detail.TchPpsDsc ? ':' + detail.TchPpsDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">希望多久可以拿到贷款</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.ExpcTrm, chooseList5) }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">利率接受范围</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.IntRtAcptScop, chooseList6) }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">期望额度</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.ExptLmt, chooseList72) }}
                                </div>
                            </div>
                        </div>
                        <div class="slide_content fs17 margin_top10">
                            <div class="slide_content_item display">
                                <div class="view_left">负债情况</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.LglRprsLbyCcst, chooseList102) }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">负债类型</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.LglRprsLbyTp, chooseList9) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <section class="section_container color272727" v-if="detail.EstbDocMnBy == 1">
            <div class="section_container_item" :class="sildeIndex[0] ? 'padding_bottom10' : ''">
                <div class="slide_container">
                    <div class="slide_header display">
                        <div class=" fs17 fw600">基本信息</div>
                        <div
                            class="view_right display flex justify_content_right color1482FF fs15"
                            @click="slideHandle(0)">
                            {{ sildeIndex[0] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[0]">
                        <div class="slide_content fs17">
                            <div class="slide_content_item display">
                                <div class="view_left">首次建档时间</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.cREATETIME }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">企业联系人姓名</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.EntpCtcManNm }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">身份证号码</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.EstbDocManIdentNum }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">企业联系⼈电话</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.EntpCtcManTelNum }}
                                </div>
                            </div>
                            <!-- <div class="slide_content_item display">
                                <div class="view_left">是否是存量客户</div>
                                <div class="view_right display flex justify_content_right">1485239AOQ95488</div>
                            </div> -->
                            <div class="slide_content_item display">
                                <div class="view_left">客户需求</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.AcctMrk, chooseList1) }}{{ detail.AcctMrkDsc ? ':' + detail.AcctMrkDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display" v-if="detail.custtype">
                                <div class="view_left">客群标签</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.custtype, chooseList01) }}{{ detail.custdesc ? ':' + detail.custdesc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">备注</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.Rak }}
                                </div>
                            </div>
                        </div>
                        <div class="slide_content fs17 margin_top10">
                            <div class="slide_content_item display">
                                <div class="view_left">企业名称</div>
                                <div class="view_right flex align_right">
                                    <div class="text_justify">
                                        {{ detail.EntpNm }}<span class="color1482FF" @click="copyHandle(detail.EntpNm)">复制</span>
                                    </div>
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">统一社会信用代码</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.UnifyUvslCrCd }}
                                </div>
                            </div>
                            
                            <div class="slide_content_item display">
                                <div class="view_left">所属⾏业</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.AtchIndus, chooseList2) }}{{ detail.AtchIndusDsc ? ':' + detail.AtchIndusDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">经营年限</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.CorpYr, chooseList3) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div class="view_left">建档定位</div>
                                <div class="view_right flex">
                                    {{ detail.EntpCorpAdr }}
                                    <span class="color1482FF" @click="copyHandle(detail.EntpCorpAdr)">复制</span>
                                </div>
                            </div>
                            
                            <div class="_slide_content_item" v-if="imageLocal1.length > 0">
                                <div class="view_right">招牌照片</div>
                                <div class="photo_container">
                                    <div
                                        class=""
                                        v-for="(item, index) in imageLocal1"
                                        @click="previewHandle(imageLocal1, index)"
                                        :key="index">
                                        <img :src="item" alt="">
                                        <div class="fs13">点击查看大图</div>
                                    </div>
                                </div>
                            </div>
                            <div class="_slide_content_item" v-if="imageLocal3.length > 0">
                                <div class="view_right">小微企业办公或经营场所照片</div>
                                <div class="photo_container">
                                    <div
                                        class=""
                                        v-for="(item, index) in imageLocal3"
                                        @click="previewHandle(imageLocal3, index)"
                                        :key="index">
                                        <img :src="item" alt="">
                                        <div class="fs13">点击查看大图</div>
                                    </div>
                                </div>
                            </div>
                            <div class="_slide_content_item" v-if="imageLocal2.length > 0">
                                <div class="view_right">营业执照</div>
                                <div class="photo_container">
                                    <div
                                        class=""
                                        v-for="(item, index) in imageLocal2"
                                        @click="previewHandle(imageLocal2, index)"
                                        :key="index">
                                        <img :src="item" alt="">
                                        <div class="fs13">点击查看大图</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="section_container_item padding_bottom10">
                <div class="slide_container">
                    <div class="slide_header display">
                        <div class="fs17 fw600">经营情况</div>
                        <!-- <div
                            class="view_right display flex justify_content_right color1482FF"
                            @click="slideHandle(2)">
                            {{ sildeIndex[2] ? '收起' : '展开' }}
                        </div> -->
                    </div>
                    <div class="slide_content fs17 ">
                        <div class="slide_content_item display">
                            <div class="view_left">企业主营业务</div>
                            <div class="view_right display flex justify_content_right">{{ detail.EntpMnByBsn }}</div>
                        </div>
                        <div class="slide_content_item display">
                            <div class="view_left">经营场所</div>
                            <div class="view_right display flex justify_content_right">
                                {{ formatRadio(detail.CorpPce, chooseList11) }}
                            </div>
                        </div>
                        <div class="slide_content_item display">
                            <div class="view_left">企业近6个⽉⽉均营收</div>
                            <div class="view_right display flex justify_content_right">
                                {{ formatRadio(detail.EntpPrxSixMoMoyAvIncm, chooseList12) }}
                            </div>
                        </div>
                        <!-- <div class="slide_content_item display">
                            <div class="view_left">是否是存量客户</div>
                            <div class="view_right">1485239AOQ95488</div>
                        </div> -->
                        <div class="slide_content_item display">
                            <div class="view_left">企业员工</div>
                            <div class="view_right display flex justify_content_right">
                                {{ formatRadio(detail.EntpStfPsnNum, chooseList13) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="section_container_item" :class="sildeIndex[2] ? 'padding_bottom10' : ''">
                <div class="slide_container">
                    <div class="slide_header display">
                        <div class="fw600 fs17">融资需求及负债情况</div>
                        <div
                            class="view_right display flex justify_content_right color1482FF"
                            @click="slideHandle(2)">
                            {{ sildeIndex[2] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[2]">
                        <div class="slide_content fs17">
                            <div class="slide_content_item display">
                                <div class="view_left">资金用途</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.TchPps, chooseList4) }}{{ detail.TchPpsDsc ? ':' + detail.TchPpsDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">希望多久可以拿到贷款</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.ExpcTrm, chooseList5) }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">利率接受范围</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.IntRtAcptScop, chooseList6) }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">期望额度</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.ExptLmt, chooseList7) }}
                                </div>
                            </div>
                        </div>
                        <div class="slide_content fs17 margin_top10">
                            <div class="slide_content_item display">
                                <div class="view_left">法定代表人持股比例</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ detail.LglRprsShrhldRto ? detail.LglRprsShrhldRto + '%' : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">法定代表人负债情况</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatRadio(detail.LglRprsLbyCcst, chooseList8) }}
                                </div>
                            </div>
                            <div class="slide_content_item display">
                                <div class="view_left">法定代表人负债情况</div>
                                <div class="view_right display flex justify_content_right">
                                    {{ formatCheckBox(detail.LglRprsLbyTp, chooseList9) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <div  v-if="flag">
            <div class="now_container85" v-if="detail.phjdAlldataDeclare.batchstatus == 0 && (detail.phjdAlldataDeclare.checkstatus == 0 || detail.phjdAlldataDeclare.checkstatus == 4)"></div>

            <footer
                class="footer_fiexd_container now_container85"
                v-if="detail.phjdAlldataDeclare.batchstatus == 0 && (detail.phjdAlldataDeclare.checkstatus == 0 || detail.phjdAlldataDeclare.checkstatus == 4)">
                <!-- <div
                    class="footer_container display"
                    v-if="backstatus || detail.phjdAlldataDeclare.batchstatus != 0 || detail.phjdAlldataDeclare.checkstatus == 1 || detail.phjdAlldataDeclare.checkstatus == 2">
                    <div
                        class="footer_view_right fs16 flex display align_item_center justify_content_center"
                        
                        @click="backHandle">返回</div>
                </div> -->
                <div class="footer_container display" >
                    <div
                        class="footer_view_left fs16 flex display align_item_center justify_content_center"
                        @click="popupBottom.show = true">驳回</div>
                    <div
                        class="footer_view_right fs16 flex display align_item_center justify_content_center"
                        
                        @click="nextHandle('2')">通过</div>
                </div>
            </footer>
        </div>
        <van-popup
            v-model="popupBottom.show"
            round
            position="bottom">
            <div class="popup_bottom_container fs16">
                <div class="popup_bottom_header">
                    <div class="popup_bottom_header_title">请输入驳回原因</div>
                    <div class="cancel_container" @click="popupBottom.show = false">取消</div>
                </div>
                <div class="popup_bottom_content">
                    <van-field
                        type="textarea"
                        v-model="submitData.checkcontent"
                        rows="3" autosize placeholder="请输入"
                        maxlength="50">
                    </van-field>
                </div>
                <div class="popup_bottom_footer">
                    <div class="" @click="nextHandle('1')">
                        确认
                    </div>
                </div>
            </div>
            
        </van-popup>
    </div>
</body>
<script type="text/javascript" src="../../common/js/vue.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../../common/js/clipboard.js"></script>
<script type="text/javascript" src="../../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../../common/js/base.js"></script>
<script type="text/javascript" src="../../common/js/jssdk.js"></script>
<script src="../../common/js/watermark.js"></script>
<script src="../../common/js/server.js"></script>
<script src="../js/dataJson.js"></script>
<script src="../js/details.js?v=20280905"></script>
