    $(function () {
        initJSSDK(['hideAllNonBaseMenuItem', 'closeWindow']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        })
    });
     function getUserFinish (){
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }
</script>
