[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f6f6f6;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    overflow: auto;
}
/* ------------------------------------------------ 信息 -------------------------------------- */
.visitInfo{
    width: 100%;
    margin-top: 10px;
}
.visitInfo .info{
    width: 100%;
    background-color: #fff;
    padding: 15px 16px;
    box-sizing: border-box;
    display: flex;
    position: relative;
}
.visitInfo .info::after{
    content: '';
    width: calc(100% - 32px);
    height: 2px;
    background: #E6E7E8;
    -ms-transform: scaleY(.3);
    -webkit-transform: scaleY(.3);
    transform: scaleY(.3);
    position: absolute;
    bottom: 0px;
    left: 16px;
    z-index: 1;
}
.visitInfo .info:last-child::after{
    display: none;
}
.visitInfo .info span{
    display: block;
    line-height: 20px;
}
.visitInfo .info span:nth-child(1){
    width: 100px;
    font-size: 15px;
    color: #666;
}
.visitInfo .info span:nth-child(2){
    flex: 1;
    font-size: 15px;
    color: #000;
    word-break: break-all;
}

.visitInfo .info .tel{
    flex: 1;
    display: flex;
}
.visitInfo .info .tel i{
    height: 20px;
    display: flex;
    padding-right: 2px;
    box-sizing: border-box;
    align-items: center;
}
.visitInfo .info .tel i img{
    display: block;
    width: 12px;
    margin-right: 5px;
}
.visitInfo .info .tel a{
    color: #3579c6;
    text-decoration: underline;
    font-size: 15px;
    line-height: 20px;
}

.visitInfo .info2{
    width: 100%;
    background-color: #fff;
    padding: 15px 16px 13px;
    box-sizing: border-box;
}
.visitInfo .info2 .title{
    display: block;
    width: 100%;
    font-size: 15px;
    color: #000;
    line-height: 20px;
}
.visitInfo .info2 .title span{
    color: #9DA0A3;
}
.visitInfo .info2 .uploadImg{
    width: 100%;
    padding: 17px 0 9px;
    display: flex;
}
.visitInfo .info2 .uploadImg .uploaded{
    width: 80px;
    height: 80px;
    border-radius: 4px;
    background-color: #f6f6f6;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
}
.visitInfo .info2 .uploadImg .uploaded .myFaceImg{
    display: block;
    width: 100%;
    border-radius: 4px;
}
/* ------------------------------- 按钮 --------------------- */
.btn{
    width: 100%;
    margin-top: 95px;
    padding: 0 16px;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
}
.btn span{
    display: block;
    width: calc((100% - 30px)/2);;
    line-height: 43px;
    border-radius: 6px;
    font-size: 15px;
    color: #fff;
    text-align: center;
    border: 1px solid #267EF0;
}
.btn span:nth-child(1){
    color: #267EF0;
    background-color: transparent;
}
.btn span:nth-child(2){
    color: #fff;
    background-color: #267EF0;
}