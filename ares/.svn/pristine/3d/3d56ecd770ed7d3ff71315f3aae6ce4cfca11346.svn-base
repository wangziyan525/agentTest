[v-cloak] {
  display: none;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
    "Helvetica Neue", Arial, sans-serif;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 80px;
}

/* 内容区域 */
.content {
  padding-top: 10px;
}

/* 分隔条 */
.section-gap {
  height: 10px;
  background-color: #f5f5f5;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 15px;
  color: #272727;
  font-weight: 400;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  text-align: right;
  border: none;
  outline: none;
  font-size: 15px;
  color: #272727;
}

.form-input::placeholder {
  color: #999;
}

/* 提示内容区域 */
.tips-section {
  background-color: #fff;
  padding: 16px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 15px;
  color: #272727;
  font-weight: 500;
}

.add-btn {
  font-size: 14px;
  color: #1989fa;
  cursor: pointer;
}

.add-btn:active {
  opacity: 0.7;
}

/* 提示条目 */
.tip-item {
  background-color: #f7f8fa;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.tip-index {
  font-size: 14px;
  color: #666;
}

.delete-btn {
  font-size: 14px;
  color: #ff4949;
  cursor: pointer;
}

.delete-btn:active {
  opacity: 0.7;
}

.tip-textarea {
  width: 100%;
  border: 1px solid #eee;
  border-radius: 4px;
  padding: 10px;
  font-size: 14px;
  color: #272727;
  resize: none;
  outline: none;
  background-color: #fff;
}

.tip-textarea::placeholder {
  color: #999;
}

.tip-textarea:focus {
  border-color: #1989fa;
}

/* 预览区域 */
.preview-section {
  margin: 16px;
  background-color: #fff;
  border-radius: 8px;
  padding: 16px;
}

.preview-title {
  font-size: 14px;
  color: #999;
  margin-bottom: 12px;
}

.preview-box {
  background-color: #fffbe8;
  border: 1px solid #ffe58f;
  border-radius: 8px;
  padding: 16px;
}

.preview-header {
  font-size: 16px;
  color: #272727;
  font-weight: 500;
  text-align: center;
  margin-bottom: 12px;
}

.preview-content {
  font-size: 14px;
  color: #666;
}

.preview-item {
  display: flex;
  margin-bottom: 8px;
  line-height: 1.5;
}

.preview-item:last-child {
  margin-bottom: 0;
}

.preview-num {
  flex-shrink: 0;
  margin-right: 4px;
  color: #fa8c16;
}

.preview-text {
  color: #666;
}

/* 底部按钮 */
.bottom-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  background-color: #fff;
}

.bottom-btn {
  width: 100%;
  height: 44px;
  background-color: #1989fa;
  border: none;
  border-radius: 22px;
  font-size: 16px;
  color: #fff;
  cursor: pointer;
}

.bottom-btn:active {
  opacity: 0.8;
}
