/**
 * 是否字典
 * @param {*} key 
 */

function formatBusiType (key) {
    let params = {
        320: '挂牌申请',
        321: '挂牌接收',
    };
    return params[key];
};


/**
 * 贴现申请人规模
 * @param {*} key 
 */

function formatScale (key) {
    let params = {
        'SC00': '大型企业',
        'SC01': '中型企业',
        'SC02': '小型企业',
        'SC03': '微小企业',
        'SC04': '其他'
    };
    return params[key];
};

/**
 * 贴现申请人行业分类
 * @param {*} key 
 */

function formatIndClass (key) {
    let params = {
        'A0000': '农、林、牧、渔业',
        'B0000': '采矿业',
        'C0000': '制造业',
        'D0000': '电力、热力、燃气及水生产和供应业',
        'E0000': '建筑业',
        'F0000': '批发和零售业',
        'G0000': '交通运输、仓储和邮政业',
        'H0000': '住宿和餐饮业',
        'I0000': '信息传输、软件和信息技术服务业',
        'J0000': '金融业',
        'K0000': '房地产业',
        'L0000': '租赁和商务服务业',
        'M0000': '科学研究和技术服务业',
        'N0000': '水利、环境和公共设施管理业',
        'O0000': '居民服务、修理和其他服务业',
        'P0000': '教育',
        'Q0000': '卫生和社会工作',
        'R0000': '文化、体育和娱乐业',
        'S0000': '公共管理、社会保障和社会组织',
        'T0000': '国际组织',
        'U0000': '其他'
    };
    return params[key];
};


