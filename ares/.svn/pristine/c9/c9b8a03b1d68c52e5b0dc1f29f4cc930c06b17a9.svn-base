<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>建档数据排名</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/index.css?v=5.2">
</head>
<body style="overflow: hidden;height: 100vh;">
    <div id="app" style="overflow-y: scroll;height: 100%;display:none">
       
       <div v-if="page=='page1'">
            <div class="seachData" style="background: #F5F6F7;">
                <div style="background: #fff;">
                    <div class="searchLine">
                        <div class="seachDataForm" >
                            <div :class="cdate=='1'?'chooseItem':''" @click="choosecdate('1')">昨日</div>
                            <div :class="cdate=='2'?'chooseItem':''" @click="choosecdate('2')">本月</div>
                            <div :class="cdate=='3'?'chooseItem':''" @click="choosecdate('3')">自定义</div>
                            <div :class="cdate=='4'?'chooseItem':''" @click="choosecdate('4')">累计</div>
                        </div>
                        <van-popup 
                                v-model="DateRangeshow"
                                position="bottom"
                                :close-on-click-overlay="false">
                                <van-calendar v-model='DateRangeshow' :min-date="minRangeDate" :max-date="maxRangeDate"  allow-same-day color='#0465FF' type="range" 
                                class="calendar" @confirm='onDateRangeConfirm' @close="DateRangeshow=false"></van-calendar>
        
                        </van-popup>
                        <!-- <div class="seachDataForm" >
                            <div :class="estbdocmnby=='0'?'chooseItem':''" @click="chooseestbdocmnby('0')">全部</div>
                            <div :class="estbdocmnby=='1'?'chooseItem':''" @click="chooseestbdocmnby('1')">企业</div>
                            <div :class="estbdocmnby=='2'?'chooseItem':''" @click="chooseestbdocmnby('2')">个体</div>
                        </div> -->
                    </div>
                    <div class="jdData">
                        <div >
                            <div class="dataTitle1">共建档</div>
                            <div class="datatotalNum">{{total}}</div>
                        </div>
                        <div >
                            <div class="dataTitle1" @click="warnText('1')">有效建档<img src="images/warn.png" class="warnImg"></div>
                            <div class="datatotalNum">{{validtotal}}</div>
                        </div>
                        <div >
                            <div class="dataTitle1" @click="warnText('2')">待申报<img src="images/warn.png" class="warnImg"></div>
                            <div class="datatotalNum">{{waitdeclared}}</div>
                        </div>
                        <div >
                            <div class="dataTitle1" @click="warnText('3')">已申报<img src="images/warn.png" class="warnImg"></div>
                            <div class="datatotalNum">{{declared}}</div>
                        </div>
                    </div> 
                </div>
                <div class="warnSpan" style="width: 92%;margin:auto;padding-top: 8px;">统计数据时间为截止{{currentDate}}</div>
                <div style="height: 4px;"></div>
            </div>
            
            <div class="scrollPart" style="margin-top: 0;height: 100vh;">
                <div class="topDiv" style="height: 178px;"></div>
                <div class="tabList" style="margin-top: 0;">
                    <div :class="tabFlag=='1'?'chooseRole':''" @click="chooseTab('1')">一级机构</div>
                    <div :class="tabFlag=='2'?'chooseRole':''" @click="chooseTab('2')">经营支行</div>
                    <div :class="tabFlag=='3'?'chooseRole':''" @click="chooseTab('3')">员工</div>
                </div>
                <div class="seachSsbm seachSsbmNew"  v-if="tabFlag=='1'">
                    <div :class="org_cls=='qh'?'chooseSsbm':''" @click="chooseTyle('qh')" >区行组</div>
                    <div :class="org_cls=='fh'?'chooseSsbm':''"  @click="chooseTyle('fh')">分行组</div>
                    <div :class="org_cls=='zsh'?'chooseSsbm':''" @click="chooseTyle('zsh')">直属行组</div>
                </div>
        
                <div class="seachSsbm seachSsbmNew"  v-if="tabFlag=='2' && (role !='zonghang' && role !='zonghang_general')">
                    <div :class="org_cls=='quanhang'?'chooseSsbm':''"  @click="chooseTyle('quanhang')" >全行排名</div>
                    <div :class="org_cls=='benjigou'?'chooseSsbm':''"  @click="chooseTyle('benjigou')">本机构内排名</div>
                </div>
        
                <div class="seachSsbm seachSsbmNew"  v-if="tabFlag=='3' && (role !='zonghang' && role !='zonghang_general')">
                    <div :class="org_cls=='quanhang'?'chooseSsbm':''"  @click="chooseTyle('quanhang')" >全行排名</div>
                    <div :class="org_cls=='benjigou'?'chooseSsbm':''"  @click="chooseTyle('benjigou')">本机构内排名</div>
                </div>
                
                <div class="rankList">
                    <div>
                        <div class="rankPart rankPartNew rankTitle">
                            <div class="rankIndex">排名</div>
                            <div v-if="tabFlag=='1'">
                                <div v-if="org_cls=='qh'" class="ssabmName">区行名称</div>
                                <div v-if="org_cls=='fh'" class="ssabmName">分行名称</div>
                                <div v-if="org_cls=='zsh'" class="ssabmName">直属行名称</div>
                            </div>
                            <div v-if="tabFlag=='3'">
                                <div  class="ssabmName">客户经理姓名</div>
                            </div>
                            <div v-if="tabFlag=='2' || tabFlag=='3'">
                                <div  class="ssabmName">经营支行名称</div>
                            </div>
                            
                            <div class="jdTotal">建档数</div>
                            <div class="validNum">有效建档数</div>
                            <div class="validRate">有效占比（%）</div>
                            <div class="jdTotal">待申报数</div>
                            <div class="jdTotal">已申报数</div>
                        </div>
                        <div class="rankContent rankContentNew" v-if="list.length>0">
                            <div class="rankPart rankPartNew" v-for="item in list">
                                <div class="rankIndex">{{item.DatCnt.num}}</div>
                                <div v-if="tabFlag=='3'">
                                    <div  class="ssabmName">{{item.DatCnt.employeename}}</div>
                                </div>
                                <div v-if="tabFlag=='2' || tabFlag=='3'">
                                    <div  class="ssabmName">
                                        <div>{{item.DatCnt.bu_descr}}</div>
                                        <div>{{item.DatCnt.ssbm}}</div>
                                    </div>
                                </div>
                                <div v-if="tabFlag=='1'">
                                    <div class="ssabmName rank2decoration" v-if="item.DatCnt.is_down=='0'" @click="goSsbm(item.DatCnt.bu_descr,item.DatCnt.org_id)">
                                        {{item.DatCnt.bu_descr}}
                                    </div>
                                    
                                    <div class="ssabmName" v-else>
                                        {{item.DatCnt.bu_descr}}
                                    </div>
                                </div>
                                
                                <div class="jdTotal numberText">{{item.DatCnt.total}}</div>
                                <div class="validNum numberText">{{item.DatCnt.validtotal}}</div>
                                <div class="validRate numberText">{{item.DatCnt.validpercent}}</div>
                                <div class="jdTotal numberText">{{item.DatCnt.waitdeclared}}</div>
                                <div class="jdTotal numberText">{{item.DatCnt.declared}}</div>
                            </div>
                            
                        </div>
                        <div class="moreText" @click="queryList" v-if="!ifEnd && list.length>0">
                            <div>查看更多</div>
                        </div>
                        <div v-if="list.length==0" class="nodate">
                            暂无排名
                        </div>
                        
                    </div>
        
                </div>
                <div style="height: 80px;" class="footDiv"></div>
            </div>
            <div class="footTab">
                <div class="footOne" @click="toPage()">
                    <img src="images/index.png">
                    <div >我的建档</div>
                </div>
                <div class="footOne" @click="toDeclarePage()" >
                    <img src="images/jdsb.png">
                    <div >建档申报</div>
                </div>
                <div class="footOne">
                    <img src="images/listChoose.png">
                    <div class="choosetab">建档数据</div>
                </div>
            </div>
       </div>

       <div v-if="page=='page2'">
            <div class="ssabmTitle rank2decoration" @click="backBu_descr">{{bu_descr}}</div>
            <div >
                <div class="rankList">
                    <div>
                        <div class="rankPart rankPartNew rankTitle">
                            <div class="rankIndex">排名</div>
                            <div  class="ssabmName">经营支行名称</div>
                            
                            <div class="jdTotal">建档数</div>
                            <div class="validNum">有效建档数</div>
                            <div class="validRate">有效占比（%）</div>
                            <div class="jdTotal">待申报数</div>
                            <div class="jdTotal">已申报数</div>
                        </div>
                        <div class="rankContent rankContentNew" v-if="list.length>0">
                            <div class="rankPart rankPartNew" v-for="item in list">
                                <div class="rankIndex">{{item.DatCnt.num}}</div>
                                <div>
                                    <div class="ssabmName " v-if="item.DatCnt.is_down=='0'" @click="goemployeename(item.DatCnt.ssbm,item.DatCnt.org_id)">
                                        <div class="rank2decoration">{{item.DatCnt.bu_descr}}</div>
                                        <div class="rank2decoration">{{item.DatCnt.ssbm}}</div>
                                    </div>
                                    <div class="ssabmName" v-else>
                                        <div >{{item.DatCnt.bu_descr}}</div>
                                        <div >{{item.DatCnt.ssbm}}</div>
                                    </div>
                                </div>
                                
                                <div class="jdTotal numberText">{{item.DatCnt.total}}</div>
                                <div class="validNum numberText">{{item.DatCnt.validtotal}}</div>
                                <div class="validRate numberText">{{item.DatCnt.validpercent}}</div>
                                <div class="jdTotal numberText">{{item.DatCnt.waitdeclared}}</div>
                                <div class="jdTotal numberText">{{item.DatCnt.declared}}</div>
                            </div>
                            
                        </div>
                        <div class="moreText" @click="queryDownList('2')" v-if="!ifEnd && list.length>0">
                            <div>查看更多</div>
                        </div>
                        <div v-if="list.length==0" class="nodate">
                            暂无排名
                        </div>
                        
                    </div>
        
                </div>
                <div style="height: 100px;"></div>
            </div>
            <div class="footApply" >
                <div @click="backBu_descr">
                    <span>返回</span>
                </div>
            </div>
        </div>

        <div v-if="page=='page3'">
            <div class="ssabmTitle " style="display: flex;">
                
                <div class="rank2decoration" @click="backBu_descr" v-if="bu_descr">{{bu_descr}}</div>
                <div style="margin: 0 8px;">/</div>
                <div class="rank2decoration" @click="backSsbm">{{ssbm}}</div>
            </div>
            <div >
        
                <div class="rankList">
                    <div>
                        <div class="rankPart rankPartNew rankTitle">
                            <div class="rankIndex">排名</div>
                            <div  class="ssabmName">客户经理姓名</div>
                            <div  class="ssabmName">经营支行名称</div>
                            <div class="jdTotal">建档数</div>
                            <div class="validNum">有效建档数</div>
                            <div class="validRate">有效占比（%）</div>
                            <div class="jdTotal">待申报数</div>
                            <div class="jdTotal">已申报数</div>
                        </div>
                        <div class="rankContent rankContentNew" v-if="list.length>0">
                            <div class="rankPart rankPartNew" v-for="item in list">
                                <div class="rankIndex">{{item.DatCnt.num}}</div>
                                <div  class="ssabmName">{{item.DatCnt.employeename}}</div>
                                <div  class="ssabmName">
                                    <div>{{item.DatCnt.bu_descr}}</div>
                                    <div>{{item.DatCnt.ssbm}}</div>
                                </div>
                                <div class="jdTotal numberText">{{item.DatCnt.total}}</div>
                                <div class="validNum numberText">{{item.DatCnt.validtotal}}</div>
                                <div class="validRate numberText">{{item.DatCnt.validpercent}}</div>
                                <div class="jdTotal numberText">{{item.DatCnt.waitdeclared}}</div>
                                <div class="jdTotal numberText">{{item.DatCnt.declared}}</div>
                            </div>
                            
                        </div>
                        <div class="moreText" @click="queryDownList('3')" v-if="!ifEnd && list.length>0">
                            <div>查看更多</div>
                        </div>
                        <div v-if="list.length==0" class="nodate">
                            暂无排名
                        </div>
                        
                    </div>
        
                </div>
                <div style="height: 100px;"></div>
            </div>
            <div class="footApply" >
                <div @click="backSsbm">
                    <span>返回</span>
                </div>
            </div>
        </div>
    </div>
</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="./../common/js/server.js"></script>
<script type="text/javascript" src="js/rankNew.js"></script>
<!-- <script src="../common/js/vConsole.min.js"></script> -->
<script type="text/javascript">
    // var vConsole = new VConsole();
    
    function getUserFinish(){
            initJSSDK(['hideAllNonBaseMenuItem','invoke','closeWindow']);

           wx.ready(function() {
               wx.hideAllNonBaseMenuItem();
               WeixinJSBridge.on('menu:setfont', function() {
                    WeixinJSBridge.invoke('setFontSizeCallback', { 'fontSize' : '0' });
                });

           });
           // 调用水印
           var username = $.parseJSON($.cookie("user")).name;
           __canvasWM({
               content: username
           });
           initFun()
    }

</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>