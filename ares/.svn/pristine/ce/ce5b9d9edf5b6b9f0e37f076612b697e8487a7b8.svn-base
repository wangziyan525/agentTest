<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
    name="viewport" />
  <link rel="stylesheet" href="../common/css/weui.min.css">
  <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
  <link rel="stylesheet" href="../common/css/vant-2.12.css">
  <link rel="stylesheet" href="css/appointment.css">
  <title>临时提额预约</title>
</head>

<body>
  <div id="app" v-cloak>

    <!-- Tab切换 -->
    <div class="tab-wrap">
      <div class="tab-item" :class="{ active: activeTab === 'pending' }" @click="handleTabChange('pending')">
        <span>待审批</span>
        <div class="tab-line" v-if="activeTab === 'pending'"></div>
      </div>
      <div class="tab-item" :class="{ active: activeTab === 'approved' }" @click="handleTabChange('approved')">
        <span>我已审批</span>
        <div class="tab-line" v-if="activeTab === 'approved'"></div>
      </div>
    </div>

    <!-- 状态筛选标签（仅在我已审批Tab显示） -->
    <!-- Tab标签 -->
    <div class="tab1-wrap" v-if="activeTab === 'approved'">
      <div class="tab1-list">
        <div class="tab1-item" :class="{ active: activeTab2 === index }" v-for="(tab, index) in tabList" :key="index"
          @click="handleTabChange1(index)">
          {{ tab.name }}
        </div>
      </div>
    </div>

    <!-- 列表内容 -->
    <div class="list-content" :class="{ 'with-filter': activeTab === 'approved' }">
        <van-list v-model="loading" :finished="finished" @load="onLoad">
          <!-- 列表卡片 -->
          <div class="card-item" v-for="(item, index) in list" :key="index" @click="handleCardClick(activeTab,item)">
            <div class="card-header">
              <span class="card-name">{{ item.clientNm }}({{ item.identNum }})</span>
              <img class="card-arrow" src="images/rightArrow.png" alt="">
            </div>
            <div class="card-divider"></div>
            <div class="card-info">
              <div class="info-row">
                <span class="info-label">银行卡</span>
                <span class="info-value">西安银行借记卡({{ item.crdNum}})</span>
              </div>
              <div class="info-row">
                <span class="info-label">申请时间</span>
                <span class="info-value">{{ item.aplyTm }}</span>
              </div>
            </div>
          </div>
          <!-- 无数据状态 -->
          <div class="empty-wrap" v-if="list.length == 0">
            <img src="https://img.yzcdn.cn/vant/empty-image-default.png" alt="无数据">
            <span>暂无数据</span>
          </div>
        </van-list>
    </div>
  </div>

</body>
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/watermark.js"></script>
<script src="./../common/js/server.js"></script>
<script src="js/appointment.js"></script>
<script src="js/accounting.min.js"></script>

<script src="../common/js/vConsole.min.js"></script>

<script>
  //  var vConsole = new VConsole();
  initJSSDK(['hideAllNonBaseMenuItem', 'invoke', 'selectEnterpriseContact'])
  wx.ready(function () {
    wx.hideAllNonBaseMenuItem();
  });
  function getUserFinish() {
    var username = $.parseJSON($.cookie("user")).name;
    __canvasWM({
      content: username
    });
    initFun()
  }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>

</html>