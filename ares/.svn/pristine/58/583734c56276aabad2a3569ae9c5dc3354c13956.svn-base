// 格式化年月日

function formatDate (param) {
    let year, month, date;
    year = param.getFullYear();
    if (param.getMonth() + 1 > 9) {
        month = param.getMonth() + 1;
    } else {
        month = '0' + (param.getMonth() + 1);
    }
    if (param.getDate() > 9) {
        date = param.getDate()
    } else {
        date = '0' + param.getDate()
    }
    return `${year}${month}${date}`;
}




