<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>来访记录</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../../common/css/weui.min.css" />
    <link rel="stylesheet" href="../../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../../common/css/vant-2.12.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/visitRecord.css?v=0.0.3">
</head>
<body>

    <div id="app" v-cloak>
        
        <!-- tab切换 -->
        <div class="tab">
            <van-tabs v-model="active" @click="changeActive">
                <van-tab title="待审批"></van-tab>
                <van-tab title="已审批"></van-tab>
                <van-tab title="已失效"></van-tab>
            </van-tabs>
        </div>

        <!-- 列表 -->
        <div class="main" ref="main" @scroll="handleScroll">
            <template v-if="isHaveList">
                <template v-for="(it,i) in list">
                    <div class="record" @click="toDetail(it)">
                        <div class="title">
                            <span>申请时间：{{it.createtime}}</span>
                            <template v-if="it.approve_status == 1"><span style="color: #FF9430;">待同意</span></template>
                            <template v-if="it.approve_status == 2"><span style="color: #44C966;">已同意</span></template>
                            <template v-if="it.approve_status == 3"><span style="color: red;">已驳回</span></template>
                            <template v-if="it.approve_status == 4"><span style="color: #666;">已失效</span></template>
                        </div>
                        <div class="detail">
                            <div class="info">
                                <span style="width: 90px;">来访人姓名：</span><span>{{it.name}}</span>
                            </div>
                            <div class="info">
                                <span style="width: 90px;">来访人性别：</span><span>{{it.gender == '1'?'男':'女'}}</span>
                            </div>
                            <div class="info">
                                <span>联系电话：</span><span>{{it.telephone}}</span>
                            </div>
                            <div class="info">
                                <span>来访时间：</span><span>{{it.visit_time}}</span>
                            </div>
                            <div class="info">
                                <span>来访事由：</span><span>{{it.visit_reason}}</span>
                            </div>
                        </div>
                    </div>
                </template>
            </template>
            <template v-if="noList">
                <div class="noList">
                    <img src="./image/noList.png" alt="">
                    <span>暂无数据</span>
                </div>
            </template>
        </div>

     
    </div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script type="text/javascript" src="../../common/js/vue.min.js"></script>
<script type="text/javascript" src="../../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../../common/js/base.js"></script>
<script type="text/javascript" src="../../common/js/jssdk.js"></script>
<script type="text/javascript" src="../../common/js/jwxwork.js"></script>
<script type="text/javascript" src="../../common/js/watermark.js?v=1.2"></script>
<script type="text/javascript" src="../../common/js/vConsole.min.js"></script>
<script type="text/javascript" src="../../common/js/server.js"></script>
<script type="text/javascript" src="./js/visitRecord.js?v=0.0.18"></script>
<script>

    // var vConsole = new VConsole();


    //初始化微信社区
    $(function () {
        initJSSDK([ 'hideAllNonBaseMenuItem','invoke','chooseImage','uploadImage','previewImage']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });


    function getUserFinish() {
        action();
    }


</script>
<script type="text/javascript" src="../../common/js/getUserInfo.js"></script>
