/* 标题左竖线 */

.view_left_vertical {
    position: relative;
    padding-left: 10px;
}

.view_left_vertical::before {
    position: absolute;
    display: inline-block;
    content: '';
    top: calc(50% - 9px);
    left: 0;
    width: 3px;
    height: 18px;
    background-color: #4675c9;
}

/* 左箭头 */

.session_item_container_right_link {
    position: relative;
    padding-right: 10px;
}

.session_item_container_right_link::before {
    content: " ";
    display: inline-block;
    height: 5px;
    width: 5px;
    border-width: 1px 1px 0 0;
    border-color: #999;
    border-style: solid;
    /* -webkit-transform: matrix(.71,.71,-.71,.71,0,0); */
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: 50%;
    position: absolute;
    margin-top: -2px;
    right: 0px;
}

/* 下箭头 */

._bottom_link {
    position: relative;
    padding-right: 18px;
}

._bottom_link::before {
    content: " ";
    display: inline-block;
    height: 8px;
    width: 8px;
    border-width: 1px 1px 0 0;
    border-color: #333;
    border-style: solid;
    transform: matrix(.71,.71,.71,-.71,0,0);
    top: 50%;
    position: absolute;
    margin-top: -6px;
    right: 3px;
}

/* 右箭头 */

._right_link {
    position: relative;
    padding-right: 18px;
}

._right_link::before {
    content: "";
    display: inline-block;
    height: 6px;
    width: 6px;
    border-width: 1px 1px 0 0;
    border-color: #333;
    border-style: solid;
    transform: matrix(.71,.71,-.71,.71,0,0);
    top: 50%;
    position: absolute;
    margin-top: -3px;
    right: 0;
}

/* 语音 */

.voice_content {
    margin-top: 10px;
    border: 1px solid #4675c9;
    border-radius: 4px;
}

.voice_icon {
    width: 15px;
    margin-right: 10px;
}

.voice_icon img {
    width: 100%;
}

/* 底部 */

.footer_container {
    padding: 10px 12px;
}

.button_container {
    height: 50px;
    background: #4675c9;
    color: #fff;
    border-radius: 6px;
}

.button_container_left {
    border: 1px solid #4675c9;
    border-radius: 6px;
    height: 50px;
    color: #4675c9;
    margin-right: 10px;
}

/* 固定底部 */

.footer_container_fiexd {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50px;

}

/* 流转信息 */

.content_part {
    overflow: hidden;
}

.apply_name {
    padding: 5px 0;
}

.apply_message {
    margin-top: 5px;
}


.van-step--vertical .van-step__line {
    top: 34px;
    height: calc(100% - 20px);
}

[class*=van-hairline]::after {
    border-color: #ddd;
}

.van-step--vertical {
    padding: 15px 15px 15px 0;
}

.van-step--vertical .van-step__circle-container {
    top: 25px;
}

/* 审批意见 */

.approve_checked_item {
    margin-left: 12px;
}

.approve_checked_icon {
    width: 18px;
    height: 18px;
    margin-right: 8px;
    display: inline-block;
}

.approve_checked_icon img {
    width: 100%;
}

.view_content_approve {
    padding: 0px 10px 15px 10px;
}

.triangle {
    position: relative;
    padding-right: 15px;
}

.triangle::before {
    content: '';
    position: absolute;
    border-width: 0 6px 6px 0;
    border-style: solid;
    border-color: transparent transparent #A8A8A8 transparent;
    transform: rotate(-45deg);
    top: calc(50% - 3px);
    right: 5px;
}




/* 整屏弹框 */

/* popup-right */
.popup--nodes--overlay {
    background-color: #fff !important;
}

.van-popup--right {
    background-color: #f5f5f5 !important;
}


.popup-img-box {
    width: 18px;
    align-items: center;
    margin-right: 10px;
}

.popup-img-box img, .popup-main-item-img img {
    width: 100%;
}

.popup-main-item-img div {
    width: 18px;
    height: 18px;
}

.popup__container {
    padding: 12px 12px 0;
}

.session__item__container
{
    height: 50px;
    padding: 0 12px;
}

.popup__main__container {
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
}

.border_top_bofore:first-child {
    border-top: none;
}

.borderradius6 {
    border-radius: 6px;
}

.popup__main__item__img img {
    width: 100%;
}

.popup__main__item__img div {
    width: 18px;
    height: 18px;
}

.popup__footer__container {
    padding: 45px 0px;
}


.button__cancel {
    height: 45px;
    line-height: 45px;
    text-align: center;
    border: 1px solid #4273d8;
    /* background: #2467FF; */
    color: #4273d8;
    border-radius: 6px;
    margin-right: 12px;
    box-sizing: border-box;
}

.button__container {
    height: 45px;
    line-height: 45px;
    text-align: center;
    background: #4273d8;
    color: #fff;
    border-radius: 6px;
}

/* 中间弹框提示 */

.popup_center_container {
    width: calc(100vw - 96px);
    border-radius: 8px;
}

.popup_center_content {
    padding: 30px 0;
    font-family: PingFangSC-Medium;
    font-size: 17px;
    color: #3B3B3B;
    text-align: center;
    font-weight: 500;
}

.popup_center_footer_btn {
    height: 50px;
}


/* 底部弹框 */

.van-picker__toolbar {
    height: 50px;
    border-bottom: 1px solid rgba(6,15,26,0.10);
}

.van-picker__cancel {
    color: #999;
    font-size: 15px;
}

.van-picker__title {
    font-weight: 500;
    font-size: 16px;
    color: #000;
}

.van-picker__confirm {
    color: #4675c9;
    font-size: 15px;
}

.van-picker-column__item--selected > .van-ellipsis {
    color: #4675c9;
}

.position_icon {
    display: inline-block;
    padding-top: 3px;
    width: 13px;
    height: 16px;
    margin-right: 10px;
}



/* vant 初始化 */

.van-cell {
    padding: 0;
    /* font-size: 15px; */
    line-height: unset;
}

.van-field__control {
    color: #272727;
    font-size: 16px;
}

::-webkit-input-placeholder {
    color:  #999 !important;
    font-size: 16px;
}


.van-popup--right {
    background-color: #f3f4f6 !important;
}

.weui-dialog__btn {
    color: #0475c9 !important;
}

.van-popup--round {
    border-radius: 8px !important;
}

/* 列表 */

.noList img{
    display: block;
    width: 80%;
}
.noList span{
    margin-top: 10px;
    color: #000000;
    line-height:32px;
    font-size:15px;
}
.noList{
    width: 94%;
    height: 100px;
    margin: 38% auto 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #000000;
    line-height:32px;
}
.noList img{
    width:55%;
}

.header_fiexd {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
}


.footer_fiexd {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    background-color: #fff;
}

.footer_fiexd_container {
    height: 50px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, .1);
}


.border_right_before {
    position: relative;
}

.border_right_before::before {
    content: '';
    position: absolute;
    height: 20px;
    width: 1px;
    right: 0;
    top: calc(50% - 10px);
    background-color: #e1e1e1;
}

.required {
    position: relative;
    color: #FF4D4F;
}

/* .required::before {
    content: '*';
    position: absolute;
    color: #FF4D4F;
    right: 0;
} */

.picker_header {
    position: fixed;
    width: 100%;
    height: 50px;
    padding: 0 15px;
    z-index: 99;
    background-color: #fff;
}

.picker_main {
    padding: 5px 12px;
}

.van-checkbox-group .van-cell {
    padding: 13px;
    
}

.van-cell .van-cell__value .van-checkbox {
    justify-content: flex-end !important;
}
