<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
        name="viewport" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>党委书记接待日登记</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/registInput.css?v=1.3">
    <link rel="stylesheet" href="css/common.css">
</head>

<body style="background:#fff">
    <div id="app" style="height: 100% " v-cloak>
        
        <div style="position: relative;background: #F6F7F9;border-radius: 5px;height: 100%"
            v-if="page=='page1'">
            <div class="listScroll" >

                <div>
                    <div class="listParts">
                        <div>
                            <div class="containList">
                                <div class="listLine">
                                    <div>姓名</div>
                                    <div>{{item.name}}</div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="listParts">
                        <div>
                            <div class="containList">
                                <div class="listLine">
                                    <div>性别</div>
                                    <div>{{item.sex == '1' ? '男' : '女'}}</div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="listParts" style="margin-bottom:8px">
                        <div>
                            <div class="containList">
                                <div class="listLine">
                                    <div>联系电话</div>
                                    <div>
                                        <van-field v-model="formData.mobile" rows="1" maxlength="15" autosize input-align="right"
                                            type="tel" placeholder="请输入">
                                        </van-field>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="listParts">
                        <div>
                            <div class="containList">
                                <div class="listLine">
                                    <div>所在单位</div>
                                    <van-field v-model="formData.registrationDept" rows="1" autosize input-align="right"
                                        type="textarea" placeholder="请输入">
                                    </van-field>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="listParts">
                        <div>
                            <div class="containList">
                                <div class="listLine">
                                    <div>职务</div>
                                    <van-field v-model="formData.registrationPost" rows="1" autosize input-align="right"
                                        type="textarea" placeholder="请输入">
                                    </van-field>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>


            </div>
            <div class="selectDate" @click="chooseTab(tab)">
                <p>预约访谈时间</p>
                <p style="margin-right: 3%">{{month}}</p>
            </div>
            <div class="inputTitle">
                <p>预约访谈事项</p>
            </div>
            <div style="background: #fff;">
                <div style="box-sizing:border-box">
                    <div class="textAreaPart"  >
                        <div class="yuyun-box" @click="showRecorddiv()">
                            <img src="./image/yuyin.png " />可尝试语音输入
                        </div>
                        <div class="yuyinTextArea">
                            <van-field v-model="formData.LoanPpsDsc" rows="3" autosize type="textarea" class="input_textarea"
                            maxlength="500" show-word-limit placeholder="请填写">
                        </van-field>
                        </div>   
                    </div>
                    <div >
                        <div class="recodeblock" @click="startRecord">
                            <img src="image/luyin.gif"> <div start="no" class="luyinbtn">开始说话</div>
                        </div>
                    </div>
                </div>
           

            <div class="btn">
                <span @click="subInfo">提交</span>
            </div>
            <van-popup v-model="monthShow" position="bottom" style="border-radius: 6px;">
                <van-datetime-picker type="year-month" title="按年月筛选" :min-date='minDate' v-model='formData.currentDate'
                    :formatter="formatter" @cancel="monthShow=false" @confirm="chooseDate">
                </van-datetime-picker>
            </van-popup>
        </div>


        
    </div>
    <div v-if="page=='page2'" style="background:#fff">
            <div class="resultPart">
                <img src="image/result.png">
                <div>提交成功</div>
            </div>
            
            <div class="confirm" @click="toExit">确认</div>
       </div>



</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/registInput.js?v=1.0"></script>
<script src="../common/js/vConsole.min.js"></script> 
<script type="text/javascript">
// var vConsole = new VConsole();
    //初始化微信社区
    $(function () {
        initJSSDK(['hideAllNonBaseMenuItem', 'chooseImage', 'uploadImage', 'downloadImage', 'startRecord', 'stopRecord', 'translateVoice', 'closeWindow']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });
    function getUserFinish() {
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun();
    }

</script>
<script type="text/javascript" src="../common/js/getUserInfo.js?v=202110229"></script>

</html>