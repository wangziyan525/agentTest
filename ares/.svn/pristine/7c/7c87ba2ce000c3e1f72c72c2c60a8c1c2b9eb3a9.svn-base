<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"
        name="viewport" />
    <mata http-equiv="Content-Security-Policy" content="upgrade-insecure-requests" />
    <title>白名单审批管理</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../common/css/weui.min.css" />
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="./css/style.css?v=1.0.6">
</head>

<body>
    <div id="app" v-cloak>
        <div>
            <!-- 待审批 、已审批 -->
            <div>
                <div class="tab_con">
                    <span v-for="(item,index) in tabs" :key="index" :class="tabIndex==index?'active':'color999'"
                        @click='tabTap(index,item.id)'>{{item.text}}</span>
                </div>
                <div class="viewFlag">
                    <div class="list_box">
                        <div class="list_t">共<span
                                style="color: #0465FF;font-weight:bold;">{{list.length}}</span>条{{tabIndex==0?'待':"已"}}审批快E贷申请单
                        </div>
                        <div v-if='list.length>0' v-for="(item,index) in list" :key='index'>
                            <div class="displayTop">
                                <div v-if='tabIndex==0' style="padding:10px 10px 10px 0;" @click='selectTap(index)'>
                                    <img class="select_img"
                                        :src="item.check?'./images/selected.png':'./images/select.png'" alt="">
                                </div>
                                <div :class="tabIndex==0?'list_m approval_list displayFlex':'list_m displayFlex'" >
                                    <div class="list_m_r">
                                        <div>
                                            <span>客户姓名</span>
                                            <span>{{item.ClientNm}}</span>
                                        </div>
                                        <div>
                                            <span>身份证号</span>
                                            <span>{{item.IdentNum}}</span>
                                        </div>
                                        <div>
                                            <span>单位名称</span>
                                            <span>{{item.UtNm}}</span>
                                        </div>
                                        <div>
                                            <span>职级</span>
                                            <span>{{item.Pstn}}</span>
                                        </div>
                                    </div>
                                    <div class="more_box"  @click='toDetail(item)'>
                                        <img class="more_img" src="./images/more.png" alt="">
                                    </div>
                                </div>
                            </div>
                            <!-- 占位 -->
                            <div style="height:10px;"></div>
                        </div>
                        <div v-if='list.length==0' class="noData">
                            <img src="./images/noList.png" alt="">
                            <div>暂无数据</div>
                        </div>
                    </div>
                    <div v-if='tabIndex==0&&list.length>0'>
                        <!-- 占位 -->
                        <div style="height:100px"></div>
                        <div class="list_btn displayFlex">
                            <div class="displayStart" @click='selectAllTap'>
                                <img class="select_img"
                                    :src="checkAllFlag?'./images/selected.png':'./images/select.png'" alt="">
                                <span style="margin-left:6px;">全选</span>
                            </div>
                            <div class="approval_btn displayFlex">
                                <span @click='disagreeShowTap'>驳回</span>
                                <span @click='peopleShowTap'>审核并提交</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <!-- 驳回 -->
                        <van-popup v-model="disagreeFlag" position="bottom" style="border-radius:8px 8px 0 0;">
                            <div>
                                <div class="disagree_t">驳回申请</div>
                                <div class="disagree_m lineBottom">
                                    <div class="disagree_m_t">
                                        <span>驳回意见</span>
                                        <span style="color: #FF4D4F;">*</span>
                                    </div>
                                    <div class="textarea_box">
                                        <textarea class="textClass" v-model='disagreeVal' placeholder="请输入你的驳回意见"
                                            maxlength="200"></textarea>
                                        <span class="text_num">{{disagreeVal.length}}/200</span>
                                    </div>
                                    <div class="disagree_tips">注：驳回理由将同步至申请人，需清晰具体</div>
                                </div>
                                <div class="disagree_btn" :style="disagreeVal==''?'opacity: 0.4;':''">
                                    <div @click='disagreeTap'>提交</div>
                                </div>
                            </div>
                        </van-popup>
                        <!-- 审核人选择 -->
                        <van-popup v-model="peopleObj.peopleShow" position="bottom" style="border-radius:8px 8px 0 0;">
                            <van-picker show-toolbar :title="peopleObj.title" item-height="50px" visible-item-count="3"
                                :columns="peopleObj.peopleList" @confirm="peopleConfirm"
                                @cancel="peopleObj.peopleShow=false">
                            </van-picker>
                        </van-popup>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>

</html>
<!-- 引入 Vue 的 JS 文件 -->
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/server.js"></script>
<script type="text/javascript" src="./js/list.js?v=1.4.5"></script>
<script type="text/javascript" src="../common/js/watermark.js?v=1.3"></script>
<!-- <script type="text/javascript" src="../common/js/vConsole.min.js"></script> -->
<script>
    // var vConsole = new VConsole();
    //初始化微信社区
    $(function () {
        initJSSDK(['hideAllNonBaseMenuItem', 'invoke', 'closeWindow']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });
    function getUserFinish() {
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun();
    }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>