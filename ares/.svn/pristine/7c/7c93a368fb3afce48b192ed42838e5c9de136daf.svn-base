<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
          name="viewport" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>西安银行</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/statement.css">
</head>
<body style="overflow: hidden">
<div id="app" style="overflow-y: hidden;height: 100%;display:none">
    <div style="position: relative;background: #fff;border-radius: 5px;box-sizing: border-box">
        <div style="display: flex;justify-content: space-between;align-items: center;border-bottom: 1px solid #eee">
            <div class="tab" style="width: 70%;border-bottom: 0">
                <div style="width: 22%"><p :class="tab=='1'?'activeTab':''" @click="chooseTab('1')">按月</p></div>
                <div style="width: 22%"><p :class="tab=='0'?'activeTab':''" @click="chooseTab('0')">按日</p></div>
            </div>
            <div>
                <img src="image/export.png" @click="exportData()" style="display: block;padding-right: 15px">
            </div>
        </div>

        <div class="selectDate" @click="chooseTab(tab)">
            <p v-if="tab=='1'">筛选月份</p>
            <p v-if="tab=='0'">筛选日期</p>
            <p v-if="tab=='1'" style="margin-right: 3%" >{{month}}</p>
            <p v-if="tab=='0'" style="margin-right: 3%" >{{day}}</p>
        </div>
    </div>

    <div class="listScroll" style="overflow-y: auto">
        <van-list>
            <div v-if="list.length>0" v-for="(item, index) in list">
                <div class="listParts">
                    <div>
                        <div class="containList" @click="jump(item)">
                            <div class="listLine">
                                <div>{{item.time}}</div>
                                <div><img src="image/right.png"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </van-list>

    </div>

    <div v-if="tab=='0'" style="">
        <div class="listTitle">
            <p>网点名称</p><p>上午</p><p>下午</p>
        </div>
        <div class="orgList" style="overflow-y: auto">
            <div v-if="orgList.length>0" v-for="(item, index) in orgList">
                <div class="listInfo">
                    <p>{{item.buDescr}}-{{item.ssbm}}</p>
                    <p v-if="item.morningStatus==1" style="color:#2EB34B">已完成</p>
                    <p v-if="item.morningStatus==0" style="color:#FF573F">未完成</p>
                    <p v-if="item.morningStatus==2" style="color:#FF573F">不营业</p>
                    <p v-if="item.afternoonStatus==1" style="color:#2EB34B">已完成</p>
                    <p v-if="item.afternoonStatus==0" style="color:#FF573F">未完成</p>
                    <p v-if="item.afternoonStatus==2" style="color:#FF573F">不营业</p>
                </div>
            </div>
        </div>
        <div class="nodata" v-if="orgList.length==0 || orgList.length==null">暂无数据</div>
    </div>

    <van-popup v-model="dayShow" position="bottom" style="border-radius: 6px;">
        <van-datetime-picker type="date"
                             title="按日筛选"
                             :max-date='maxDate'
                             v-model='currentDate'
                             :formatter="formatter"
                             @cancel="dayShow=false"
                             @confirm="chooseDate">
        </van-datetime-picker>
    </van-popup>
    <van-popup v-model="monthShow" position="bottom" style="border-radius: 6px;">
        <van-datetime-picker type="year-month"
                             title="按年月筛选"
                             :max-date='maxDate'
                             v-model='currentDate'
                             :formatter="formatter"
                             @cancel="monthShow=false"
                             @confirm="chooseDate">
        </van-datetime-picker>
    </van-popup>

</div>


</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/statementDF.js?v=20230410"></script>
<script type="text/javascript">
    //初始化微信社区
    $(function() {
        initJSSDK(['hideAllNonBaseMenuItem','chooseImage','uploadImage','downloadImage', 'startRecord', 'stopRecord', 'translateVoice','closeWindow']);
        wx.ready(function() {
            wx.hideAllNonBaseMenuItem();
        });
    });
    function getUserFinish(){
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }

</script>
<script type="text/javascript" src="../common/js/getUserInfo.js?v=202110229"></script>
</html>