<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"
        name="viewport" />
    <mata http-equiv="Content-Security-Policy" content="upgrade-insecure-requests" />
    <title>问诊预约管理</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../../common/css/weui.min.css" />
    <link rel="stylesheet" href="../../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../css/style.css?v=1.0.3">
</head>

<body>
    <div id="app" v-cloak>
        <div class="edit_t">
            <div class="displayFlex lineBottom">
                <span>医师姓名</span>
                <input type="text" placeholder="填写医师姓名" v-model='doctorName'>
            </div>
            <div class="displayFlex lineBottom">
                <span>医师头衔</span>
                <div class="displayEnd" @click='positionObj.positionShow=true'>
                    <input type="text" placeholder="请选择医师头衔" readonly v-model='positionText'>
                    <img class="more_img" src="../images/more.png" alt="">
                </div>
            </div>
            <div>
                <div style="padding:10px 0;box-sizing: border-box;">问诊时间段</div>
                <div class="displayFlex">
                    <span class="timeClass" @click='dateShow(1)' :style="startDate==''?'color:#999':''">{{startDate?startDate:'起始时间'}}</span>
                    <span style="width:10px;height:1px;background:#F2F2F2;"></span>
                    <span class="timeClass" @click='dateShow(2)'  :style="endDate==''?'color:#999':''">{{endDate?endDate:'终止时间'}}</span>
                </div>
            </div>
        </div>
        <!-- 占位 -->
        <div style='height:10px'></div>
        <div class="edit_m">
            <div class="edit_m_t displayFlex">
                <span>每日问诊时间段截止时间</span>
                <div class="displayEnd">
                    <span @click='timeObj.timeShow=true' :style="endTime==''?'color:#999':''">{{endTime==''?'选择时间':endTime}}</span>
                    <img class="more_img" src="../images/more.png" alt="">
                </div>
            </div>
            <div class="edit_m_b">
                温馨提示：最晚不超过 22:00
            </div>
        </div>
        <!-- 医师简介 -->
        <div class="doctorIntr">
            <div class="doctorIntr_t lineBottom">医师简介</div>
            <div class="doctorIntr_b">
                <textarea name="" id="" cols="30" rows="10" placeholder="请输入医师简介内容"
                v-model="markValue" maxlength="500"></textarea>
            </div>
        </div>
        <!-- 占位 -->
        <div style="height:100px"></div>
        <div class="footer_btn" @click='submitTap'>保存</div>
        <div>
            <!-- 医师头衔 -->
            <van-popup v-model="positionObj.positionShow" position="bottom" style="border-radius:8px 8px 0 0;">
                <van-picker show-toolbar :title="positionObj.title" item-height="50px" visible-item-count="3"
                    :columns="positionObj.positionList" @confirm="positionConfirm" @cancel="positionObj.positionShow=false">
                </van-picker>
            </van-popup>
            <!--日期选择-->
            <van-popup v-model="dateObj.dateShow" position="bottom" style="border-radius: 6px;">
                <van-datetime-picker type="date" title="按年月筛选" v-model="dateObj.currentDate" :min-date='dateObj.minDate'
                    :formatter="formatter" @cancel="dateObj.dateShow=false" @confirm="chooseDate">
                </van-datetime-picker>
            </van-popup>
            <!-- 时间选择 -->
            <van-popup v-model="timeObj.timeShow" position="bottom" style="border-radius: 6px;">
                <van-datetime-picker type="time" title="截止时间" :min-hour='9' :formatter="formatterTime"
                    @cancel="timeObj.timeShow=false" @confirm="chooseTime">
                </van-datetime-picker>
            </van-popup>
        </div>
    </div>
</body>

</html>
<!-- 引入 Vue 的 JS 文件 -->
<script type="text/javascript" src="../../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../../common/js/vue.min.js"></script>
<script type="text/javascript" src="../../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../../common/js/base.js"></script>
<script type="text/javascript" src="../../common/js/jssdk.js"></script>
<script type="text/javascript" src="../../common/js/server.js"></script>
<script type="text/javascript" src="./js/doctorEdit.js?v=1.2.1"></script>
<script type="text/javascript" src="../../common/js/watermark.js?v=1.2"></script>
<script>
    //初始化微信社区
    $(function () {
            initJSSDK(['hideAllNonBaseMenuItem', 'invoke','closeWindow']);
            wx.ready(function () {
                wx.hideAllNonBaseMenuItem();
            });
        });
    function getUserFinish() {
            // 调用水印
            var username = $.parseJSON($.cookie("user")).name;
            __canvasWM({
                content: username
            });
            initFun();
        }
</script>
<script type="text/javascript" src="../../common/js/getUserInfo.js"></script>