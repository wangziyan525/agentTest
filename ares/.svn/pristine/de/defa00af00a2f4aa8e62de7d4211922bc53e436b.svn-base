[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
/* ---------------------------------------- 列表 --------------------------------------*/
.mainModel{
    width: 100%;
    flex: 1;
    overflow-y: auto;
    padding: 10px 12px;
    box-sizing: border-box;
}
/* ------- 没有列表 -------- */
.noList img{
    display: block;
    width: 70%;
}
.noList span{
    margin-top: 10px;
    color: #333;
    line-height:32px;
    font-size:15px;
}
.noList{
    width: 94%;
    height: 100px;
    margin: 30% auto 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #000000;
    line-height:32px;
}
.noList img{
    width:55%;
}
/* ------- 有列表 -------- */
.mainModel .list{
    width: 100%;
    padding: 15px 16px;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    justify-content: space-between;
    position: relative;
}
.mainModel .list::before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.mainModel .list:last-child::before{
    display: none;
}
.mainModel .list .left{
    display: flex;
}
.mainModel .list .left i{
    width: 20px;
    height: 20px;
    margin-right: 16px;
}
.mainModel .list .left i img{
    display: block;
    width: 100%;
}
.mainModel .list .left span{
    font-size: 15px;
    line-height: 20px;
    color: #000000;
}
.mainModel .list .right{
    font-size: 15px;
    line-height: 20px;
}
.mainModel .list .right .active1{
    color: #F91717;
}
.mainModel .list .right .active2{
    color: #44C966;
}
/* ---------------------------------------- 底部按钮 --------------------------------------*/
.btnModel{
    width: 100%;
    background: #fff;
    box-shadow: 0 -2px 4px 0 rgba(223,223,223,0.50);
    padding: 15px 15px 20px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.btnModel .bigBtn{
    width: 100%;
    background: #267EF0;
    border-radius: 6px;
    color: #fff;
    padding: 13px 0;
    box-sizing: 13px 0;
    font-size: 15px;
    line-height: 20px;
    border: 1px solid #267EF0;
    text-align: center;
}
.btnModel .smallBtn{
    width: calc((100% - 16px)/2);
    padding: 12px 0;
    box-sizing: 13px 0;
    font-size: 15px;
    line-height: 20px;
    text-align: center;
    border-radius: 6px;
    border: 1px solid #267EF0;
}
.btnModel .smallBtn:nth-child(1){
    color: #267EF0;
    background-color: transparent;
}
.btnModel .smallBtn:nth-child(2){
    color: #fff;
    background-color: #267EF0;
}