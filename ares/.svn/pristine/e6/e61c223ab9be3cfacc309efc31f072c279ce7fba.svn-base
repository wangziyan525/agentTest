<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>西安银行</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/index.css?v=2.0">
</head>
<body style="overflow: hidden">
    <div id="app" style="overflow-y: scroll;height: 100%;display:none">

        <div class="listTopPart">
            <div class="listOneLine">
                <img src="images/search.png">
                <div class="keyInput">                    
                    <van-field type="text" v-model="searchWord.name" placeholder="请输入密钥卡编号" maxlength="50" ></van-field>
                </div>
                <div class="keySearchBtn" @click="queryList">搜索</div>
            </div>
            <div class="listsecondLine">
                <div class="dateDown" @click="pickerdate('startTime')">{{searchWord.startTime?searchWord.startTime:"开始时间"}}</div>
                <div>—</div>
                <div class="dateDown" @click="pickerdate('endTime')">{{searchWord.endTime?searchWord.endTime:"结束时间"}}</div>
            </div>
            <van-popup
                        v-model="popupDataShow"
                        position="bottom"
                        :close-on-click-overlay="false">
                    <van-datetime-picker
                            v-model="currentDate"
                            type="date"
                            title="选择日期"
                            @confirm="getTime"
                            @cancel="closeTime"
                    >
                    </van-datetime-picker>
                </van-popup>
        </div>

        <div v-if="list.length>0">
            <div class="listContent" v-for="item in list" @click="goDetail(item.id)">
                <div class="listTopLine listBottomborder">
                    <div>申请时间：{{item.createTime}}</div>
                    <div :class="'cardStatus'+item.cardStatus">{{cardStatusOpt[item.cardStatus]}}</div>
                </div>
                <div class="listCard">
                    <div class="listLine">
                        <div>密钥卡编号：</div>
                        <div>{{item.cardNumber}}</div>
                    </div>
                    <div class="listLine" v-if="flag=='2'">
                        <div>申请人：</div>
                        <div>{{item.applyPeopleName}}</div>
                    </div>
                    <div class="listLine" v-if="flag=='2'">
                        <div>所属部门：</div>
                        <div>{{item.applyDepartment}}</div>
                    </div>
                </div>
                <div class="listBottomLine listTopborder" v-if="item.cardStatus!='0'">
                    <div>审核时间：{{item.updateTime}}</div>
                    <div class="listrefuse" v-if="item.cardStatus=='3'">
                        <div>驳回理由</div>
                        <div>{{item.remark}}</div>
                    </div>
                </div>
            </div>
        </div>
        <div v-else class="nodate">
            <div class="noMessage">
                <img src="images/noMessage.png">
            </div>
            暂无数据
        </div>
        <div style="height: 55px;"></div>
        <div class="footTab" v-if="flag=='1'">
            <div class="applyButton" @click="applyBtn">
                <div>申请密钥卡</div>
            </div>
       </div>
    </div>
</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="./../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/list.js"></script>
<!-- <script src="../common/js/vConsole.min.js"></script> -->
<script type="text/javascript">
    // var vConsole = new VConsole();

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });
    function getUserFinish(){
            initJSSDK(['hideAllNonBaseMenuItem','invoke','closeWindow']);

           wx.ready(function() {
               wx.hideAllNonBaseMenuItem();
               WeixinJSBridge.on('menu:setfont', function() {
                    WeixinJSBridge.invoke('setFontSizeCallback', { 'fontSize' : '0' });
                });

           });
           
           // 调用水印
           var username = $.parseJSON($.cookie("user")).name;
           __canvasWM({
               content: username
           });
           initFun()
    }
    // initFun()
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>