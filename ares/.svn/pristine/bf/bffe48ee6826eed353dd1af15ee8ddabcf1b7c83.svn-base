<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>建档详情</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/index.css?v=4.0">
</head>
<body style="overflow: hidden">
<div id="app" style="overflow-y: scroll;height: 100%;display:none">
    <div class="detailCard">
        <div class="detailTop">
            
            <div class="listOneNew">
                <div>{{ detail.EntpNm }}</div>
                <div class="detailStatusNew">
                    <div class="listStatus10" v-if="detail.deleted=='Y'">已作废</div>
                    <div :class="'listStatus'+detail.status" v-else>{{listStatusOpt[detail.status]}}</div>

                </div>
            </div>
            <div class="listTag" style="margin-bottom: 10px;">
                <div  :class="'phjdzt'+detail.EstbDocMnBy">
                    {{estbdocmnbyListOpt[detail.EstbDocMnBy]}}
                </div>
                <div v-if="detail.isopencard" :class="'isopencard'+detail.isopencard">
                    {{listopencardOpt[detail.isopencard]}}
                </div>
                <div v-if="detail.isopenacct" :class="'isopencard'+detail.isopenacct">
                    {{listopenacctOpt[detail.isopenacct]}}
                </div>
            </div>

            <div class="listTime">
                <div>法人：{{ detail.EntpCtcManNm }}</div>
                <div>电话：{{ detail.EntpCtcManTelNum }}</div>
            </div>


        </div>

        <div class="detailtopLine">
            <div class="listTime">
                <div>首次建档时间：{{ detail.cREATETIME }}</div>
            </div>
        </div>
    </div>

    <div class="tabList" style="margin-bottom: 10px;">
        <div :class="tab=='1'?'activeTab':''" @click="choosetab('1')" style="font-size: 16px;">建档情况</div>
        <div :class="tab=='2'?'activeTab':''" @click="choosetab('2')" style="font-size: 16px;">办理业务</div>
        <div :class="tab=='3'?'activeTab':''" @click="choosetab('3')" style="font-size: 16px;">跟进记录</div>
    </div>

    <div v-if="tab=='1'">
        <div v-if="flag=='1'">
            <div class="contentPart">
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>基本信息</div>
                        <div :class="sildeIndex[0] ? 'openText':'closeText'" @click="slideHandle(0)">
                            {{ sildeIndex[0] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[0]">
                        <div class="phDetailBox">

                            <div class="slide_content_item">
                                <div>联系人姓名</div>
                                <div>
                                    {{ detail.EntpCtcManNm }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>身份证号码</div>
                                <div>
                                    {{ detail.EstbDocManIdentNum }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>联系人电话</div>
                                <div>
                                    {{ detail.EntpCtcManTelNum }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>客户需求</div>
                                <div>
                                    {{ formatCheckBox(detail.AcctMrk, chooseList1) }}{{ detail.AcctMrkDsc ? ':' +
                                    detail.AcctMrkDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>备注</div>
                                <div>
                                    {{ detail.Rak }}
                                </div>
                            </div>
                        </div>
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>企业名称</div>
                                <div>
                                    {{ detail.EntpNm }}
                                    <img class="copyImg" src="images/copy.png" @click="copyHandle(detail.EntpNm)">
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>统⼀社会信⽤代码</div>
                                <div>
                                    {{ detail.UnifyUvslCrCd }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>所属⾏业</div>
                                <div>
                                    {{ formatRadio(detail.AtchIndus, chooseList2) }}{{ detail.AtchIndusDsc ? ':' +
                                    detail.AtchIndusDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>经营年限</div>
                                <div>
                                    {{ formatRadio(detail.CorpYr, chooseList3) }}
                                </div>
                            </div>
                            <div class="oneContent_item">
                                <div class="slide_content_item">
                                    <div>建档定位</div>
                                    <div>
                                        <img class="copyImg" src="images/copy.png"
                                             @click="copyHandle(detail.EntpCorpAdr)">
                                    </div>
                                </div>
                                <div class="_slide_content_item">
                                    {{ detail.EntpCorpAdr }}
                                </div>
                            </div>
                            <div class="contentChoose borderLine" v-if="imageLocal1.length>0">
                                <div class="imgText">招牌照片</div>
                                <div class="imgUpload">
                                    <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal1">
                                        <img :src="itemImg" class="uploadImg"
                                             @click="previewHandle(imageLocal1, indexImg)">
                                    </div>

                                </div>
                            </div>
                            <div class="contentChoose borderLine" v-if="imageLocal3.length > 0">
                                <div class="imgText">小微企业办公或经营场所照片</div>
                                <div class="imgUpload">
                                    <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal3">
                                        <img :src="itemImg" class="uploadImg"
                                             @click="previewHandle(imageLocal3, indexImg)">
                                    </div>

                                </div>
                            </div>
                            <div class="contentChoose borderLine" v-if="imageLocal2.length > 0">
                                <div class="imgText">营业执照</div>
                                <div class="imgUpload">
                                    <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal2">
                                        <img :src="itemImg" class="uploadImg"
                                             @click="previewHandle(imageLocal2, indexImg)">
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div style="height: 10px;"></div>
                    </div>

                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>融资需求与负债</div>
                        <div :class="sildeIndex[1] ? 'openText':'closeText'" @click="slideHandle(1)">
                            {{ sildeIndex[1] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[1]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>资金用途</div>
                                <div>
                                    {{ formatCheckBox(detail.TchPps, chooseList4) }}{{ detail.TchPpsDsc ? ':' +
                                    detail.TchPpsDsc
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>希望多久可以拿到贷款</div>
                                <div>
                                    {{ formatRadio(detail.ExpcTrm, chooseList5) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>利率接受范围</div>
                                <div>
                                    {{ formatRadio(detail.IntRtAcptScop, chooseList6) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>期望额度</div>
                                <div>
                                    {{ formatRadio(detail.ExptLmt, chooseList7) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法定代表人持股比例</div>
                                <div>
                                    {{ detail.LglRprsShrhldRto ? detail.LglRprsShrhldRto + '%' : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法定代表人负债情况</div>
                                <div>
                                    {{ formatRadio(detail.LglRprsLbyCcst, chooseList8) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法定代表人负债类型</div>
                                <div>
                                    {{ formatCheckBox(detail.LglRprsLbyTp, chooseList9) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>企业负债情况</div>
                                <div>
                                    {{ formatCheckBox(detail.EntpLbyCcst, chooseList10) }}
                                </div>
                            </div>
                        </div>
                        <div style="height: 10px;"></div>
                    </div>

                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>经营情况</div>
                        <div :class="sildeIndex[2] ? 'openText':'closeText'" @click="slideHandle(2)">
                            {{ sildeIndex[2] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[2]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>企业主营业务</div>
                                <div>{{ detail.EntpMnByBsn }}</div>
                            </div>
                            <div class="slide_content_item">
                                <div>经营场所</div>
                                <div>
                                    {{ formatRadio(detail.CorpPce, chooseList11) }}{{ detail.LseMoRntl ? ':' +
                                    detail.LseMoRntl
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>企业近6个⽉⽉均营收</div>
                                <div>
                                    {{ formatRadio(detail.EntpPrxSixMoMoyAvIncm, chooseList12) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>企业员工</div>
                                <div>
                                    {{ formatRadio(detail.EntpStfPsnNum, chooseList13) }}
                                </div>
                            </div>

                        </div>
                        <div style="height: 10px;"></div>
                    </div>
                </div>

                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>家庭情况</div>
                        <div :class="sildeIndex[3] ? 'openText':'closeText'" @click="slideHandle(3)">
                            {{ sildeIndex[3] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[3]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>法人年龄范围</div>
                                <div>
                                    {{ formatRadio(detail.frnlfw, chooseList20) }}{{ detail.frnlfwotherdsc ? ':' +
                                    detail.frnlfwotherdsc
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法人婚姻子女情况</div>
                                <div>
                                    {{ formatRadio(detail.frhyznqk, chooseList21) }}{{ detail.frhyznqkotherdsc ? ':' +
                                    detail.frhyznqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法人子女学龄</div>
                                <div>
                                    {{ formatRadio(detail.frznxl, chooseList22) }}{{ detail.frznxlotherdsc ? ':' +
                                    detail.frznxlotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>赡养老人情况</div>
                                <div>
                                    {{ formatRadio(detail.sylrqk, chooseList23) }}{{ detail.sylrqkotherdsc ? ':' +
                                    detail.sylrqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <!-- <div class="slide_content_item">
                                <div>老人身体情况</div>
                                <div>
                                    {{ formatRadio(detail.lrstqk, chooseList24) }}{{ detail.lrstqkotherdsc ? ':' +
                                    detail.lrstqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>老人经济情况</div>
                                <div>
                                    {{ formatCheckBox(detail.lrjjqk, chooseList25) }}{{ detail.lrjjqkotherdsc ? ':' +
                                    detail.lrjjqkotherdsc
                                    : ''}}
                                </div>
                            </div> -->
                            <div class="slide_content_item">
                                <div>家庭月均支出情况</div>
                                <div>
                                    {{ formatRadio(detail.jtyjzc, chooseList26) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>家庭情况主观评价</div>
                                <div>
                                    {{ formatCheckBox(detail.jtqkzgpj, chooseList27) }}{{ detail.jtqkzgpjotherdsc ? ':'
                                    + detail.jtqkzgpjotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>信息来源</div>
                                <div>
                                    {{ formatCheckBox(detail.datasourcesjtqk, chooseList28) }}{{
                                    detail.datasourcesjtqkotherdsc ? ':' + detail.datasourcesjtqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                        </div>
                        <div style="height: 10px;"></div>
                    </div>
                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>资产情况</div>
                        <div :class="sildeIndex[4] ? 'openText':'closeText'" @click="slideHandle(4)">
                            {{ sildeIndex[4] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[4]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>房产情况</div>
                                <div>
                                    {{ formatRadio(detail.fcqk, chooseList29) }}{{ detail.fcqkotherdsc ? ':' +
                                    detail.fcqkotherdsc
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>房产评价</div>
                                <div>
                                    {{ formatRadio(detail.fcpj, chooseList30) }}{{ detail.fcpjotherdsc ? ':' +
                                    detail.fcpjotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>车产情况</div>
                                <div>
                                    {{ formatRadio(detail.ccqk, chooseList31) }}{{ detail.ccqkotherdsc ? ':' +
                                    detail.ccqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>车产评价</div>
                                <div>
                                    {{ formatRadio(detail.ccpj, chooseList32) }}{{ detail.ccpjotherdsc ? ':' +
                                    detail.ccpjotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>金融资产偏好</div>
                                <div>
                                    {{ formatCheckBox(detail.jrzcph, chooseList33) }}{{ detail.jrzcphotherdsc ? ':' +
                                    detail.jrzcphotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>金融资产主观评价</div>
                                <div>
                                    {{ formatCheckBox(detail.jrzczgpj, chooseList34) }}{{ detail.jrzczgpjotherdsc ? ':'
                                    + detail.jrzczgpjotherdsc
                                    : ''}}
                                </div>
                            </div>

                            <div class="slide_content_item">
                                <div>信息来源</div>
                                <div>
                                    {{ formatCheckBox(detail.datasourcesjtzcqk, chooseList35) }}{{
                                    detail.datasourcesjtzcqkotherdsc ? ':' + detail.datasourcesjtzcqkotherdsc
                                    : ''}}
                                </div>
                            </div>

                        </div>
                        <div style="height: 10px;"></div>
                    </div>
                </div>
            </div>

            

           
        </div>

        <div v-if="flag=='2'">
            <div class="contentPart ">
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>基本信息</div>
                        <div :class="sildeIndex[0] ? 'openText':'closeText'" @click="slideHandle(0)">
                            {{ sildeIndex[0] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[0]">
                        <div class="phDetailBox">

                            <div class="slide_content_item">
                                <div>联系人姓名</div>
                                <div>
                                    {{ detail.EntpCtcManNm }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>身份证号码</div>
                                <div>
                                    {{ detail.EstbDocManIdentNum }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>联系人电话</div>
                                <div>
                                    {{ detail.EntpCtcManTelNum }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>客户需求</div>
                                <div>
                                    {{ formatCheckBox(detail.AcctMrk, chooseList1) }}{{ detail.AcctMrkDsc ? ':' +
                                    detail.AcctMrkDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>备注</div>
                                <div>
                                    {{ detail.Rak }}
                                </div>
                            </div>
                        </div>
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>商户名称</div>
                                <div>
                                    {{ detail.EntpNm }}
                                    <img class="copyImg" src="images/copy.png" @click="copyHandle(detail.EntpNm)">
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>统⼀社会信⽤代码</div>
                                <div>
                                    {{ detail.UnifyUvslCrCd }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>所属⾏业</div>
                                <div>
                                    {{ formatRadio(detail.AtchIndus, chooseList2) }}{{ detail.AtchIndusDsc ? ':' +
                                    detail.AtchIndusDsc : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>经营年限</div>
                                <div>
                                    {{ formatRadio(detail.CorpYr, chooseList3) }}
                                </div>
                            </div>
                            <div class="oneContent_item">
                                <div class="slide_content_item">
                                    <div>建档定位</div>
                                    <div>
                                        <img class="copyImg" src="images/copy.png"
                                             @click="copyHandle(detail.EntpCorpAdr)">
                                    </div>
                                </div>
                                <div class="_slide_content_item">
                                    {{ detail.EntpCorpAdr }}
                                </div>
                            </div>
                            <div class="contentChoose borderLine" v-if="imageLocal1.length>0">
                                <div class="imgText">招牌照片</div>
                                <div class="imgUpload">
                                    <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal1">
                                        <img :src="itemImg" class="uploadImg"
                                             @click="previewHandle(imageLocal1, indexImg)">
                                    </div>

                                </div>
                            </div>
                            <div class="contentChoose borderLine" v-if="imageLocal3.length > 0">
                                <div class="imgText">小微企业办公或经营场所照片</div>
                                <div class="imgUpload">
                                    <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal3">
                                        <img :src="itemImg" class="uploadImg"
                                             @click="previewHandle(imageLocal3, indexImg)">
                                    </div>

                                </div>
                            </div>
                            <div class="contentChoose borderLine" v-if="imageLocal2.length > 0">
                                <div class="imgText">营业执照</div>
                                <div class="imgUpload">
                                    <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal2">
                                        <img :src="itemImg" class="uploadImg"
                                             @click="previewHandle(imageLocal2, indexImg)">
                                    </div>

                                </div>
                            </div>
                        </div>
                        <div style="height: 10px;"></div>
                    </div>

                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>融资需求与负债</div>
                        <div :class="sildeIndex[1] ? 'openText':'closeText'" @click="slideHandle(1)">
                            {{ sildeIndex[1] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[1]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>资金用途</div>
                                <div>
                                    {{ formatCheckBox(detail.TchPps, chooseList4) }}{{ detail.TchPpsDsc ? ':' +
                                    detail.TchPpsDsc
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>希望多久可以拿到贷款</div>
                                <div>
                                    {{ formatRadio(detail.ExpcTrm, chooseList5) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>利率接受范围</div>
                                <div>
                                    {{ formatRadio(detail.IntRtAcptScop, chooseList6) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>期望额度</div>
                                <div>
                                    {{ formatRadio(detail.ExptLmt, chooseList72) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>负债情况</div>
                                <div>
                                    {{ formatRadio(detail.LglRprsLbyCcst, chooseList102) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>负债类型</div>
                                <div>
                                    {{ formatCheckBox(detail.LglRprsLbyTp, chooseList9) }}
                                </div>
                            </div>
                        </div>
                        <div style="height: 10px;"></div>
                    </div>

                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>经营情况</div>
                        <div :class="sildeIndex[2] ? 'openText':'closeText'" @click="slideHandle(2)">
                            {{ sildeIndex[2] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[2]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>企业主营业务</div>
                                <div>{{ detail.EntpMnByBsn }}</div>
                            </div>
                            <div class="slide_content_item">
                                <div>经营场所</div>
                                <div>
                                    {{ formatRadio(detail.CorpPce, chooseList112) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>近3个月月均移动支付流水</div>
                                <div>
                                    {{ formatRadio(detail.PrxThreeMoMoyAvMovPytSeq, chooseList122) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>家庭月均支出（元）</div>
                                <div>
                                    {{ detail.FamMoyAvExpn}}
                                </div>
                            </div>

                        </div>
                        <div style="height: 10px;"></div>
                    </div>
                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>家庭情况</div>
                        <div :class="sildeIndex[3] ? 'openText':'closeText'" @click="slideHandle(3)">
                            {{ sildeIndex[3] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[3]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>法人年龄范围</div>
                                <div>
                                    {{ formatRadio(detail.frnlfw, chooseList20) }}{{ detail.frnlfwotherdsc ? ':' +
                                    detail.frnlfwotherdsc
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法人婚姻子女情况</div>
                                <div>
                                    {{ formatRadio(detail.frhyznqk, chooseList21) }}{{ detail.frhyznqkotherdsc ? ':' +
                                    detail.frhyznqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>法人子女学龄</div>
                                <div>
                                    {{ formatRadio(detail.frznxl, chooseList22) }}{{ detail.frznxlotherdsc ? ':' +
                                    detail.frznxlotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>赡养老人情况</div>
                                <div>
                                    {{ formatRadio(detail.sylrqk, chooseList23) }}{{ detail.sylrqkotherdsc ? ':' +
                                    detail.sylrqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>家庭月均支出情况</div>
                                <div>
                                    {{ formatRadio(detail.jtyjzc, chooseList26) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>家庭情况主观评价</div>
                                <div>
                                    {{ formatCheckBox(detail.jtqkzgpj, chooseList27) }}{{ detail.jtqkzgpjotherdsc ? ':'
                                    +
                                    detail.jtqkzgpjotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>信息来源</div>
                                <div>
                                    {{ formatCheckBox(detail.datasourcesjtqk, chooseList28) }}{{
                                    detail.datasourcesjtqkotherdsc ? ':' + detail.datasourcesjtqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                        </div>
                        <div style="height: 10px;"></div>
                    </div>
                </div>
                <div class="phDetailcontentPart">
                    <div class="phDetailContentLine">
                        <div>资产情况</div>
                        <div :class="sildeIndex[4] ? 'openText':'closeText'" @click="slideHandle(4)">
                            {{ sildeIndex[4] ? '收起' : '展开' }}
                        </div>
                    </div>
                    <div v-if="sildeIndex[4]">
                        <div class="phDetailBox">
                            <div class="slide_content_item">
                                <div>房产情况</div>
                                <div>
                                    {{ formatRadio(detail.fcqk, chooseList29) }}{{ detail.fcqkotherdsc ? ':' +
                                    detail.fcqkotherdsc
                                    : '' }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>房产评价</div>
                                <div>
                                    {{ formatRadio(detail.fcpj, chooseList30) }}{{ detail.fcpjotherdsc ? ':' +
                                    detail.fcpjotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>车产情况</div>
                                <div>
                                    {{ formatRadio(detail.ccqk, chooseList31) }}{{ detail.ccqkotherdsc ? ':' +
                                    detail.ccqkotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>车产评价</div>
                                <div>
                                    {{ formatRadio(detail.ccpj, chooseList32) }}{{ detail.ccpjotherdsc ? ':' +
                                    detail.ccpjotherdsc
                                    : ''}}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>金融资产偏好</div>
                                <div>
                                    {{ formatCheckBox(detail.jrzcph, chooseList33) }}
                                </div>
                            </div>
                            <div class="slide_content_item">
                                <div>金融资产主观评价</div>
                                <div>
                                    {{ formatCheckBox(detail.jrzczgpj, chooseList34) }}{{ detail.jrzczgpjotherdsc ? ':'
                                    +
                                    detail.jrzczgpjotherdsc
                                    : ''}}
                                </div>
                            </div>

                            <div class="slide_content_item">
                                <div>信息来源</div>
                                <div>
                                    {{ formatCheckBox(detail.datasourcesjtzcqk, chooseList35) }}{{
                                    detail.datasourcesjtzcqkotherdsc ? ':' + detail.datasourcesjtzcqkotherdsc
                                    : ''}}
                                </div>
                            </div>

                        </div>
                        <div style="height: 10px;"></div>
                    </div>
                </div>
            </div>


        </div>

        <div class="contentPart ">
            <div class="contentLine phDetailcontentPart phDetailcontentPartNew">
                <div>客户需求</div>
                <div>
                    {{ formatCheckBox(detail.AcctMrk, chooseList1) }}{{ detail.AcctMrkDsc ? ':' + detail.AcctMrkDsc : ''
                    }}
                </div>
            </div>
            <div class="contentChoose pjTextArea phDetailcontentPartNew">
                <div class="chooseTitle">备注</div>
                <div class="textAreaPart">
                    <van-field type="textarea" @blur="localStrongFun()" v-model="detail.Rak" rows="4" autosize
                               readonly></van-field>
                </div>
            </div>
        </div>

        <div class="contentPart " v-if="detail.status=='1'">
            <div class="contentLine phDetailcontentPart phDetailcontentPartNew" >
                <div>有效时间</div>
                <div>{{ detail.updateYxDate }}</div>

            </div>

        </div>

    </div>

    <div v-if="tab=='2'">
        <div class="detailBusiness" v-if="flag=='1'">
            <div class="businessLine">
                <div class="businessLineleft">对公开户</div>
                <div :class="'businessLineright'+businessInfo.openacct_ind">{{businessInfo.openacct_ind?businessOpt1[businessInfo.openacct_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人开卡</div>
                <div :class="'businessLineright'+businessInfo.opencard_ind">{{businessInfo.opencard_ind?businessOpt2[businessInfo.opencard_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">收单业务</div>
                <div :class="'businessLineright'+businessInfo.open_recv_bill_biz_ind">{{businessInfo.open_recv_bill_biz_ind?businessOpt3[businessInfo.open_recv_bill_biz_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人按揭贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_indv_mtg_loan_ind">{{businessInfo.proc_indv_mtg_loan_ind?businessOpt4[businessInfo.proc_indv_mtg_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人消费贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_indv_consm_loan_ind">{{businessInfo.proc_indv_consm_loan_ind?businessOpt4[businessInfo.proc_indv_consm_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人助业贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_indv_assist_loan_ind">{{businessInfo.proc_indv_assist_loan_ind?businessOpt4[businessInfo.proc_indv_assist_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人存款（非活期）</div>
                <div :class="'businessLineright'+businessInfo.proc_dpst_biz_ind">{{businessInfo.proc_dpst_biz_ind?businessOpt5[businessInfo.proc_dpst_biz_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人理财</div>
                <div :class="'businessLineright'+businessInfo.proc_chrem_biz_ind">{{businessInfo.proc_chrem_biz_ind?businessOpt5[businessInfo.proc_chrem_biz_ind]:"--"}}</div>
            </div>
            <div class="businessLine" >
                <div class="businessLineleft">普惠贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_corp_loan_ind">{{businessInfo.proc_corp_loan_ind?businessOpt4[businessInfo.proc_corp_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">代发工资</div>
                <div :class="'businessLineright'+businessInfo.contr_payroll_biz_ind">{{businessInfo.contr_payroll_biz_ind?businessOpt6[businessInfo.contr_payroll_biz_ind]:"--"}}</div>
            </div>
        </div>

        <div class="detailBusiness" v-if="flag=='2'">
            <div class="businessLine">
                <div class="businessLineleft">开户</div>
                <div :class="'businessLineright'+businessInfo.openacct_ind">{{businessInfo.openacct_ind?businessOpt1[businessInfo.openacct_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人开卡</div>
                <div :class="'businessLineright'+businessInfo.opencard_ind">{{businessInfo.opencard_ind?businessOpt2[businessInfo.opencard_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">收单业务</div>
                <div :class="'businessLineright'+businessInfo.open_recv_bill_biz_ind">{{businessInfo.open_recv_bill_biz_ind?businessOpt3[businessInfo.open_recv_bill_biz_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人按揭贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_indv_mtg_loan_ind">{{businessInfo.proc_indv_mtg_loan_ind?businessOpt4[businessInfo.proc_indv_mtg_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人消费贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_indv_consm_loan_ind">{{businessInfo.proc_indv_consm_loan_ind?businessOpt4[businessInfo.proc_indv_consm_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人助业贷款</div>
                <div :class="'businessLineright'+businessInfo.proc_indv_assist_loan_ind">{{businessInfo.proc_indv_assist_loan_ind?businessOpt4[businessInfo.proc_indv_assist_loan_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">存款（非活期）</div>
                <div :class="'businessLineright'+businessInfo.proc_dpst_biz_ind">{{businessInfo.proc_dpst_biz_ind?businessOpt5[businessInfo.proc_dpst_biz_ind]:"--"}}</div>
            </div>
            <div class="businessLine">
                <div class="businessLineleft">个人理财</div>
                <div :class="'businessLineright'+businessInfo.proc_chrem_biz_ind">{{businessInfo.proc_chrem_biz_ind?businessOpt5[businessInfo.proc_chrem_biz_ind]:"--"}}</div>
            </div>
            
        </div>

    </div>

    <div v-if="tab=='3'">
        <div class="addRecord" @click="addRecordPopup">
            <img src="images/add.png">新增跟进记录
        </div>
        <van-popup v-model="showcancelPopup" closeable round position="bottom" :style="{height:'40%'}">
            <div class="contentPart">
                <div class="contentChoose">
                    <div class="chooseTitle popouTitle">新增跟进记录</div>
                    <div class="textAreaPart">
                        <van-field type="textarea" v-model="addRecodeText" rows="4" autosize placeholder="请输入"
                                maxlength="200"></van-field>
                    </div>
                </div>
                <div style="position: relative;">
                    <div class="record">
                        <div @click="showRecorddiv()">
                            <img src="images/voice.png" class="voice">
                        </div>
                    </div>
                    <div class="recodeblock" @click="startRecord()">
                        <img src="images/luyin.gif">
                        <div start="no" class="luyinbtn">开始说话</div>
                    </div>
                </div>
            </div>
            <div class="applyButton" @click="addRecordBtn" style="width: 88%;margin: 10px auto;">
                <div>提交</div>
            </div>
        </van-popup>

        <div class="recordList">
            <div class="stepPart">
                <div class="stepOne" v-for="item in recodeList">
                    <div class="stepText">
                        <div>{{item.content}}</div>
                        <div>{{item.createtime}}</div>
                    </div>
                    <div class="stepCircle"></div>
                    <div class="stepLine"></div>
                </div>

            </div>

        </div>
    </div>

    <div style="height: 100px;"></div>
    <div class="footApply" v-if="ifEdit=='1'">
    <div @click="goEdit">
        <img src="images/applyEdit.png" class="applyEdit">
        <span>修改</span>
    </div>
    </div>
</div>
</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="./../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/dataJson.js"></script>
<script type="text/javascript" src="js/idCardCheck.js"></script>
<script type="text/javascript" src="js/phdetail.js"></script>

<!-- <script src="../common/js/vConsole.min.js"></script> -->
<script type="text/javascript">
    // var vConsole = new VConsole();

    function getUserFinish() {
        initJSSDK(['hideAllNonBaseMenuItem', 'chooseImage', 'uploadImage', "stopRecord", "startRecord", "translateVoice", 'invoke', 'closeWindow']);

        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
            WeixinJSBridge.on('menu:setfont', function () {
                WeixinJSBridge.invoke('setFontSizeCallback', {'fontSize': '0'});
            });

        });
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }


</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>