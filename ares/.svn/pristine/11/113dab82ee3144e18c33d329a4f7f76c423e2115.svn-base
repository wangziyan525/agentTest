
body{
    padding: 0;
    margin: 0;
    list-style-type: none;
    background: #f5f5f5;
    width:100%;
    height: 100%;
    font-size: 15px;
    color: #333333;
    overflow: auto;
}
/*增大弹出框间距开始-----邹龙*/
.weui-dialog{
    border-radius: 12px !important;
}
.weui-dialog .weui-dialog__hd{
    padding: 2em 1.5em 1.5em;
}
.lineBottom{
    position: relative;
}
.lineBottom:after{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
}
/*增大弹出框间距结束-----邹龙*/
.scroll{
    width: 100%;
    height: 100%;
    position: absolute;
    top:0;
    bottom: 0;
    left: 0;
    right: 0;
    overflow: auto;
}
#page{
    overflow: auto;
}
.page{
    display: none;
    padding-bottom: 20px;
}

.banner{
    width: 100%;
}
.banner img{
    width: 100%;
}

.menu-box{
    width: 100%;
    height: 40px;
    line-height: 40px;
    vertical-align: middle;
    display: flex;
    background: #ffffff;
    text-align: center;
    margin-top: -5px;
}
.menu-box .menu{
    width: 100%;
    font-size: 15px;
    position: relative;
}
.menu-box .selected:after{
    position: absolute;
    content: ' ';
    left: 50%;
    margin-left: -10.5px;
    margin-top: 37px;
    width: 21px;
    height: 3px;
    background: linear-gradient(90deg, #2467FF 0%, #0088FF 100%);
    border-radius: 2px;
}

.report-num-box{
    background: #ffffff;
    padding: 10px 15px 15px;
    box-sizing: border-box;
    margin-top: 10px;
}
.report-num-box .item{
    width: 100%;
    display: flex;
    padding-top: 5px;
}
.report-num-box .item .left{
    font-size: 14px;
    color: #999999;
    width: 50%;
    flex-shrink: 0;
    text-align: left;
}
.report-num-box .item .right{
    font-size: 14px;
    width: 50%;
    text-align: right;
}

.report-process-box{
    margin-top: 10px;
    width: 100%;
    padding: 15px;
    border-bottom: 0.5px solid #E3E7FD;
    background: #ffffff;
    box-sizing: border-box;
}
.report-process-box .title{
    font-size: 15px;
    margin-bottom: 10px;
    width: 100%;
    display: flex;
}
.report-process-box .tit{
    width: 100px;
}
.report-process-box .countdown{
    flex: 1;
    font-size: 14px;
    color: #999;
    display: flex;
    justify-content: flex-end;
}
.report-process-box .countdown span{
    display: block;
}
.report-process-box .countdown span:nth-child(2){
    /* padding: 0 8px;
    line-height: 20px;
    color: rgba(101, 195, 12, 1);
    background-color:rgba(101, 195, 12, .1);
    margin-left: 10px;
    font-size: 12px; */
    margin-left: 10px;
    color: #2467FF;
    font-weight: bold;
}
.report-process-box .process-box{
    width: 100%;
    display: flex;
}
.report-process-box .process-box .process-back{
    width: 100%;
    height: 16px;
    background: #FFFFFF;
    border-radius: 14px;
    /*border: 1px solid #E3E7FD;*/
    margin-top: 5px;
}
.report-process-box .process-box .process{
    height: 16px;
    background: linear-gradient(90deg, #8151FF 0%, #2467FF 100%);
    display: block;
    border-radius: 14px;
}
.report-process-box .process-box .process-num{
    color: #666666;
    text-align: right;
    width: 80px;
    font-size: 18px;
    font-weight: 500;
    padding-top: 1px;
}

/*总进度-报表*/
.report-canvas-box{
    width: 100%;
    display: flex;
    background: #ffffff;
    padding: 15px 12px 0px 12px;
    box-sizing: border-box;
}
.report-canvas-box .report{
    width: 100%;
    text-align: center;
}
.report-canvas-box .report .label{
    text-align: center;
    font-size: 12px;
}
.report-canvas-label{
    width: 100%;
    display: flex;
    background: #ffffff;
    padding: 0px 0px 2px 0px;
    text-align: center;
}
.report-canvas-label .label{
    width: 100%;
    padding: 0 5px;
    box-sizing: border-box;
}

.list-box{
    width: 100%;
    padding: 15px;
    box-sizing: border-box;
    background: #ffffff;
    margin-top: 15px;
}
.list-box .row-title{
    width: 100%;
    padding-bottom: 10px;
    border-bottom: 0.5px solid #E3E7FD;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding-right: 70px;
    box-sizing: border-box;
}
.list-box .row-title .button{
    color: #2467FF;
    text-align: right;
    position: absolute;
    width: 70px;
    height: 24px;
    right: 15px;
    margin-top: -24px;
    line-height: 24px;
    vertical-align: middle;
}
.list-box .row{
    width: 100%;
    padding-top: 10px;
    display: flex;
}
.list-box .row .left{
    color: #999999;
    text-align: left;
    width: 30%;
}
.list-box .row .right{
    text-align: right;
    width: 80%;
}


.yuyun-box {
    width: 100%;
    height: 44px;
    line-height: 44px;
    border-radius: 6px;
    color: #4273d8;
    border: 1px solid #4273d8;
    text-align: center;
    margin: 12px auto;
    font-size: 16px;
}

.yuyun-box img {
    height: 20px;
    vertical-align: middle;
    margin-right: 6px;
}
.input-box{
    width: 100%;
}
.input-box textarea{
    height: 100px;
    width: 100%;
    background: #f4f5f9;
    border-radius: 5px;
    -webkit-appearance: none;
    outline: 0;
    padding: 12px 10px 5px 10px;
    border: 0px;
    box-sizing: border-box;
    font-size: 15px;
}
.input-box .input-num{
    width: 80px;
    text-align: right;
    position: absolute;
    right: 20px;
    margin-top: -28px;
    font-size: 12px;
}
.uploadImg-box{
    width: 100%;
    display: flex;
    flex-wrap: wrap;
}
.uploadImg-box .upload{
    width: 60px;
    height: 60px;
    margin-right: 15px;
    margin-bottom: 15px;
    display: inline-flex;
}
.uploadImg-box .upload img{
    width: 100%;
    height: 100%;
}
.uploadImg-box .upload .delete{
    width: 15px;
    height: 15px;
    margin-top: -10px;
    margin-left: 51px;
    position: absolute;
}
.uploadImg-box .upload .delete img{
    width: 15px;
    height: 15px;
}

.button-box{
    width: 100%;
    display: flex;
    justify-content: space-between;
    margin-top: 35px;
    padding: 0px 15px;
    box-sizing: border-box;
}
.button-box .button{
    width: 44%;
    height: 45px;
    border-radius: 22.5px;
    border: 1px solid #2467FF;
    background: #2467FF;
    color: #ffffff;
    line-height: 45px;
    vertical-align: middle;
    font-size: 15px;
    text-align: center;
}
.button-box .back{
    border:1px solid #2467FF;
    background: #ffffff;
    color: #2467FF;
}

/****************语音输入开始****************/
.luyinbtn {
    width: 100px;
    background-color: #fff;
    color: #333;
    height: 36px;
    line-height: 36px;
    border-radius: 8px;
    margin: 6px auto 12px;
    font-size: 15px;
    font-weight: 500;
}

.recodeblock {
    position: fixed;
    width: 140px;
    max-width: 300px;
    top: 45%;
    left: 50%;
    -webkit-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, .6);
    text-align: center;
    border-radius: 3px;
    overflow: hidden;
    -webkit-transition-duration: .2s;
    transition-duration: .2s;
    -webkit-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%);
    -webkit-transform-origin: 0 0;
    transform-origin: 0 0;
    margin: 0;
    border-radius: 12px;
    visibility: hidden;
    opacity: 0;
}

.recodeblock.showluyin {
    opacity: 1;
    visibility: visible;
}

.recodeblock img {
    width: 68%;
    margin: 15px auto 0;
}
.btnDiv{
    display: flex;
}
.luyinline {
    width: 40%;
    height: 34px;
    line-height: 34px;
    border-radius: 50px;
    color: #4273d8;
    border: 1px solid #4273d8;
    text-align: center;
    margin: 10px auto;
    font-size: 15px;
}

.luyinline img {
    height: 20px;
    vertical-align: middle;
    margin-right: 6px;
}

.yuyin-input{
    height: auto;
    padding: 10px 3% 5px 3%;
    border-bottom: 0px;
    flex-direction: column
}
select:invalid{
    color: #999999;
}
option{
    color: #121212;
}
/****************语音输入结束****************/
.nodata{
    width: 100%;
    height: 60px;
    line-height: 60px;
    vertical-align: middle;
    text-align: center;
}
.van-notice-bar{
    width: 100%;
    position: absolute;
    box-sizing: border-box;
    background: rgba(0,0,0,0.3);
    height: 30px;
    font-size: 12px;
}

