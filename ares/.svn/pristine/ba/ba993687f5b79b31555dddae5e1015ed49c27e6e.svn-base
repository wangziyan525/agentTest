
.main_container {
    padding: 0 12px;
}

.main_item {
    background-color: #fff;
    border-radius: 4px;
    margin-top: 10px;
}

.main_item:first-child {
    margin-top: 0;
}

.header_container {
    height: 45px;
    display: flex;
    padding: 0 12px;
    align-items: center;
    background-color: #fff;
}

