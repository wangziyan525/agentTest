[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
/* ------------------------------- 详情 ----------------------------------------*/
.main{
    flex: 1;
    overflow-y: auto;
    margin: 10px 0;
    background: #fff;
    padding: 0 10px;
    box-sizing: border-box;
}
.item{
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    position: relative;
    display: flex;
    cursor: pointer;
}
.item::before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.item span{
    display: block;
}
.item span:nth-child(1){
    width: 80px;
    font-size: 15px;
    line-height: 20px;
    color: #666;
}
.item span:nth-child(2){
    flex: 1;
    text-align: right;
    font-size: 15px;
    line-height: 20px;
    color: #333;
}
.item input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    background-color: #fff;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 15px;
    color: #333;
    line-height: 20px;
    border-radius: 6px;
    text-align: right;
}
.item i{
    display: flex;
    align-items: center;
    margin-left: 10px;
}
.item i img{
    display: block;
    width: 8px;
}
.item1{
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    position: relative;
    cursor: pointer;
}
.upItem1{
    position: static;
}
.upItem1::before{
    display: none;
}
.item1::before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.item1 .total{
    font-size: 15px;
    line-height: 20px;
    color: #666;
    display: flex;
    align-items: center;
}
.item1 .total img{
    display: block;
    width: 16px;
    margin-left: 5px;
    transition: transform 0.3s ease;
}
.item1 .total .rotate{
    transform: rotate(180deg)
}
.item1 .add{
   display: flex;
   align-items: center;
   padding: 8px 10px;
   box-sizing: border-box;
   background: #F0F7FF;
    border-radius: 4px;
}
.item1 .add img{
    display: block;
    width: 12px;
    height: 12px;
    margin-right: 5px;
}
.item1 .add span{
    font-size: 15px;
    line-height: 16px;
    color: #267EF0;
}
.peopleList{
    width: 100%;
    background: #F5F6F7;
    border-radius: 6px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
}
.expanded{
    max-height: 3000px;
}

.peopleList .peopleLisItem{
    width: 100%;
    padding: 15px;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    position: relative;
}
.peopleList .peopleLisItem::before{
    content: " ";
    position: absolute;
    left: 15px;
    bottom:0;
    width: calc(100% - 30px);
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.peopleList .peopleLisItem:last-child::before{
    display: none;
}
.peopleList .peopleLisItem .name{
    font-size: 15px;
    line-height: 20px;
    color: #000;
}
.peopleList .peopleLisItem .delete{
    display: flex;
    align-items: center;
} 
.peopleList .peopleLisItem .delete img{
    display: block;
    width: 18px;
    height: 18px;
}
.noList{
    width: 94%;
    padding: 30px 0;
    box-sizing: border-box;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #000;
    line-height:32px;
}
.noList span{
    color: #333;
    font-size:15px;
}
/* ------------------------------------- 底部按钮 -----------------------------*/
.footBtn{
    width: 100%;
    background-color: #fff;
    padding: 10px 15px 30px;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    cursor: pointer;
}
.bigBtn{
    width: 100%;
    padding: 13px 0;
    box-sizing: border-box;
    background: #267EF0;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    font-size: 15px;
    line-height: 20px;
    color: #fff;
}
.smallBtn{
    width: calc((100% - 12px)/2);;
    padding: 13px 0;
    box-sizing: border-box;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    font-size: 15px;
    line-height: 18px;
    border: 1px solid #267EF0;
}
.footBtn .smallBtn:nth-child(1){
    background: transparent;
    color: #267EF0;
}
.footBtn .smallBtn:nth-child(2){
    background: #267EF0;
    color: #fff;
}

/* 机构列表 */
.stepList{
    width: 50%;
    position: absolute;
    top: 52px;
    right: 0;
    background-color: #e1edf9;
    border-radius: 4px;
    z-index: 99;
    text-align: right;
    max-height: 50vh;
    overflow-y: auto;
}
.stepList .stepLis{
    width: 100%;
    max-height: 200px;
    overflow-y: auto;
    padding: 10px 15px;
    box-sizing: border-box;
    font-size: 14px;
    line-height: 20px;
    color: #333;
    position: relative;
}
.stepList .stepLis::before{
    content: " ";
    position: absolute;
    left: 15px;
    bottom:0;
    width: calc(100% - 30px);
    height: 1px;
    border-bottom:1px solid #b6cade;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.stepList .stepLis:last-child::before{
    display: none;
}