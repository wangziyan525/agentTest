body{
    background: #F5F6F7;
    width:100%;
    min-height:100vh;
}
*{
    margin:0;
    padding:0;
    -webkit-overflow-scrolling: touch !important;
    -webkit-tap-highlight-color: rgba(0,0,0,0) !important;
    -webkit-tap-highlight-color: transparent !important;
    font-family: 'Microsoft YaHei', Tahoma, Arial, sans-serif;
}
input{
    border: none;
    outline: none;
    appearance: none;
}
textarea{
    border: none;
    outline: none;
    border-style: none;
    text-shadow: none;
    -webkit-appearance: none;
    -webkit-user-select: text;
    outline-color: transparent;
    resize: none;
}
[v-cloak]{
    display: none;
}
.weui-dialog{
    border-radius: 8px !important;
    font-size: 17px;
}
.weui-dialog .weui-dialog__hd{
    padding: 20px;
}
.weui-dialog__ft,.weui-dialog__btn{
    font-size: 17px;
    color: #267EF0;
}
.van-picker-column__item--selected{
    color: #4675C9;
}
.van-picker__cancel, .van-picker__confirm{
    font-size: 16px;
}
.lineBottom{
    position: relative;
}
.lineBottom:after{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #e5e5e5;
    color: #e5e5e5;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index:22;
}
.displayFlex{
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.displayAround{
    display: flex;
    justify-content:space-around;
    align-items: center;
}
.displayStart{
    display: flex;
    justify-content:flex-start;
    align-items: center;
}
.displayEnd{
    display: flex;
    justify-content:flex-end;
    align-items: center;
}
.displayTop{
    display: flex;
    justify-content: space-between;
    align-items:flex-start; 
}
.color999{
    color: #999999;
}
.color666{
    color: #666666;
}
.noData{
    padding:20px;
    box-sizing: border-box;
    text-align: center;
    font-size:15px;
    line-height:40px;
    color: #9b9b9b;
}
.noData img{
    width:50%;
}
/* 审批管理列表 */
.index_t{
    background: #fff;
    padding: 10px 15px;
    box-sizing: border-box;
    font-size: 15px;
    color: #3B3B3B;
    position: fixed;
    top:0;
    left:0;
    width:100%;
}
.down_img{
    width:14px;
    height:14px;
    margin-left:6px;
}
.list_t{
    font-size: 12px;
    color: #999999;
    padding: 11px 0;
    box-sizing: border-box;
}
.list_box{
    padding: 0 12px;
    padding-top:44px;
    box-sizing: border-box;
}
.list_m{
    width:100%;
    padding: 10px 12px;
    box-sizing: border-box;
    font-size: 14px;
    background: #FFFFFF;
    border-radius: 4px;
}
.list_m_r>div{
    display: flex;
    justify-content: flex-start;
    padding-bottom: 4px;
    color: #3B3B3B;
}
.list_m_r>div:last-child{
    padding-bottom: 0;
}
.list_m_r>div>span:first-child{
    color: #999;
    min-width:85px;
}
.status_tip{
    font-size:12px;
    border-radius:2px;
    padding:1px 4px;
    line-height:12px;
}
.status_tip1{
    color: #0465FF;
    background: rgba(4,101,255,.15);
}
.status_tip2{
    color: #FF9E48;
    background:rgba(255,158,72,.15);
}
.status_tip3{
    color: #FF4D4F;
    background:rgba(255,77,79,.15);
}
.more_box{
    padding: 30px 10px;
    box-sizing: border-box;
}
.more_img{
    width:14px;
    height:14px;
}
.index_btn,.edit_btn,.list_btn{
    background: #FFFFFF;
    border-radius: 0px 0px 6px 6px;
    position: fixed;
    bottom:0;
    left:0;
    width:100%;
    padding: 7px 12px 33px 12px;
    box-sizing: border-box;
    font-size: 15px;
}
.index_add{
    width:100%;
    background: #0465FF;
    border-radius: 6px;
    font-size: 15px;
    color: #FFFFFF;
    text-align: center;
    padding: 12px 0;
    box-sizing: border-box;
}
.position_box{
    font-size: 16px;
    color: #3B3B3B;
}
.position_item{
    padding: 15px 0;
    text-align: center;
}
.position_cancle{
    padding: 17px 0 41px 0;
    box-sizing: border-box;
    text-align: center;
}

/* 白名单客户编辑 */
.edit_textarea::-webkit-scrollbar{
    display: none;
}
.edit_t{
    background: #fff;
    padding: 0 12px;
    padding-bottom:10px;
    box-sizing: border-box;
    font-size:13px;
    color: #999999;
}
.edit_text{
    background: #F5F6F7;
    border-radius: 4px;
    padding: 10px 12px;
    box-sizing: border-box;
    color: #666666;
}
.edit_m{
    font-size:14px;
    background: #fff;
    padding: 0 12px;
    box-sizing: border-box;
    color: #3B3B3B;
}
.edit_m input{
    width:calc(100% - 118px);
}
.edit_m textarea{
    width:calc(100% - 118px);
}
.edit_item{
    padding: 8px 0;
    box-sizing: border-box;
}
.edit_m_l{
    width:118px;
}
.edit_textarea{
    height:auto;
}
.edit_position div{
    border: 1px solid rgba(245,246,247,1);
    border-radius: 4px;
    padding: 6px 23px;
    box-sizing: border-box;
    font-size:13px;
    position: relative;
}
.edit_position_active{
    color: #0465FF;
    border: 1px solid rgba(4,101,255,1) !important;
}
.edit_position{
    padding: 10px 0;
    box-sizing: border-box;
}
.select_p{
    width:15px;
    height:7px;
    position: absolute;
    top:0;
    right:0;
}
.edit_btn span{
    width:49%;
    padding: 12px 0;
    box-sizing: border-box;
    text-align: center;
    line-height:20px;
    background: #F5F6F7;
    border-radius: 6px;
    color: #3B3B3B;
}
.edit_btn span:last-child{
    background: #0465FF;
    color: #fff;
}

/* 待审批  已审批列表 */
.tab_con{
    position: fixed;
    top:0;
    left:0;
    width:100%;
    background: #fff;
    font-size:15px;
    display: flex;
    justify-content:space-around;
}
.tab_con span{
    padding:10px 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}
.active{
    color: #3b3b3b;
    position: relative;
 }
 .active:after{
    color: #4675C9;
    border-radius:1px;
    content: " ";
    position: absolute;
    left:50%;
    bottom:3px;
    width:20px;
    border-bottom:2px solid #4675C9;
    transform: translateX(-50%);
 }
 .select_img{
     width:16px;
     height:16px;
 }
 .approval_list{
     width:calc(100% - 26px);
 }
 .approval_btn{
     width:calc(100% - 64px);
 }
 .approval_btn span{
    width:48%;
    padding: 12px 0;
    box-sizing: border-box;
    text-align: center;
    line-height:20px;
    background: rgba(255,4,4,0.08);
    border-radius: 6px;
    color: #FF4D4F;
 }
 .approval_btn span:last-child{
    background: #0465FF;
    color: #fff;
}
.disagree_t{
    font-size: 15px;
    color: #3B3B3B;
    font-weight: bold;
    text-align: center;
    padding: 20px 0;
    box-sizing: border-box;
}
.disagree_m{
    padding: 0 12px;
    box-sizing: border-box;
}
.disagree_m_t{
    font-size: 15px;
    color: #3B3B3B;
    line-height: 21px;
    font-weight:bold;
    padding-bottom: 10px;
    box-sizing: border-box;
}
.textClass{
    background: #F5F6F7;
    border-radius: 4px;
    width: 100%;
    padding:10px;
    padding-bottom: 30px;
    box-sizing: border-box;
    line-height:18px;
    font-size: 14px;
    height:124px;
}
.textarea_box{
    position: relative;
}
.text_num{
    color: #999999;
    position: absolute;
    right: 24px;
    bottom:10px;
}
.disagree_tips{
    font-size: 13px;
    color: #A8A8A8;
    padding:10px 0px;
    box-sizing: border-box;
}
.disagree_btn{
    padding: 8px 12px 33px 12px;
    box-sizing: border-box;
}
.disagree_btn>div{
    background: #0465FF;
    border-radius: 6px;
    color: #fff;
    text-align:center;
    padding: 12px 0;
    box-sizing: border-box;
}
.weui-toast{
    z-index: 3000;
    font-size: 14px;
    color: #FFFFFF;
}
/* 审批进度流程 */
.detail_t{
    width:100%;
    padding: 10px 12px;
    box-sizing: border-box;
    font-size: 14px;
    background: #FFFFFF;
}
.detail_t>div{
    display: flex;
    justify-content: flex-start;
    padding-bottom: 4px;
    color: #3B3B3B;
}
.detail_t>div:last-child{
    padding-bottom: 0;
}
.detail_t>div>span:first-child{
    color: #999;
    min-width:85px;
}
.detail_m{
    padding: 10px 12px;
    box-sizing: border-box;
}
.detail_m>div{
    background: #fff;
    border-radius: 4px;
}
.detail_m_t{
    font-size: 15px;
    color: #3B3B3B;
    font-weight:bold;
    padding: 12px;
    box-sizing: border-box;
}
.detail_approval_list{
    padding: 10px 0;
    background: white;
}
.detail_approval_m{
    display: flex;
    justify-content: space-between;
    padding:0px 12px 0px 12px;
}

.detail_approval_m:last-child{
    margin-bottom: 0;
}
.left{
    width:7px;
    margin-right: 12px;
    display: flex;
    justify-content: space-around;
    position: relative;
}
.left i{
    width:7px;
    height:7px;
    border-radius: 50%;
    background: #0465FF;
    line-height: 50px;
    margin-top:20px;
}
.left1 i{
    background: #fff;
    border: 0.5px solid rgba(4,101,255,1);
    box-sizing: border-box;
}
/* .left::before{
    content: '';
    width: 1px;
    height:52px;
    background: #0465FF;
    position: absolute;
    top: -33px;
} */
.left1::before{
    background: #DAD7D7;
}
.left::after{
    content: '';
    width: 1px;
    height: -webkit-calc(100% - 5px);
    background: #0465FF;
    position: absolute;
    bottom: -22px;
}
.left1::after{
    background: #DAD7D7;
}
.detail_approval_m:first-child .left::before{
    display: none;
}
.detail_approval_m:last-child .left::after{
    display: none;
}
.detail_approval_r{
    border: 1px solid rgba(245,246,247,1);
    border-radius: 4px;
    padding: 12px;
    box-sizing: border-box;
    width:100%;
    font-size: 14px;
    margin-bottom:30px;
}
.detail_approval_name{
    color: #3B3B3B;
    font-weight: bold;
}
.detail_approval_position{
    color: #0465FF;
    background-color: rgba(4,101,255,.15);
    font-size:12px;
    border-radius:2px;
    padding: 1px 4px;
}
.detail_approval_status{
    min-width:50px;
    text-align: right;
    font-size: 14px;
    color: #0465FF;
}
.detail_approval_reason{
    font-size: 14px;
    color: #A8A8A8;
    padding-top:4px;
}

/* 完成页面 */
.finished_t{
    text-align:center;
    padding:50px 0 120px 0;
    box-sizing: border-box;
}
.finished_t_text{
    font-size: 18px;
    color: #3B3B3B;
    font-weight:bold;
    line-height:25px;
    padding-top: 20px;
}
.finished_img{
    width:133px;
    height:82px;
}
.finished_m>div{
    margin:0 auto;
    width: 65%;
    padding: 12px 0;
    line-height:14px;
    text-align: center;
    border-radius: 22px;
    background: #0465FF;
    color: #FFFFFF;
    font-size:14px;
}
/* .finished_m>div:last-child{
    margin-top:10px;
    background: #F5F6F7;
    color: #3B3B3B;
} */