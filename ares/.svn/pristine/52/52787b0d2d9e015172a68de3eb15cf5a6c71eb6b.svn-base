[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
/* --------------------------------- tab切换 ---------------------- */
.tabs{
    width: 100%;
    height: 50px;
}
.van-tabs--line .van-tabs__wrap{
    height: 50px !important;
}
.van-tab{
    font-size: 15px !important;
    color: #000 !important;
}
.van-tab--active{
    color: #4675C9 !important;
}
.van-tabs__line{
    width: 33% !important;
    height: 2px !important;
    background-color: #4675C9 !important;
}
/* --------------------------------- 搜索 ---------------------- */
.search{
    width: 100%;
    padding: 10px 12px;
    box-sizing: border-box;
}
.search .searchMain{
    width: 100%;
    padding: 10px 12px;
    box-sizing: border-box;
    background: #fff;
    border-radius: 50px;
    display: flex;
    align-items: center;
}
.search .searchMain img{
    width: 15px;
    margin-right: 10px;
}
.search .searchMain input{
    flex: 1;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 15px;
    color: #333;
    line-height: 15px;
    background-color: #fff;
}
/* --------------------------------- 搜索 ---------------------- */
.search{
    width: 100%;
    padding: 10px 12px;
    box-sizing: border-box;
}
.search .searchMain{
    width: 100%;
    padding: 10px 12px;
    box-sizing: border-box;
    background: #fff;
    border-radius: 50px;
    display: flex;
    align-items: center;
}
.search .searchMain img{
    width: 15px;
    margin-right: 10px;
}
.search .searchMain input{
    flex: 1;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 15px;
    color: #333;
    line-height: 15px;
    background-color: #fff;
}
/* --------------------------------- 筛选------------------------ */
.filter{
    width: 100%;
    padding: 10px 20px;
    background: #fff;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    margin-top: 10px;
}
.filter .filterTime{
    width: 50%;
    display: flex;
    align-items: center;
}
.filter .filterStatus{
    width: 40%;
    display: flex;
    align-items: center;
    justify-content: flex-end;
}
.filter .filterTime img,
.filter .filterStatus img{
    display: block;
    width: 12px;
    margin-left: 5px;
}
.filter .filterTime .filterText{
    font-size: 14px;
    line-height: 20px;
    color: #333;
}
.filter .filterTime .filterText span{
    font-size: 14px;
    line-height: 20px;
    color: #666;
}
.filter .filterStatus .filterText{
    font-size: 14px;
    line-height: 20px;
    color: #666;
}

/*----------------------------------------- 列表 ---------------------------------------*/
.mainList{
    flex: 1;
    overflow-y: auto;
    padding: 10px 12px;
    box-sizing: border-box;
}
.mainList .list{
    width: 100%;
    background: #fff;
    border-radius: 6px;
    margin-bottom: 10px;
}
.mainList .list .title{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    position: relative;
    display: flex;
    justify-content: space-between;
}
.mainList .list .title:before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.mainList .list .title span{
    font-size: 15px;
    line-height: 20px;
    color: #333;
    font-weight: bold;
}
.mainList .list .title em{
    font-size: 12px;
    line-height: 16px;
    padding: 1px 5px;
    box-sizing: border-box;
    margin-left: 5px;
    border-radius: 4px;
}
.mainList .list .title .em1{
    border: 1px solid #32AF25;
    color: #32AF25;
}
.mainList .list .title .em2{
    border: 1px solid #f90808;
    color: #f90808;
}
.mainList .list .title .em3{
    border: 1px solid #e0992d;
    color: #e0992d;
}
.mainList .list .listDetail{
    width: 100%;
    padding: 15px 12px 10px;
    box-sizing: border-box;
    position: relative;
}
.mainList .list .listDetail .detail{
    width: 100%;
    display: flex;
    margin-bottom: 10px;
}
.mainList .list .listDetail .detail span{
    display: block;
    font-size: 15px;
    line-height: 20px;
}
.mainList .list .listDetail .detail span:nth-child(1){
    color: #999;
    width: 120px;
}
.mainList .list .listDetail .detail span:nth-child(2){
    flex: 1;
    color: #333;
    text-align: right;
}
.mainList .list .listDetail .detail em{
    margin-left: 10px;
}
.mainList .list .toDetail{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    position: relative;
    text-align: center;
    font-size: 15px;
    line-height: 20px;
    color: #0F71FF;
}
.mainList .list .toDetail:before{
    content: " ";
    position: absolute;
    left: 0;
    top:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
/* ---------------------------------遮罩层(时间选择)------------------------ */
.popupContent{
    width: 100%;
    height: 100%;
}
.popupContent .title{
    width: 100%;
    font-size: 14px;
    color: #333333;
    line-height: 20px;
    padding: 5px 0;
    box-sizing: border-box;
    font-weight: 500;
    padding: 0 15px;
    box-sizing: border-box;
}
/*时间段*/
.popupContent .daiTime{
    width: 100%;
    display: flex;
    margin: 20px 0;
    padding: 0 15px;
    box-sizing: border-box;
}
.popupContent .daiTime span{
    display: flex;
    width: calc((100% - 30px)/4);
    padding: 6px 0;
    box-sizing: border-box;
    background: #F2F2F2;
    border-radius: 5px;
    font-size: 12px;
    line-height: 20px;
    color: #333333;
    text-align: center;
    justify-content: center;
    align-items: center;
}
.popupContent .daiTime span:nth-child(4n+2){
    margin-left: 10px;
    margin-right: 10px;
}
.popupContent .daiTime span:nth-child(4n+3){
    margin-right: 10px;
}
.popupContent .daiTime .diyTimeActive{
    background: #4675C9;
    color: #fff;
}
/*自定义时间*/
.popupContent .diyTime{
    width: 100%;
    display: flex;
    align-items: center;
    margin: 20px 0;
    padding: 0 15px;
    box-sizing: border-box;
}
.popupContent .diyTime .startTime,
.popupContent .diyTime .endTime{
    width: calc((100% - 40px)/2);
    display: flex;
    align-items: center;
    padding: 10px 12px;
    box-sizing: border-box;
    background: #F2F2F2;
    border-radius: 50px;
}
.popupContent .diyTime .startTime i,
.popupContent .diyTime .endTime i{
    display: flex;
    justify-content: center;
    align-items: center;
    width: 30px;
}
.popupContent .diyTime .startTime i img,
.popupContent .diyTime .endTime i img{
    display: block;
    width: 12px;
}
.popupContent .diyTime .startTime input,
.popupContent .diyTime .endTime input{
    width: 100%;
    background: #F2F2F2;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 14px;
    color: #333;
    line-height: 14px;
    text-align: center;
}
.popupContent .diyTime span{
    width: 40px;
    font-size: 15px;
    line-height: 20px;
    text-align: center;
    color: #999;
}
/*状态筛选*/
.popupContent .diyStatus{
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    margin: 20px 0;
    padding: 0 15px;
    box-sizing: border-box;
}
.popupContent .diyStatus span{
    display: flex;
    width: calc((100% - 20px)/3);
    padding: 6px 0;
    box-sizing: border-box;
    background: #F2F2F2;
    border-radius: 16px;
    font-size: 12px;
    line-height: 20px;
    color: #333333;
    text-align: center;
    justify-content: center;
    align-items: center;
}
.popupContent .diyStatus span:nth-child(3n+2){
    margin-left: 10px;
    margin-right: 10px;
}
.popupContent .diyStatus span:nth-child(4){
    margin-top: 15px;
}
.popupContent .diyStatus .diyTimeActive{
    background: #4675C9;
    color: #fff;
}
/* ----------------------------- 按钮 ------------------------------- */
.searchBtn{
    width: 100%;
    display: flex;
    border-top: 0.5px solid rgba(238,238,238,1);
    margin-top: 30px;
}
.searchBtn span{
    display: block;
    width: 50%;
    font-size: 15px;
    line-height: 50px;
    letter-spacing: 0;
    text-align: center;
}
.searchBtn span:nth-child(1){
    background: #fff;
}
.searchBtn span:nth-child(2){
    background: #4675C9;
    color: #fff;
}
.searchModel .choosed{
    background: #077BFF !important;
    color: #fff !important;
}


.dataOver{
    width: 100%;
    padding: 30px 0;
    text-align: center;
    font-size: 14px;
    color: #666;
}

.status1{
    color: #1e751e !important;
}
.status2{
    color: #f90808 !important;
}
.status3{
    color: #e0992d !important;
}