<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>员工职务</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../../common/css/weui.min.css" />
    <link rel="stylesheet" href="../../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../../common/css/vant-2.12.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/position.css?v=0.0.9">
</head>
<body>

    <div id="app" v-cloak>

         <!-- 被考核人 -->
         <div class="examine" @click="isshowChoosePeople1=true">
            <span>被考核人</span>
            <input type="text" placeholder="请选择被考核人" v-model="assessee" readonly>
            <i><img src="./image/to.png" alt=""></i>
        </div>

        <!-- 负责部门（分管部门） -->
        <template v-if="isshowDividingDep">
            <div class="examine" @click="isshowChoosePeople2=true">
                <template v-if="assessee == '管理型支行部门负责人' ">
                    <span>负责部门</span>
                    <input type="text" placeholder="请选择负责部门" v-model="dividingDep" readonly> 
                </template>
                <template v-if="assessee == '管理型支行行领导' ">
                    <span>分管部门</span>
                    <input type="text" placeholder="请选择分管部门" v-model="dividingDep" readonly> 
                </template>
                <i><img src="./image/to.png" alt=""></i>
            </div>
        </template>

        <!-- 第一考核人 -->
        <div class="examine" @click="chooseExaminePeople(1)">
            <span>考核人1(管理型支行)</span>
            <input type="text" placeholder="请选择考核人1" v-model="examinePeople1Name" readonly>
            <i><img src="./image/to.png" alt=""></i>
        </div>

        <!-- 第二考核人 -->
        <div class="examine" @click="chooseExaminePeople(2)">
            <span>考核人2(总行)</span>
            <input type="text" placeholder="请选择考核人2" v-model="examinePeople2Name" readonly>
            <i><img src="./image/to.png" alt=""></i>
        </div>


        <div style="width: 100%;height: 50px;"></div>

        <!-- 按钮 -->
        <div class="btn">
            <div class="bigBtn" @click="toTian">确定</div>
        </div>

         <!--遮罩层(选择被考核人)-->
         <van-action-sheet v-model="isshowChoosePeople1" title="请选择被考核人">
            <div class="popupContent">
                <div style="width: 100%;height: 15px;"></div>
                <template v-for="(it,i) in chooseList1">
                    <div class="choosePeopleList" @click="choosedDep1(i)">
                        <div class="left">{{it.name}}</div>
                        <div class="right">
                            <template v-if="it.isChoose">
                                <img src="./image/choosed.png" alt="">
                            </template>
                            <template v-else>
                                <img src="./image/noChosoe.png" alt="">
                            </template>
                        </div>
                    </div>
                </template>
                <div style="width: 100%;height: 30px;"></div>
            </div>
        </van-action-sheet>

        <!--遮罩层(选择分管部门)-->
        <van-action-sheet v-model="isshowChoosePeople2" title="请选择分管部门">
            <div class="popupContent">
                <div style="width: 100%;height: 15px;"></div>
                <template v-for="(it,i) in chooseList2">
                    <div class="choosePeopleList" @click="choosedDep2(i)">
                        <div class="left">{{it.name}}</div>
                        <div class="right">
                            <template v-if="it.isChoose">
                                <img src="./image/choosed.png" alt="">
                            </template>
                            <template v-else>
                                <img src="./image/noChosoe.png" alt="">
                            </template>
                        </div>
                    </div>
                </template>
                <div style="width: 100%;height: 30px;"></div>
            </div>
        </van-action-sheet>

    </div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script type="text/javascript" src="../../common/js/vue.min.js"></script>
<script type="text/javascript" src="../../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../../common/js/base.js"></script>
<script type="text/javascript" src="../../common/js/jssdk.js"></script>
<script type="text/javascript" src="../../common/js/newJwxwork.js"></script>
<script type="text/javascript" src="../../common/js/watermark.js?v=1.2"></script>
<script type="text/javascript" src="../../common/js/vConsole.min.js"></script>
<script type="text/javascript" src="../../common/js/server.js"></script>
<script type="text/javascript" src="./js/branchPosition.js?v=0.0.34"></script>
<script>

    // var vConsole = new VConsole();


    //初始化微信社区
    $(function () {
        initJSSDK([ 'hideAllNonBaseMenuItem','invoke','selectEnterpriseContact']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });


    function getUserFinish() {
        action();
    }


</script>
<script type="text/javascript" src="../../common/js/getUserInfo.js"></script>
