[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: 0px 12px 15px;
    box-sizing: border-box;
}
/* ------------------------------------------- 票据列表信息 ------------------------------------ */
.billInfo{
    width: 100%;
    background-color: #fff;
    margin-top: 10px;
    border-radius: 6px;
}
.billInfo .billInfoTitle{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    position: relative;
}
.billInfo .billInfoTitle:before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.billInfo .billInfoTitle span{
    font-size: 15px;
    line-height: 20px;
    color: #333;
}
.billInfo .billInfoTitle em{
    display: inline-block;
    margin-left: 20px;
    padding: 1px 5px;
    box-sizing: border-box;
    border-radius: 4px;
    font-size: 12px;
    line-height: 14px;
    border: 1px solid #409eff;
    color: #409eff;
    background-color: #fff;
}
.billInfo .billInfoContent{
    width: 100%;
    padding: 5px 0;
    box-sizing: border-box;
}
.billInfo .billInfoContent .billInfoContentRow{
    width: 100%;
    padding: 7px 12px;
    box-sizing: border-box;
    position: relative;
    display: flex;
}
.billInfo .billInfoContent .billInfoContentRow span{
    display: block;
    font-size: 14px;
    line-height: 20px;
}
.billInfo .billInfoContent .billInfoContentRow span:nth-child(1){
    width: 100px;
    color: #a2a2a2;
    margin-right: 10px;
}
.billInfo .billInfoContent .billInfoContentRow span:nth-child(2){
    flex: 1;
    color: #313448;
    white-space: normal;
    word-break: break-all;
    text-align: right;
}
.billInfo .billInfoContent .billInfoContentRow em{
    display: block;
    font-size: 15px;
    line-height: 20px;
    margin-left: 10px;
}

.dataOver{
    width: 100%;
    padding: 30px 0;
    text-align: center;
    font-size: 14px;
    color: #666;
}