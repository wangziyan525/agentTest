[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    /* overflow: hidden; */
}
#app{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
/* ---------------------------------------- 搜索 --------------------------------------*/
.searchModel{
    width: 100%;
    background-color: #fff;
    padding: 11px 12px;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
}
.searchModel i{
    display: flex;
    width: 34px;
    align-items: center;
    justify-content: center;
    background: #F5F6F7;
    padding: 7px 0px;
    box-sizing: border-box;
    border-radius: 0 20px 20px 0;
}
.searchModel i img{
    display: block;
    width: 35%;
}
.searchModel input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    background: #F5F6F7;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 14px;
    color: #333;
    line-height: 20px;
    border-radius: 6px;
    padding: 7px 16px;
    box-sizing: border-box;
    border-radius: 20px 0 0 20px;
}
/* ---------------------------------------- 底部按钮 --------------------------------------*/
.btnModel{
    width: 100%;
    background: #fff;
    box-shadow: 0 -2px 4px 0 rgba(223,223,223,0.50);
    padding: 15px 15px 20px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.btnModel .btnBig{
    width: 100%;
    background: #267EF0;
    border-radius: 6px;
    color: #fff;
    padding: 13px 0;
    box-sizing: 13px 0;
    font-size: 15px;
    line-height: 20px;
    border: 1px solid #267EF0;
    text-align: center;
}
/* ---------------------------------------- 列表 --------------------------------------*/
.mainModel{
    width: 100%;
    flex: 1;
    overflow-y: auto;
    padding: 10px 12px;
    box-sizing: border-box;
}
/* ------- 没有列表 -------- */
.noList img{
    display: block;
    width: 70%;
}
.noList span{
    margin-top: 10px;
    color: #333;
    line-height:32px;
    font-size:15px;
}
.noList{
    width: 94%;
    height: 100px;
    margin: 30% auto 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #000000;
    line-height:32px;
}
.noList img{
    width:55%;
}
/* ------- 有列表 -------- */
.mainModel .list{
    width: 100%;
    padding: 16px;
    box-sizing: border-box;
    border-radius: 6px;
    background: #fff;
    display: flex;
    margin-bottom: 10px;
}
.mainModel .list .right{
    width: 120px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    font-size: 14px;
    line-height: 20px;
}
.mainModel .list .right .type1{
    color: #44C966;
}
.mainModel .list .right .type2{
    color: #FF9430;
}   
.mainModel .list .left{
    flex: 1;
    display: flex;
    flex-direction: column;
}
.mainModel .list .left span:nth-child(1){
    display: block;
    font-size: 17px;
    line-height: 24px;
    color: #000;
    font-weight: 600;
    margin-bottom: 3px;
}
.mainModel .list .left span:nth-child(2),
.mainModel .list .left span:nth-child(3){
    display: block;
    font-size: 13px;
    line-height: 16px;
    color: #9DA0A3;
    margin-top: 5px;
}
.mainModel .list .left span:nth-child(3){
    margin-top: 7px;
}