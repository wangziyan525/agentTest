<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
        name="viewport" />
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/common.css?v=1.0.0">
    <link rel="stylesheet" href="css/index.css?v=1.0.1">
    <title>查询新增银行</title>
</head>

<body>
    <div id="app" v-cloak>
        <div class="search_fixed">
            <!-- 搜索 -->
            <div class="search_box display_flex">
                <img class="search_back" src="./images/back.png" alt="" @click='backTap()'>
                <div style="position: relative;width:calc(100% - 75px);">
                    <img class="search_icon" src="./images/search_icon.png" alt="">
                    <input type="text" v-model='keyWord' @input='searchTap()' placeholder="请输入银行名称搜索">
                </div>
                <span style="color: #999999;" @click='cancelTap()'>取消</span>
            </div>
        </div>
        <!-- 占位 -->
        <div style="height:70px;"></div>
        <div class="bank_box">
            <div v-if='viewFlag' class="bank_t">找到{{total}}个</div>
            <div v-if="list.length>0">
                <div class="bank_item display_start lineBottom" v-for='(item,index) in list' :key="index" @click='selectBank(item)'>
                    <img class="bank_icon" :src="item.imgSrc" @error='imgError' alt="">
                    <span v-html='keywordCss(item.memberBankName)'></span>
                </div>
                <div style="font-size: 12px;color: #999;text-align: center;line-height:80px;" @click='getBankList()'>{{moreFlag?'点击加载更多':'已全部加载'}}</div>
            </div>
        </div>
    </div>
</body>
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="../common/js/watermark.js"></script>
<script src="../common/js/server.js"></script>
<script src="js/search.js?v=1.1.2"></script>
<!-- <script src='../common/js/vConsole.min.js'></script> -->
<script>
    // var vConsole = new VConsole();
    initJSSDK(['hideAllNonBaseMenuItem'])
    wx.ready(function() {
        wx.hideAllNonBaseMenuItem();
    });
    function getUserFinish() {
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }
    // initFun()
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>