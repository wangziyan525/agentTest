<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"
        name="viewport" />
    <mata http-equiv="Content-Security-Policy" content="upgrade-insecure-requests" />
    <title>审批进度</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../common/css/weui.min.css" />
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="./css/style.css?v=1.0.0">
</head>

<body>
    <div id="app" v-cloak>
        <div class="detail_t">
            <div>
                <span>客户姓名</span>
                <span>{{detail.ClientNm}}</span>
            </div>
            <div>
                <span>身份证号</span>
                <span>{{detail.IdentNum}}</span>
            </div>
            <div>
                <span>单位名称</span>
                <span>{{detail.UtNm}}</span>
            </div>
            <div>
                <span>职级</span>
                <span>{{detail.Pstn}}</span>
            </div>
        </div>
        <div class="detail_m">
            <div>
                <div class="detail_m_t lineBottom">审批流程</div>
                <div v-if='approvalRecord.length>0' class="detail_approval_list">
                    <div v-for="(item,index) in approvalRecord" :key='index' class="detail_approval_m">
                        <div v-if='item.AprvSt==2||(item.flag)' class="left left1">
                            <i></i>
                        </div>
                        <div v-else class="left">
                            <i></i>
                        </div>
                        <div class="detail_approval_r">
                            <div class="displayTop">
                                <span class='detail_approval_name'>{{item.AprvManNm}}</span>
                                <div style='font-size: 12px;color: #A8A8A8;'>{{item.EmnAprvTm}}</div>
                            </div>
                            <div class="displayTop" style="padding-top: 8px;">
                                <!-- AprvSt -1-已驳回；0-已提交，1-已审批，2-待审批 -->
                                <span class="detail_approval_position">{{item.AprvManSctr}}{{item.AprvManRlDsc}}</span>
                                <span v-if='item.AprvSt==0' class="detail_approval_status">已提交</span>
                                <span v-if='item.AprvSt==1' class="detail_approval_status">已审批</span>
                                <span v-if='item.AprvSt==2' class="detail_approval_status" style="color: #FF9E48;">待审批</span>
                                <span v-if='item.AprvSt==-1' class="detail_approval_status" style="color: #FF4D4F;">已驳回</span>
                            </div>
                            <div v-if='item.AprvRsn&&item.AprvRsn!=""' class="detail_approval_reason">
                                意见：{{item.AprvRsn}}
                            </div>
                        </div>
                    </div>
                </div>
                <div v-else class="noData">
                    <img src="./images/noList.png" alt="">
                    <div>暂无审批记录</div>
                </div>
            </div>
        </div>
        <!-- 占位 -->
        <div style="height:100px"></div>
        <div class="index_btn">
            <div @click='detailCloseTap' class="index_add">关闭</div>
        </div>
    </div>
</body>

</html>
<!-- 引入 Vue 的 JS 文件 -->
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/server.js"></script>
<script type="text/javascript" src="./js/detail.js?v=1.0.5"></script>
<script type="text/javascript" src="../common/js/watermark.js?v=1.2"></script>
<!-- <script type="text/javascript" src="../common/js/vConsole.min.js"></script> -->
<script>
    // var vConsole = new VConsole();
    //初始化微信社区
    $(function () {
            initJSSDK(['hideAllNonBaseMenuItem', 'invoke','closeWindow']);
            wx.ready(function () {
                wx.hideAllNonBaseMenuItem();
            });
        });
    function getUserFinish() {
            // 调用水印
            var username = $.parseJSON($.cookie("user")).name;
            __canvasWM({
                content: username
            });
            initFun();
        }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>