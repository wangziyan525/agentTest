

[v-cloak]{
  display: none!important;
}
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background-color: #f5f5f5;
    min-height: 100vh;
  }

  #app {
    min-height: 100vh;
    background-color: #f5f5f5;
    display: flex;
    flex-direction: column;
  }

 

  .nav-back {
    color: #fff;
    font-size: 24px;
    cursor: pointer;
    position: absolute;
    left: 16px;
  }

  .nav-title {
    color: #fff;
    font-size: 18px;
    font-weight: 500;
    text-align: center;
    flex: 1;
  }

  /* 内容区域 */
  .content-wrapper {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 34px;
  }

  /* 状态行 */
  .status-row {
    background: #fff;
    padding: 14px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #f0f0f0;
  }

  .status-label {
    font-size: 14px;
    color: #333;
  }

  .status-value {
    font-size: 14px;
    color: #FF4D4F;
    font-weight: 500;
  }

  .status-value.success {
    color: #52C41A;
  }

  .status-value.processing {
    color: #1890FF;
  }

  .status-value.warning {
    color: #FA8C16;
  }
  .status-value.fail {
    color: #FF4D4F;
  }

  /* 区块标题 */
  .section-header {
    padding: 10px 16px;
    font-size: 13px;
    color: #999;
    background: #f5f5f5;
  }

  /* 信息区块 */
  .info-section {
    background: #fff;
  }

  .info-item {
    padding: 14px 16px;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .info-item:last-child {
    border-bottom: none;
  }

  .info-label {
    font-size: 14px;
    color: #333;
    flex-shrink: 0;
  }

  .info-value {
    font-size: 14px;
    color: #333;
    text-align: right;
    /* flex: 1; */
    width: 50%;
    margin-left: 20px;
    word-break: break-all;
  }

  /* 电话链接 */
  .phone-link {
    color: #4A90E2;
    text-decoration: underline;
    align-items: center;
    gap: 4px;
  }

  .phone-icon {
    width: 16px;
    height: 16px;
    margin-left: 4px;
  }

  /* 原因说明区块 */
  .reason-field {
    padding: 0 16px 16px;
  }

  .reason-field .van-cell {
    background: #F5F5F5;
    border-radius: 8px;
    padding: 12px 16px;
  }

  .reason-field .van-field__control {
    color: #333;
    font-size: 14px;
    line-height: 1.6;
  }

  .reason-field .van-cell::after {
    display: none;
  }

  /* 底部安全区域 */
  .safe-area-bottom {
    height: 34px;
    background: #f5f5f5;
  }

  /* 底部按钮区域 */
  .bottom-btn-wrapper {
    padding: 16px;
    background: #f5f5f5;
  }

  .bottom-btn-wrapper .van-button {
    width: 100%;
    height: 44px;
    font-size: 16px;
    border-radius: 8px;
  }
  /* 人员选择弹窗 */
  .popup-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border-bottom: 1px solid #eee;
  }

  .popup-header .cancel {
    font-size: 15px;
    color: #666;
    cursor: pointer;
  }

  .popup-header .title {
    font-size: 16px;
    font-weight: 500;
    color: #333;
  }

  .popup-header .confirm {
    font-size: 15px;
    color: #4A90E2;
    cursor: pointer;
  }

  .manager-list {
    max-height: 350px;
    overflow-y: auto;
  }

  .manager-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid #f5f5f5;
  }

  .manager-item:last-child {
    border-bottom: none;
  }

  .manager-item .info {
    display: flex;
    flex-direction: column;
  }

  .manager-item .name {
    font-size: 15px;
    color: #333;
    margin-bottom: 4px;
  }

  .manager-item .dept {
    font-size: 13px;
    color: #999;
  }
  .van-field__control{
    background: #F5f5f5!important;
    border-radius: 4px!important;
    color: #333 important;
  }
  .phone{
    width: 16px;
    padding-left: 4px;
    vertical-align: middle

  }