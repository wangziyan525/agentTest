[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f6f6f6;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
}
/* --------------------------------- tab切换 ---------------------- */
.tab{
    width: 100%;
    height: 50px;
}
.van-tabs--line .van-tabs__wrap{
    height: 50px !important;
}
.van-tab{
    font-size: 15px !important;
    color: #999 !important;
}
.van-tab--active{
    color: #3975C6 !important;
}
.van-tabs__line{
    width: 28px !important;
    height: 2px !important;
    background-color: #3975C6 !important;
}
/* --------------------------------- main ---------------------- */
.main{
    width: 100%;
    flex:1;
    overflow-y: auto;
    padding: 0 12px 30px;
    box-sizing: border-box;
}
.record{
    width: 100%;
    margin-top: 10px;
    padding: 0 16px;
    box-sizing: border-box;
    background-color: #fff;
    border-radius: 4px;
}
.record .title{
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    position: relative;
}
.record .title::after{
    content: '';
    width: 100%;
    height: 2px;
    background: #E6E7E8;
    -ms-transform: scaleY(.3);
    -webkit-transform: scaleY(.3);
    transform: scaleY(.3);
    position: absolute;
    bottom: 0px;
    left: 0;
    z-index: 1;
}
.record .title span:nth-child(1){
    font-family: PingFangSC-Regular;
    font-size: 13px;
    line-height: 20px;
    color: #9DA0A3;
    letter-spacing: 0;
}
.record .title span:nth-child(2){
    font-family: PingFangSC-Regular;
    font-size: 14px;
    line-height: 20px;
    color: #FF9430;
    letter-spacing: 0;
    text-align: right;
}
.record .detail{
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
}
.record .detail .info{
    width: 100%;
    padding: 5px 0;
    box-sizing: border-box;
    display: flex;
}
.record .detail .info span{
    display: block;
    font-size: 15px;
    line-height: 20px;
    letter-spacing: 0;
}
.record .detail .info span:nth-child(1){
    width: 80px;
    color: #9DA0A3;
}
.record .detail .info span:nth-child(2){
    flex: 1;
    text-align: left;
    color: #000;
    word-break: break-all;
}
/* ---------------------------------------- 没有列表 ---------------------------------------- */
.noList img{
    display: block;
    width: 70%;
}
.noList span{
    margin-top: 10px;
    color: #333;
    line-height:32px;
    font-size:15px;
}
.noList{
    width: 94%;
    height: 100px;
    margin: 40% auto 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #000000;
    line-height:32px;
}
.noList img{
    width:55%;
}