}

.session_item_container
{
    padding: 12px 12px;
}

.session_item_active {
    padding: 12px 10px;
}

.session_item_title {
    min-width: 100px;
}

.session_active_title {
    min-width: 100px;
}

.border_none {
    border: none !important;
}
.lineBottom{
    position: relative;
}
.lineBottom:after{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #E1E1E1;
    color: #E1E1E1;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.color999999 {
    color: #999 !important;
}

.fw600 {
    font-weight: 600 !important;
}

.fw400 {
    font-weight: 400;
}

.color333333 {
    color: #333 !important;
}
.text_overflow {
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.margin_top_5 {
    margin-top: 5px;
}

.margin_top_10 {
    margin-top: 10px;
}

.margin_right_0 {
    margin-right: 0 !important;
}

.padding10 {
