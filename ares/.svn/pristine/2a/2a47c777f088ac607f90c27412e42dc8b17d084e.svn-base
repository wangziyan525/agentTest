/* 高度 */

.height43 {
    height: 43px;
}

.height45 {
    height: 45px;
}

.height50 {
    height: 50px;
}

/* 最小宽度 */

.min_width120 {
    min-width: 120px;
}

.min_width100 {
    min-width: 100px;
}

.min_width80 {
    min-width: 80px;
}

.min_width40 {
    min-width: 40px;
}

.min_width70 {
    min-width: 70px;
}

.width50 {
    width: 50px;
}

/* 标题左竖线 */

.view_left_vertical {
    position: relative;
    padding-left: 10px;
}

.view_left_vertical::before {
    position: absolute;
    display: inline-block;
    content: '';
    top: calc(50% - 9px);
    left: 0;
    width: 3px;
    height: 18px;
    background-color: #4675c9;
}

/* 左箭头 */

.session_item_container_right_link {
    position: relative;
    padding-right: 10px;
}

.session_item_container_right_link::before {
    content: " ";
    display: inline-block;
    height: 5px;
    width: 5px;
    border-width: 1px 1px 0 0;
    border-color: #999;
    border-style: solid;
    /* -webkit-transform: matrix(.71,.71,-.71,.71,0,0); */
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: 50%;
    position: absolute;
    margin-top: -2px;
    right: 10px;
}

/* 下箭头 */

._bottom_link {
    position: relative;
    padding-right: 18px;
}

._bottom_link::before {
    content: " ";
    display: inline-block;
    height: 5px;
    width: 5px;
    border-width: 1px 1px 0 0;
    border-color: #333;
    border-style: solid;
    /* -webkit-transform: matrix(.71,.71,-.71,.71,0,0); */
    transform: matrix(.71,.71,.71,-.71,0,0);
    position: relative;
    top: 12px;
    position: absolute;
    margin-top: -6px;
    right: 3px;
}


/* 底部 */

.footer_container {
    padding: 30px 12px;
}

.button_container {
    height: 50px;
    color: #fff;
    background: #3199DD;
    border-radius: 6px;
}

.button_container_left {
    border: 1px solid #3199DD;
    border-radius: 6px;
    height: 50px;
    color: #3199DD;
    margin-right: 10px;
}

/* 固定底部 */

.footer_container_fiexd {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50px;

}


.van-step--vertical .van-step__line {
    top: 34px;
    height: calc(100% - 20px);
}

[class*=van-hairline]::after {
    border-color: #ddd;
}

.van-step--vertical {
    padding: 15px 15px 15px 0;
}

.van-step--vertical .van-step__circle-container {
    top: 25px;
}


/* 整屏弹框 */

/* popup-right */
.popup--nodes--overlay {
    background-color: #fff !important;
}

.van-popup--right {
    background-color: #f5f5f5 !important;
}


.popup-img-box {
    width: 18px;
    align-items: center;
    margin-right: 10px;
}

.popup-img-box img, .popup-main-item-img img {
    width: 100%;
}

.popup-main-item-img div {
    width: 18px;
    height: 18px;
}

.popup__container {
    padding: 12px 12px 0;
}

.session__item__container
{
    height: 50px;
    padding: 0 12px;
}

.popup__main__container {
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
}

.border_top_bofore:first-child {
    border-top: none;
}

.popup__main__item__img img {
    width: 100%;
}

.popup__main__item__img div {
    width: 18px;
    height: 18px;
}

.popup__footer__container {
    padding: 45px 0px;
}

/* vant 初始化 */

.van-cell {
    padding: 0;
    font-size: 15px;
}

.van-field__control {
    color: #333;
}

::-webkit-input-placeholder {
    color:  #999 !important;
    font-size: 15px;
}


.van-popup--right {
    background-color: #f3f4f6 !important;
}

.weui-dialog{
    border-radius: 8px !important;
    font-size: 17px;
}
.weui-dialog .weui-dialog__hd{
    padding: 20px;
}
.weui-dialog__ft,.weui-dialog__btn{
    font-size: 17px;
    color: #267EF0;
}


.header_fiexd {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
}


.footer_fiexd {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    background-color: #fff;
}

.footer_fiexd_container {
    height: 50px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, .1);
}


.finished_footer{
    display: flex;
    justify-content:space-between;
    align-items: center;
    padding: 0 10px;
    box-sizing: border-box;
    margin-top:42px;
}
.finished_footer span{
    width:45%;
    border: 1px solid rgba(49,153,221,1);
    border-radius: 5px;
    font-size: 16px;
    text-align: center;
    padding: 12px 0;
    box-sizing: border-box;
}

.footer_eidt{
    background: #fff;
    padding: 7px 15px;
    box-sizing: border-box;
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 9999;
    font-size: 16px;
}

.noData{
    text-align: center;
    line-height:100px;
}
