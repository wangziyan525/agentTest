<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <META HTTP-EQUIV="Pragma" CONTENT="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>西安银行</title>
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" type="text/css" href="css/index.css?v=1.0.1">
</head>
<body>
    <div id="signId" style="display: none"></div>
     <div class="page" id="page1" style="display: none;">
         <div class="mid1" style="overflow-y: auto" id="contentBox">
             
         </div>
         <div class="bottom">
             <div class="btn">去签名</div>
         </div>
     </div>
     <div class="page" id="page2" >
         <div style="background: #fff;border-radius: 5px">
             <!--<div class="title" id="title"><p>请手写您的签名</p></div>-->
             <div class="mid1">
                 <div class="mid2 myCanvasDiv" style="height: 200px">
                     <canvas id="myCanvas"></canvas>
                 </div>
             </div>
             <p style="font-size: 14px;padding: 0 10px 10px 10px"><span style="color: red">*</span>签名时请使用正楷字体；横屏签名时请确保手机及企业微信自动旋转打开</p>
         </div>
         <div class="control-ops control" onclick="clearArea()">清空签名</div>
         <div class="btns">
             <p class="back">返回</p>
             <p class="sureSign">确认签名</p>
         </div>

     </div>
     <div class="page" id="page3" style="overflow: auto;padding: 0 10px 0 6px">
         <img src="" />
     </div>
</body>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/base.js"></script>
<script src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="js/mobile-detect.min.js"></script>
<script type="text/javascript" src="js/draw.js?v=1.0" ></script>
<script src="js/index.js?v=1.3"></script>
<script src="../common/js/watermark.js?v=1.0"></script>
<script type="text/javascript">
    function getUserFinish(){
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        
        queryImginfo();
        InitThis();
        initDate();
    }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script></html>