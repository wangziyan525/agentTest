<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>提前还款申请审批</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../common/css/weui.min.css" />
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/list.css?v=1.0.3">
</head>
<body>

    <div id="app" v-cloak>
        <!-- tab切换 -->
        <div>
            <div class="tab_con">
                <span v-for="(item,index) in tabs" :key="index" :class="tabIndex==index?'active':'color9b9'"
                    @click='tabTap(index,item.id)'>{{item.text}}</span>
            </div>
        </div>
        <!-- 搜索-->
        <div class="searchTnput">
            <form action="javascript:return true;">
                <input type="text" style="display: none;">
                <input type="search" placeholder="请输入企业名称搜索" v-model='keyword' @keyup.enter='searchTap()'>
                <img src="./image/search.png" class="searchIcon" alt="">
            </form>
        </div>
        <!--筛选-->
        <template v-if="tabIndex == 1">
            <div class="filter">
                 <!--状态筛选-->
            <div class="filterStatus" @click="showChooseStatusModel">
                <div class="filterText">{{filterStatusText}}</div>
                <img src="./image/down.png" alt="">
            </div>
            <!--时间筛选-->
            <div class="filterTime" @click="showChooseTimeModel">
                <div class="filterText" v-html="filterTimeText"></div>
                <img src="./image/down.png" alt="">
            </div>

        </div>
        </template>

        <!-- 列表-->
        <div class="mainList">
            <div v-if='list.length>0'>
                <div v-for="(item,index) in list" :key='index' class="list">
                    <div class="title">
                        <span>{{item.COMP_NAME}}</span>
                        <template v-if="tabIndex == 1">
                            <em v-if="item.status == 1" class="em1">审批同意</em>
                            <em v-if="item.status == 2" class="em2">审批拒绝</em>
                        </template>
                    </div>
                    <div class="listDetail">
                        <div class="detail">
                            <span>还款⾦额</span><span>￥{{numFormat(item.TRAN_AMT)}}</span>
                        </div>
                        <div class="detail">
                            <span>贷款产品名称</span><span>{{item.PRO_NAME}}</span>
                        </div>
                        <div class="detail">
                            <span>贷款账号</span><span>{{item.LOAN_ACCT_NO}}</span>
                        </div>
                        <div class="detail">
                            <span>还款账号</span><span>{{item.REYPAY_ACCT}}</span>
                        </div>
                        <div v-if='item.status==0' class="detail">
                            <span>申请时间</span><span>{{item.createTime}}</span>
                        </div>
                        <div v-else class="detail">
                            <span>审批时间</span><span>{{item.updateTime}}</span>
                        </div>
                    </div>
                    <div class="toDetail" @click="toDetail(item.id)">
                        <template v-if="item.status == 0">审批</template>
                        <template v-else>详情</template>
                    </div>
                </div>
            </div>
            <div v-if="list.length==0" class="noData">
                <img src="./image/noList.png" alt="">
                <div>暂无数据</div>
            </div>
        </div>

        <!--遮罩层(时间)-->
        <van-action-sheet v-model="isshowChooseTime" title="请选择查询时间">
            <div class="popupContent">
                <div style="width: 100%;height: 30px"></div>
                <div class="title">自定义时间</div>
                <div class="diyTime">
                    <div class="startTime" @click="showDiyTime(1)">
                        <input type="text" placeholder="开始时间" readonly v-model="startTime">
                        <i><img src="./image/down.png" alt=""></i>
                    </div>
                    <span>至</span>
                    <div class="endTime" @click="showDiyTime(2)">
                        <input type="text" placeholder="结束时间" readonly v-model="endTime">
                        <i><img src="./image/down.png" alt=""></i>
                    </div>
                </div>
                <div class="title">时间段</div>
                <div class="daiTime">
                    <span :class="chooseTimeDuan==0?'diyTimeActive':''" @click="changTimeDuan(0)">近一周</span>
                    <span :class="chooseTimeDuan==1?'diyTimeActive':''" @click="changTimeDuan(1)">近一月</span>
                    <span :class="chooseTimeDuan==2?'diyTimeActive':''" @click="changTimeDuan(2)">近三月</span>
                    <span :class="chooseTimeDuan==3?'diyTimeActive':''" @click="changTimeDuan(3)">近半年</span>
                </div>
                <div class="searchBtn">
                    <span @click="searchAgin()">重置</span>
                    <span @click="filterTimeSearch()">确认</span>
                </div>
            </div>
        </van-action-sheet>

        <!-- 下拉选择 -->
        <van-popup v-model="showPickerStatus" position="bottom">
            <van-picker item-height="50px" visible-item-count="3"
                    show-toolbar
                    :columns="chooseList"
                    @confirm="onConfirm"
                    @cancel="showPickerStatus=false"
            >
            </van-picker>
        </van-popup>

        <!--时间选择-->
        <van-popup v-model="chooseTimeShow" position="bottom" style="border-radius: 6px;">
            <van-datetime-picker type="date"
                                 title="按年月筛选"
                                 v-model="currentDate"
                                 :min-date='minDate'
                                 :max-date='maxDate'
                                 :formatter="formatter"
                                 @cancel="chooseTimeShow=false"
                                 @confirm="chooseDate">
            </van-datetime-picker>
        </van-popup>

    </div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/server.js"></script>
<script type="text/javascript" src="./js/common.js?v=1.0.0"></script>
<script type="text/javascript" src="./js/list.js?v=1.0.7"></script>
<script type="text/javascript" src="../common/js/watermark.js?v=1.2"></script>
<!-- <script type="text/javascript" src="../common/js/vConsole.min.js"></script> -->
<script>

    // var vConsole = new VConsole();

    //初始化微信社区
    $(function () {
            initJSSDK(['hideAllNonBaseMenuItem', 'invoke', 'chooseImage', 'uploadImage', 'previewImage']);
            wx.ready(function () {
                wx.hideAllNonBaseMenuItem();
            });
        })

        function getUserFinish() {
            // 调用水印
            var username = $.parseJSON($.cookie("user")).name;
            __canvasWM({
                content: username
            });
            action();
        }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
