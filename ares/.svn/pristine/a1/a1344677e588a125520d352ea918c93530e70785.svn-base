<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
    <title>西安银行</title>
    <!-- head 中 -->
    <link rel="stylesheet" href="../common/css/weui.min.css" />
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css" />
    <link rel="stylesheet" href="../common/css/vant-2.12.css" />
    <link rel="stylesheet" href="./css/reset.css">
    <link rel="stylesheet" href="./css/list.css?v=0.0.8">
</head>
<body>

    <div id="app" v-cloak>

        <!-- tab切换 -->
        <div class="tabs">
            <van-tabs v-model="active" @change="activeChange">
                <van-tab title="产品成立"></van-tab>
                <van-tab title="募集列表"></van-tab>
                <van-tab title="待审核"></van-tab>
                <van-tab title="已审核"></van-tab>
            </van-tabs>
        </div>

        <!-- 列表-->
        <div class="mainList" ref="main" @scroll="handleScroll">
            <template v-if="isHaveList">
                <template v-for="(it,i) in list">
                    <div class="list">
                        <div class="title">
                            <span>{{it.productName}}</span>
                        </div>
                        <div class="listDetail">
                            <div class="detail">
                                <span>产品代码</span><span>{{it.productCode}}</span>
                            </div>
                            <div class="detail">
                                <span>募集金额</span><span>{{numFormat(it.establhmentAmount)}} 元</span>
                            </div>
                            <div class="detail">
                                <span>产品成立日</span><span>{{readDate(it.productSetupDay)}}</span>
                            </div>
                            <div class="detail">
                                <span>产品到期日</span><span>{{readDate(it.productExpireDay)}}</span>
                            </div>
                        </div>
                        <div class="toDetail">
                            <template v-if="active == 0">
                                <span class="allBtn" @click="toFillDetail(it.productCode)">查看</span>
                            </template>
                            <template v-if="active == 1">
                                <span class="allBtn" @click="toCollect(it.productCode)">查看</span>
                            </template>
                            <template v-if="active == 2">
                                <span class="smallBtn" v-if="it.productApproveStatus == 1" @click="toWeight(it.productCode,it.rateApproveList[0].flowNo)">加权平均利率审核</span>
                                <span class="smallBtn" v-if="it.productApproveStatus == 2" style="color:#333;opacity: 0.5">加权平均利率审核</span>
                                <span class="smallBtn" v-if="it.productApproveStatus == 2" @click="toBecome(it.productCode,it.earningsApproveList[0].flowNo)">到期收益审核</span>
                                <span class="smallBtn" v-if="it.productApproveStatus == 1" style="color:#333;opacity: 0.5">到期收益审核</span>
                            </template>
                            <template v-if="active == 3">
                                <span class="allBtn" v-if="it.productApproveStatus == 1" @click="toApproved(it.productCode,'1')">查看</span>
                                <span class="allBtn" v-if="it.productApproveStatus == 2" @click="toApproved(it.productCode,'2')">查看</span>
                            </template>
                        </div>
                    </div>
                </template>
            </template>
            <template v-if="noList">
                <div class="noList">
                    <img src="./image/noList.png" alt="">
                    <span>暂无数据</span>
                </div>
            </template>
        </div>

    </div>

</body>
</html>


<!-- 引入 Vue 和 Vant 的 JS 文件 -->
<script type="text/javascript" src="../common/js/vue.min.js"></script>
<script type="text/javascript" src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script type="text/javascript" src="../common/js/base.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script type="text/javascript" src="../common/js/jwxwork.js"></script>
<script type="text/javascript" src="../common/js/watermark.js?v=1.2"></script>
<script type="text/javascript" src="../common/js/vConsole.min.js"></script>
<script type="text/javascript" src="../common/js/server.js"></script>
<script type="text/javascript" src="../common/js/decimal.min.js"></script>
<script type="text/javascript" src="./js/index.js?v=0.0.22"></script>
<script>

    // var vConsole = new VConsole();

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });


    //初始化微信社区
    $(function () {
        initJSSDK([ 'hideAllNonBaseMenuItem','invoke','chooseImage','uploadImage','previewImage']);
        wx.ready(function () {
            wx.hideAllNonBaseMenuItem();
        });
    });


    function getUserFinish() {
        action();
    }


</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
