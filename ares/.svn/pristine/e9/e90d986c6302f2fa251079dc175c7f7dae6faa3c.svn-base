[v-cloak] {
    display: none !important;
}
html,body{
    width: 100vw;
    height: 100vh;
    background-color: #f5f6f7;
    overflow: hidden;
}
#app{
    width: 100%;
    height: 100%;
    overflow-y: auto;
    padding: 0 12px;
    box-sizing: border-box;
}
/* ------------------------------------------- 信息 ------------------------------------ */
.baseInfo{
    width: 100%;
    background-color: rgba(236,236,236);
    border-radius: 6px;
    margin-top: 10px;
}
.baseInfo .title{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    font-size: 15px;
    line-height: 20px;
    color: #333;
}
.baseInfo .content{
    width: 100%;
    background: #fff;
}
.infoRow{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    position: relative;
    display: flex;
}
.infoRow:before{
    content: " ";
    position: absolute;
    left: 12px;
    bottom: 0;
    width: calc(100% - 24px);
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.infoRow:last-child:before{
    display: none;
}
.infoRow span{
    display: block;
    font-size: 15px;
    line-height: 20px;
}
.infoRow span:nth-child(1){
    width: 150px;
    color: #999;
    margin-right: 10px;
}
.infoRow span:nth-child(2){
    flex: 1;
    color: #333;
    white-space: normal;
    word-break: break-all;
    text-align: right;
}
.infoRow .flow{
    flex: 1;
    display: flex;
    flex-direction: column;
}
.infoRow .flow em{
    font-size: 15px;
    line-height: 20px;
    text-align: right;
}
.infoRow .flow .flowDetail{
    display: flex;
    justify-content: flex-end;
    align-items: center;
    font-size: 12px;
    line-height: 20px;
    color: #999;
}
.infoRow .flow .flowDetail img{
    display: block;
    height: 8px;
    margin-left: 5px;
}


.baseInfo .idPic{
    width: 100%;
    background: #fff;
    display: flex;
    padding: 15px 0;
    box-sizing: border-box;
}
.baseInfo .idPic .pic{
    width: 35%;
    height: 0;
    padding-top: calc(35%/1.5);
    background-color: #F5F6F7;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
    margin-left: 12px;
}

.baseInfo .idPic .picter{
    display: block;
    width: 100%;
    position: absolute;
    top:0;
}
.baseInfo .idPic .pic .loadding{
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    position: absolute;
    top:0;
    left:0;
}
.baseInfo .idPic .pic .loadding img{
    display: block;
    width: 25px;
    height: 25px;
}

/* ------------------------------------------- 转办 ------------------------------------ */
.passOnModel{
    width: 100%;
    background-color: #fff;
    margin-top: 10px;
    border-radius: 6px;
}
.passOnModel .passOn{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    display: flex;
    position: relative;
}
.passOnModel .passOn span{
    width: 100px;
    display: block;
    font-size: 15px;
    line-height: 20px;
    color: #999;
}
.passOnModel .passOn input{
    flex: 1;
    width: 100%;
    display: block;
    border: none;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
    font-size: 15px;
    color: #333;
    line-height: 20px;
    box-sizing: border-box;
    text-align: right;
}
.passOnModel .passOn i{
    display: flex;
    width: 15px;
    justify-content: center;
    align-items: center;
}
.passOnModel .passOn i img{
    display: block;
    width: 50%;
}
.passOnModel .passOn:nth-child(2):before{
    content: " ";
    position: absolute;
    left: 12px;
    top: 0;
    width: calc(100% - 24px);
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
/* ------------------------------------------- 按钮 ------------------------------------ */
.btn{
    width: 100%;
    display: flex;
    padding: 50px 12px 50px;
    box-sizing: border-box;
    justify-content: space-between;
}
.btn .smallBtn{
    width: calc((100% - 12px)/2);
    padding: 12px 0;
    box-sizing: border-box;
    font-size: 15px;
    line-height: 20px;
    border-radius: 6px;
    border: 1px solid #4675c9;
    text-align: center;
}
.btn .smallBtn:nth-child(1){
    background: transparent;
    color: #4675c9;
    border: 1px solid #4675c9;
}
.btn .smallBtn:nth-child(2){
    background: #4675c9;
    color: #fff;
}
.btn .bigBtn{
    width: 100%;
    padding: 12px 0;
    box-sizing: border-box;
    font-size: 15px;
    line-height: 20px;
    border-radius: 6px;
    text-align: center;
    background: #4675c9;
    color: #fff;
}
/* ----------------------------------------- 拒绝弹框 -------------------------------------- */
.van-popup--center{
    top: 43% !important;
    border-radius: 6px !important;
}
.refuseModel{
    width: 85vw;
    border-radius: 6px;
    background-color: #fff;
}
.refuseModel .title{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
    font-size: 15px;
    color: #333;
    line-height: 20px;
    text-align: center;
    position: relative;
}
.refuseModel .title:before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.refuseModel .refuseCt{
    width: 100%;
    padding: 15px 12px;
    box-sizing: border-box;
}
.refuseModel .refuseCt .refuseTip{
    width: 100%;
    font-size: 15px;
    color: #333;
    line-height: 30px;
}
.refuseModel .refuseCt .refuseTip em{
    color: red;
    margin-right: 10px;
}
.refuseModel .refuseCt textarea{
    resize: none;
    border:none;
    width: 100%;
    padding: 10px;
    box-sizing: border-box;
    background: #F5F5F5;
    border-radius: 4px;
    font-size: 15px;
    color: #333330;
    line-height: 20px;
    outline: none;
    resize: none;
    margin: 10px auto 15px;
}   
.refuseModel .refuseCt .refuseBtn{
    width: 100%;
    display: flex;
    padding: 10px 12px;
    box-sizing: border-box;
    justify-content: space-between;
}
.refuseModel .refuseCt .refuseBtn span{
    width: calc((100% - 12px)/2);
    padding: 8px 0;
    box-sizing: border-box;
    font-size: 15px;
    line-height: 20px;
    border-radius: 6px;
    border: 1px solid #4675c9;
    text-align: center;
}
.refuseModel .refuseCt .refuseBtn span:nth-child(1){
    background: transparent;
    color: #4675c9;
    border: 1px solid #4675c9;
}
.refuseModel .refuseCt .refuseBtn span:nth-child(2){
    background: #4675c9;
    color: #fff;
}

.status1{
    color: #1e751e !important;
}
.status2{
    color: #f90808 !important;
}
.status3{
    color: #e0992d !important;
}


/* --------------------------------- 流转信息 ------------------------------------- */
.flowModel{
    width: 100%;
    padding-bottom: 20px;
    box-sizing: border-box;
}
.flowModel .title{
    width: 100%;
    padding: 15px 0;
    box-sizing: border-box;
    text-align: center;
    font-size: 15px;
    line-height: 20px;
    color: #333;
    position: relative;
}
.flowModel .title:before{
    content: " ";
    position: absolute;
    left: 0;
    bottom:0;
    width: 100%;
    height: 1px;
    border-bottom:1px solid #ddd;
    color: #ddd;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(0.5);
    transform: scaleY(0.5);
    z-index: 2;
}
.flowModel .flowCt{
    width: 100%;
    padding: 15px 20px;
    box-sizing: border-box;
}
.flowModel .flowCt .flow{
    width: 100%;
    display: flex;
    padding-bottom: 17px;
    position: relative;
}
.flowModel .flowCt .flow .left{
    width: 5px;
    display: flex;
    justify-content: space-around;
    position: relative;
}
.flowModel .flowCt .flow .left i{
    display: block;
    margin-top: 5px;
}
.flowModel .flowCt .flow i img{
    display: block;
    width: 11px;
}
.flowModel .flowCt .flow .left::after{
    content: '';
    width: 1px;
    height:-webkit-calc(100% + 17px);
    background: #4675c9;
    position: absolute;
    top: 10px;
    left: 2px;
    -ms-transform: scaleX(.5);
    -webkit-transform: scaleX(.5);
    transform: scaleX(.5);
}
.flowModel .flowCt .flow:last-child .left::after{
    display: none;
}
.flowModel .flowCt .flow .right{
    flex: 1;
    padding-left: 16px;
    box-sizing: border-box;
}
.flowModel .flowCt .flow .right .peopleType{
    width: 100%;
    font-size: 15px;
    line-height: 20px;
    color: #999;
}
.flowModel .flowCt .flow .right .nameTime{
    width: 100%;
    display: flex;
    justify-content: space-between;
    margin: 5px 0 0;
}
.flowModel .flowCt .flow .right .nameTime .name,
.flowModel .flowCt .flow .right .nameTime .time{
    width: 50%;
    font-size: 14px;
    line-height: 20px;
}
.flowModel .flowCt .flow .right .nameTime .name{
    color: #333;
} 
.flowModel .flowCt .flow .right .nameTime .time{
    color: #999;
    text-align: right;
} 
.flowModel .flowCt .flow .right .reason{
    width: 100%;
    font-size: 14px;
    line-height: 20px;
    color: #333;
    margin: 5px 0 0;
} 