<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
          name="viewport" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>西安银行</title>
    <script src="../common/js/vue.min.js"></script>
    <script src="../common/js/vant-2.12.min.js"></script>
    <script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
    <script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
    <script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>

    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/common.css?v=1.0.1">
    <link rel="stylesheet" href="css/apply.css?v=1.0.1">

</head>
<body>
<div id="app" v-cloak>
    <div>
        <div class="title">安全检查项目</div>
        <div class="container" style="overflow-y: auto">
            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>门窗</p>
                    <p @click="showMore('windowInfo')">
                        <img v-if="windowInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="windowInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="windowInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','windowInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="windowInfo.status=='' || windowInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="windowInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','windowInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="windowInfo.status=='' || windowInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="windowInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="windowInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）"  v-model="windowInfo.describe" @input="sumTotle('windowInfo')"></textarea>
                            <div class="yuNum"><span>{{windowInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>门窗防护装置是否正常，营业期间、营业终了是否按规定锁闭。拍照1-3张：卷帘门1张、后门1张（有则拍照）、现金区窗户1张（有则拍照）。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in windowInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'windowInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='windowInfo.addImgList.length>0' v-for='(item,index) in windowInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'windowInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'windowInfo')">
                                </div>
                            </div>
                            <div v-if='windowInfo.addImgList.length+windowInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'windowInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>自卫器具</p>
                    <p @click="showMore('defendInfo')">
                        <img v-if="defendInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="defendInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="defendInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','defendInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="defendInfo.status=='' || defendInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="defendInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','defendInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="defendInfo.status=='' || defendInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="defendInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="defendInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="defendInfo.describe" @input="sumTotle('defendInfo')"></textarea>
                            <div class="yuNum"><span>{{defendInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>自卫器具是否按规定配备齐全，有无损坏，是否置于规定位置。拍照2-3张：头盔、盾牌、钢叉集中放置处1-2张、柜台及橡胶棍1张。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in defendInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'defendInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='defendInfo.addImgList.length>0' v-for='(item,index) in defendInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'defendInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'defendInfo')">
                                </div>
                            </div>
                            <div v-if='defendInfo.addImgList.length+defendInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'defendInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>防弹玻璃/护栏</p>
                    <p @click="showMore('railingInfo')">
                        <img v-if="railingInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="railingInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="railingInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','railingInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="railingInfo.status=='' || railingInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="railingInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','railingInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="railingInfo.status=='' || railingInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="railingInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="railingInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="railingInfo.describe" @input="sumTotle('railingInfo')"></textarea>
                            <div class="yuNum"><span>{{railingInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>防弹玻璃/护栏有无损坏、老化。拍照1-3张：营业柜台上方防弹玻璃/护栏整体外观1-3张。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in railingInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'railingInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='railingInfo.addImgList.length>0' v-for='(item,index) in railingInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'railingInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'railingInfo')">
                                </div>
                            </div>
                            <div v-if='railingInfo.addImgList.length+railingInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'railingInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>电源</p>
                    <p @click="showMore('powerInfo')">
                        <img v-if="powerInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="powerInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="powerInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','powerInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="powerInfo.status=='' || powerInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="powerInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','powerInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="powerInfo.status=='' || powerInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="powerInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="powerInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="powerInfo.describe" @input="sumTotle('powerInfo')"></textarea>
                            <div class="yuNum"><span>{{powerInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>电源是否损坏，或线缆上是否有其他不明附属物。拍照1-3张：电源配电箱1-3张。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in powerInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'powerInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='powerInfo.addImgList.length>0' v-for='(item,index) in powerInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'powerInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'powerInfo')">
                                </div>
                            </div>
                            <div v-if='powerInfo.addImgList.length+powerInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'powerInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>自助设备</p>
                    <p @click="showMore('selfEqInfo')">
                        <img v-if="selfEqInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="selfEqInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="selfEqInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','selfEqInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="selfEqInfo.status=='' || selfEqInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="selfEqInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','selfEqInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="selfEqInfo.status=='' || selfEqInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="selfEqInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="selfEqInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="selfEqInfo.describe" @input="sumTotle('selfEqInfo')"></textarea>
                            <div class="yuNum"><span>{{selfEqInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>自助设备运行是否正常及有无其他不明附着物。拍照1-3张：ATM机正面1-2张、防护舱外观1张（有则拍照）。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in selfEqInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'selfEqInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='selfEqInfo.addImgList.length>0' v-for='(item,index) in selfEqInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'selfEqInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'selfEqInfo')">
                                </div>
                            </div>
                            <div v-if='selfEqInfo.addImgList.length+selfEqInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'selfEqInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>监控设备</p>
                    <p @click="showMore('monitorInfo')">
                        <img v-if="monitorInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="monitorInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="monitorInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','monitorInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="monitorInfo.status=='' || monitorInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="monitorInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','monitorInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="monitorInfo.status=='' || monitorInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="monitorInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="monitorInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="monitorInfo.describe" @input="sumTotle('monitorInfo')"></textarea>
                            <div class="yuNum"><span>{{monitorInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>监控设备运转是否正常，图像是否清晰，回放是否正常。拍照2-3张：监控主机1张、显示器视频1-2张。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in monitorInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'monitorInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='monitorInfo.addImgList.length>0' v-for='(item,index) in monitorInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'monitorInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'monitorInfo')">
                                </div>
                            </div>
                            <div v-if='monitorInfo.addImgList.length+monitorInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'monitorInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>消防设备</p>
                    <p @click="showMore('fireInfo')">
                        <img v-if="fireInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="fireInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="fireInfo.showFlag=='1'">
                    <div class="contentLine border-bottom">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','fireInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="fireInfo.status=='' || fireInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="fireInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','fireInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="fireInfo.status=='' || fireInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="fireInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="fireInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="fireInfo.describe" @input="sumTotle('fireInfo')"></textarea>
                            <div class="yuNum"><span>{{fireInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <div class="titles">上传资料</div>
                        <div class="ListLine">
                            <div>消防设备是否足量，是否在有效期内。拍照1-3张：灭火器瓶体压力表1张、消火栓箱体外观1-2张（有则拍照）。</div>
                        </div>
                        <div class="upload_box">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in fireInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'fireInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='fireInfo.addImgList.length>0' v-for='(item,index) in fireInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(3,index,'fireInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'fireInfo')">
                                </div>
                            </div>
                            <div v-if='fireInfo.addImgList.length+fireInfo.addImgListOld.length<3' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(3,'fireInfo')">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contentPart">
                <div class="contentLine border-bottom">
                    <p>接送库</p>
                    <p @click="showMore('pickUpInfo')">
                        <img v-if="pickUpInfo.showFlag=='0'" src="image/down.png">
                        <img v-if="pickUpInfo.showFlag=='1'" src="image/up.png">
                    </p>
                </div>
                <div v-if="pickUpInfo.showFlag=='1'">
                    <div class="contentLine border-bottom" style="display: none !important;">
                        <div>结果</div>
                        <div style="display: flex">
                            <div @click="changeStatus('1','pickUpInfo')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="pickUpInfo.status=='' || pickUpInfo.status=='0'" class="icon" src="image/unselect.png">
                                <img v-if="pickUpInfo.status=='1'" class="icon" src="image/ckend.png">正常
                            </div>
                            <div @click="changeStatus('0','pickUpInfo')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="pickUpInfo.status=='' || pickUpInfo.status=='1'" class="icon" src="image/unselect.png">
                                <img v-if="pickUpInfo.status=='0'" class="icon" src="image/ckend.png">异常
                            </div>
                        </div>
                    </div>
                    <div class="contentLine border-bottom">
                        <div>网点监控范围</div>
                        <div style="display: flex">
                            <div @click="isArrive('1')" style="display: flex;align-items: center;margin-right: 15px;justify-content: flex-end">
                                <img v-if="pickUpInfo.arrive=='' || pickUpInfo.arrive=='0'" class="icon" src="image/unselect.png">
                                <img v-if="pickUpInfo.arrive=='1'" class="icon" src="image/ckend.png">到达
                            </div>
                            <div @click="isArrive('0')" style="display: flex;align-items: center;justify-content: flex-end">
                                <img v-if="pickUpInfo.arrive=='' || pickUpInfo.arrive=='1'" class="icon" src="image/unselect.png">
                                <img v-if="pickUpInfo.arrive=='0'" class="icon" src="image/ckend.png">未到达
                            </div>
                        </div>
                    </div>
                    <div class="border-bottom" v-if="pickUpInfo.status=='0'">
                        <div class="titles" style="padding-bottom: 0">问题描述</div>
                        <div class="titles" style="position: relative">
                            <textarea rows="8" maxlength='500' placeholder="请输入内容（500字以内）" v-model="pickUpInfo.describe" @input="sumTotle('pickUpInfo')"></textarea>
                            <div class="yuNum"><span>{{pickUpInfo.yuNum}}/500</span></div>
                        </div>
                    </div>
                    <div class="border-bottom">
                        <!--<div class="titles">上传资料</div>
                        <div class="ListLine" v-if="pickUpInfo.arrive=='1'">
                            <div>无法到达网点监控范围内的营业网点需绕库车一周拍摄前后车牌</div>
                        </div>
                        <div class="upload_box" v-if="pickUpInfo.arrive=='1'">
                            <div style="display: flex;align-items: center;flex-wrap: wrap;margin-bottom: 10px">
                                <div class="imgOne" v-for="(item,index) in pickUpInfo.addImgListOld" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                    <div class="uploadIMg" @click="bigImg(item)">
                                        <img :src="item">
                                        <img class="deleteImg" src="image/delete.png" alt="" @click.stop="deleteImg1(index,'pickUpInfo')">
                                    </div>
                                </div>
                            </div>
                            <div v-if='pickUpInfo.addImgList.length>0' v-for='(item,index) in pickUpInfo.addImgList' :key='index' style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <div class="upload_list">
                                    <img :src="item" style="object-fit: contain;" @click="replaceImg(2,index,'pickUpInfo')">
                                    <img class="deleteImg" src="image/delete.png" alt="" @click="deleteImg(index,'pickUpInfo')">
                                </div>
                            </div>
                            <div v-if='pickUpInfo.addImgList.length+pickUpInfo.addImgListOld.length<2' class="upload_info">
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="upload(2,'pickUpInfo')">
                            </div>
                        </div>-->
                        <div class="ListLine" v-if="pickUpInfo.arrive=='0'" style="margin-top: 15px">
                            <div>接送库视频（可选项）。</div>
                        </div>
                        <div class="upload_box" style="display: block" v-if="pickUpInfo.arrive=='0'">
                            <div class="upload_info" v-if="!videoShow">
                                <!--跳转1002页面 handleUpload-->
                                <img class="add_img" src="image/uploadimg.png" alt="" @click="hrefPage()">
                            </div>
                            <div class="upload_info" v-if="videoShow" style="position: relative;padding:0px 12px 0 0;box-sizing: border-box;">
                                <video class="myvideo"
                                       playsinline="true"
                                       x5-video-player-fullscreen="ture"
                                       x5-playsinline="true"
                                       x-webkit-airplay="true"
                                       webkit-playsinline="true"
                                       controls
                                       preload="auto"
                                       width="50%"
                                       height="150px">
                                    <source :src="path">
                                </video>
                                <img class="deleteVideo" src="image/delete.png" alt="" @click="deleteVideo()">
                            </div>
                            <!--accept="video/*"-->
                            <input class="changePdf" type="file" name="file" id="videoInput"  accept="video/*" @change="uploadFile" style="display: none" ref="selectFile">
                        </div>
                    </div>
                </div>
            </div>
        </div>




    </div>
    <div class="bottomButton">
        <div class="submitButton refuse" @click="submitBindtap('0')">临时保存</div>
        <div class="submitButton sure" @click="submitBindtap('1')">提 交</div>
    </div>
</div>
</body>
<script type="text/javascript" src="../common/js/base.js"></script>
<script src="./../common/js/newBase.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="js/server.js"></script>
<script src="../common/js/watermark.js"></script>

<script type="text/javascript" src="js/apply.js?v=2.2.1"></script>
<script src="../common/js/vConsole.min.js"></script>
<script>

    //var vConsole = new VConsole();
    //初始化微信社区
    $(function() {
        initJSSDK(['hideAllNonBaseMenuItem','chooseImage','uploadImage','downloadImage', 'startRecord', 'stopRecord', 'translateVoice','closeWindow','chooseVideo']);
        wx.ready(function() {
            wx.hideAllNonBaseMenuItem();
        });
    });

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });

    function getUserFinish(){
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()

    }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>

</html>
