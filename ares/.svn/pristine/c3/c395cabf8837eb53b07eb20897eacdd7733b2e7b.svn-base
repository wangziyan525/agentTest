<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0,viewport-fit=cover"
          name="viewport" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>西安银行</title>
    <link rel="stylesheet" href="../../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../../common/css/weui.min.css">
    <link rel="stylesheet" href="../../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="../css/rectify/rectifyList.css">
</head>
<body style="overflow: hidden">
<div id="app" style="overflow-y: hidden;height: 100%;display: none">
    <div class="topDiv">
        <div class="selectDiv">
            <div class="selectState" style="position: relative">
                <input class="weui-input" type="text" placeholder="请选择接收时间" v-model='receiveDate' @click="pickerdate('receiveDate')" readonly>
                <img src="../image/down.png" class="year">
            </div>
        </div>
        <div class="tab">
            <div :class="tab=='11'?'activeTab':''" @click="chooseTab('11')">待整改</div>
            <div :class="tab=='22'?'activeTab':''" @click="chooseTab('22')">整改中</div>
            <div :class="tab=='33'?'activeTab':''" @click="chooseTab('33')">审批中</div>
            <div :class="tab=='44'?'activeTab':''" @click="chooseTab('44')">整改完毕</div>
        </div>
    </div>
    <div class="listScroll" style="overflow-y: auto;margin-top: 10px">
        <van-list><!--v-model="paging.loading" :finished="paging.finished" :finished-text="paging.text"
            @load="onload"-->
            <div v-if="tabsDataList.length>0" v-for="(item, index) in tabsDataList">
                <div class="listParts" @click="jump(item)" style="margin-bottom: 10px">
                    <div class="containList" style="">
                        <div>
                            <div class="listLine" style="width: 100%">
                                <div style="font-size: 18px;font-weight: 600;width: 100%;overflow: hidden;white-space: nowrap;text-overflow: ellipsis">{{item.problemRecord?item.problemRecord:'--'}}</div>
                            </div>
                            <div class="listLine">
                                <div style="color: #9DA0A3;font-size: 14px;width: 100%" v-if="item.problemSource=='1'">问题来源: 经营支行自查</div>
                                <div style="color: #9DA0A3;font-size: 14px;width: 100%" v-if="item.problemSource=='2'">问题来源: 一级机构自查</div>
                                <div style="color: #9DA0A3;font-size: 14px;width: 100%" v-if="item.problemSource=='3'">问题来源: 一级机构抽查</div>
                                <div style="color: #9DA0A3;font-size: 14px;width: 100%" v-if="item.problemSource=='4'">问题来源: 总行抽查</div>
                            </div>
                        </div>
                        <div>
                            <div class="listLine">
                                <div v-if="item.currentStatus=='11'" style="color: #FF9430;width: 100%">待整改</div>
                                <div v-if="item.currentStatus=='22'" style="color: #267EF0;width: 100%">整改中</div>
                                <div v-if="item.currentStatus=='33'" style="color: #267EF0;width: 100%">审批中</div>
                                <div v-if="item.currentStatus=='44'" style="color: #44C966;width: 100%">整改完毕</div>
                            </div>
                        </div>
                    </div>
                    <div class="checkTime">
                        <div style="color: #9DA0A3;font-size: 14px;width: 100%">接收时间: {{item.receiveDate?item.receiveDate:'--'}}</div>
                    </div>
                </div>
            </div>
        </van-list>

        <div class="" v-if="moreStatus" @click="addMore()" style="color:#377ae6;text-align: center;padding-bottom: 10px;box-sizing: border-box;font-size: 15px">----点击加载更多----</div>
        <div class="" v-if="noMoreStatus" style="color:#999;text-align: center;padding-bottom: 10px;box-sizing: border-box;font-size: 15px">----没有更多数据了----</div>
        <div class="nodata" v-if="nodata">暂无数据</div>
    </div>
    <!--<div class="sendBtn"><div @click="jump()"><img src="../image/pen.png">检查任务下发</div></div>-->
    <!-- 时间选择器 -->
    <van-popup
            v-model="popupDataShow"
            position="bottom"
            :close-on-click-overlay="false">
        <van-datetime-picker
                v-model="currentDate"
                type="date"
                title="选择日期"
                @confirm="getTime"
                @cancel="closeTime"
        >
        </van-datetime-picker>
    </van-popup>
</div>


</body>
<script src="../../common/js/vue.min.js"></script>
<script src="../../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../../common/js/jquery.cookie_jq.js"></script>
<script src="../../common/js/watermark.js"></script>
<script type="text/javascript" src="../../common/js/jssdk.js"></script>
<script src="../../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="../js/rectify/rectifyList.js?v=2.1.0"></script>
<script type="text/javascript" src="../../common/js/vConsole.min.js"></script>
<script type="text/javascript">

    //var vConsole = new VConsole();

    //初始化微信社区
    $(function() {
        initJSSDK(['hideAllNonBaseMenuItem','chooseImage','uploadImage','downloadImage', 'startRecord', 'stopRecord', 'translateVoice','closeWindow']);
        wx.ready(function() {
            wx.hideAllNonBaseMenuItem();
        });
    });

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });

    function getUserFinish(){
        // 调用水印
        var username = $.parseJSON($.cookie("user")).name;
        __canvasWM({
            content: username
        });
        initFun()
    }

</script>
<script type="text/javascript" src="../../common/js/getUserInfo.js?v=202110229"></script>
</html>
