[v-cloak]{
    display: none;
}

html, body {
    min-height: 100vh;
    background-color: #f3f4f6;
}
.timeSelect{
    display: flex;
    align-items: center;
    background: #FFFFFF;
    font-family: PingFangSC-Regular;
    font-size: 15px;
    color: #3B3B3B;
    font-weight: 400;
    padding: 1.2% 4%;
   
}
.downPushImg{
    height: 14px;
    width: 14px;
    background-image: url('../images/downPush.png');
    background-size: contain;
    background-repeat: no-repeat;
}
.overDueTable{
    margin-top: 10px;
    background: #FFFFFF;
}
.tabArea{
    padding: 2px;
    border-bottom: 1px solid #f5f6f7;
}
.van-tab--active{
    font-family: PingFangSC-Medium; 
font-size: 14px;
color: #3B3B3B!important;
text-align: center;
font-weight: 500;
}
.van-tab{
    font-family: PingFangSC-Regular;
    font-size: 14px;
    color: #999999;
    text-align: center;
    font-weight: 400;
}
.van-tabs__line{
    background-color: #0465FF !important;
    width: 30px;
}
.custom-header{
    display: flex;
    /* justify-content: space-between; */
    padding: 9px 12px;
    width: 86%;
    background: #F5F6F7;
    margin:10px auto;
    font-family: PingFangSC-Regular;
font-size: 13px;
color: #999999;
font-weight: 400;
border-radius: 4px 4px 0px 0px;
}
.header-item{
    text-align: center;
    width: 18%;
}
.custom-btm{
    margin:12px; 
    padding: 12px;
    background: #FFFFFF   
}
.detailTitle{
    font-size: 15px;
color: #3B3B3B;
font-weight: 500;
line-height: 15px
}
.totalNum{
    font-size: 12px;
color: #0465FF;
line-height: 17px;
font-weight: 400;
margin: 0px 2px;
}
.detailTotalNum{
    font-size: 12px;
color: #999999;
line-height: 17px;
font-weight: 400;
padding: 5px 0px; 
}
.btm-table{
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #FFFFFF;
border: 1px solid rgba(245,246,247,1);
border-radius: 4px;
}
.detailListTitle{
    font-size: 13px;
color: #999999;
font-weight: 400;
width: 40%
}
.detailValue{
    font-size: 13px;
color: #3B3B3B;
font-weight: 400;
}
.detailList{
    padding: 10px 12px;
    margin-bottom: 10px
}
.listItem{
    display: flex;
    font-size: 13px;
color: #3B3B3B;
font-weight: 400;
width: 86%;
margin: 0 auto;
    
}
.listItem div{
    width: 18%;
    text-align: center;
} 
.detailListCol{
    display: flex;
    
}
.nodate{
    text-align: center;
    margin: 20px auto;
    font-size: 15px;
    color: #999999;
}
.noMessage{
    width:160px;
    margin: 50px auto 10px;
}
.noMessage>img{
    width:100%;
}