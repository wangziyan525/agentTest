.icon_contaniner {
    padding: 27px;
    background-color: #fff;
}


.icon_result {
    width: 103px;
}

.icon_result img {
    width: 100%;
}

.main_section {
    padding-top: 10px;
}

.main_section_item {
    border-radius: 4px;
    background-color: #fff;
    margin-bottom: 10px;
}

.main_section_item_header {
    background: #E6F5FF;
    border-radius: 4px 4px 0 0;
    padding: 10px;
}

.__item_list {
    padding: 14px 10px;
    border-top: 1px solid #f5f6f7;
}

.__item_list_left {
    margin-right: 10px;
    width: 120px;
}
.btn{
    /* position: fixed; */
    bottom: 0;
    width: 100%;
}
.btns{
    display: flex;
}

.submit{
    background: #377ae6;
    color: #fff;
    width: 90%;
    margin: 30px auto;
    padding: 15px;
    text-align: center;
    box-sizing: border-box;
}