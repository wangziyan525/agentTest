.main-container {

}

.tabs_container {
    height: 43px;
    background: #fff;
}

.tabs_container_item_active {
    position: relative;
    color: #3b3b3b !important;
}


.tabs_container_item_active::before {
    position: absolute;
    content: '';
    width: 100%;
    height: 2px;
    background-color: #0465FF;
    bottom: 0px;
    left: 0;
}

.main_section_container {
    padding: 12px;
}

.main_section_container_item {
    margin-bottom: 12px;
    background-color: #fff;
    border-radius: 4px;
    overflow: hidden;
}

.main_section_container_item_title {
    padding: 12px;
}

.main_section_container_item_content_item_title {
    min-width: 100px;
}

.main_section_container_item_content {
    padding: 5px 12px;
}

.main_section_container_item_content >.main_section_container_item_content_item {
    padding: 2px 0;
}


.null_data_box {
    height: 10rem;
    line-height: 10rem;
    text-align: center;
    font-size: 16px;
    color: #999;
}s

.more_container {
    height: 40px;
    width: 100%;
    text-align: center;
    line-height: 30px;
    font-size: 15px;
    color: #999;
}

.no_mare_container {
    height: 40px;
    width: 100%;
    text-align: center;
    line-height: 30px;
    font-size: 15px;
    color: #999;
}

.main_section {
    padding: 0 12px;
}

.sub_title {
    padding: 7px 0;
}

.sub_title span {
    font-family: PingFang-SC-Heavy;
    padding: 0 3px;
    color: #0465FF;
    font-size: 14px;
}

.main_container_item {
    position: relative;
    padding: 10px 18px 6px 12px;
    background-color: #fff;
    border-radius: 4px;
    margin-bottom: 10px;
}

._right_link::before {
    content: "";
    display: inline-block;
    height: 8px;
    width: 8px;
    border-width: 1px 1px 0 0;
    border-color: #999;
    border-style: solid;
    transform: matrix(.71,.71,-.71,.71,0,0);
    top: 50%;
    position: absolute;
    right: 15px;
}

.view_left {
    width: 80px;
}

.main_container_item >div {
    margin-bottom: 6px;
}

.view_right {
    word-wrap: break-word;
    flex-wrap: wrap;
    white-space: pre-wrap;
    word-break: break-all;
}

.noData{
    text-align: center;
    color: #000000;
    line-height:32px;
}
.noData img{
    width:55%;
    margin-top:20%;
}

.slide_container {
    margin: 10px 0;
    background-color: #fff;
}

.slide_container_item {
    height: 50px;
}


.banner_header_container {
    padding: 10px 20px;
}


.main_container {
    padding: 0 15px;
}

.main_content_item {
    border-radius: 6px;
    background-color: #fff;
    margin-bottom: 10px;
}

.main_content_item_header {
    padding: 10px 12px;
}

.__main_content_item {
    padding: 5px 12px;
    border-top: 1px solid #f5f6f7;
    border-bottom: 1px solid #f5f6f7;
}

.__main_content_item >div {
    padding: 5px 0;
}

.__main_content_view_left {
    margin-right: 10px;
}

.em1{
    border: 1px solid #32AF25;
    color: #32AF25;
}
 .em2{
    border: 1px solid #f90808;
    color: #f90808;
}
.em3{
    border: 1px solid #e0992d;
    color: #e0992d;
}