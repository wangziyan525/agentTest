<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>客户之声</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/index.css?v=1.0">
</head>
<body style="overflow: hidden">
    <div id="app" style="overflow-y: scroll;height: 100%;display:none">

        <div class="applyPart" v-for="(item,index) in common">
            <div class="topQuestion">
                <div class="questionNum">客户问题{{index+1}}</div>
                <div class="operationPart">
                    <div class="deletBtn"  @click="deleteQuestion(index)" v-if="index>0"><img src="images/delete.png" >删除</div>
                    <div class="addBtn"    @click="addQuestion"><img src="images/add.png">添加</div>
                </div>
            </div>
            <div>
                <div class="textAreaPart"  >
                    <div class="yuyun-box" @click="showRecorddiv(index)">
                        <img src="./images/yuyin.png " />可尝试语音输入
                    </div>
                    <div class="yuyinTextArea">
                        <van-field type="textarea" v-model="item.feedbackContent" rows="3" autosize placeholder="请输入" maxlength="300"></van-field>
                    </div>   
                </div>
                <div style="position: relative;">
                    <div class="recodeblock" @click="startRecord">
                        <img src="images/luyin.gif"> <div start="no" class="luyinbtn">开始说话</div>
                    </div>
                </div>
            </div>
            <div class="topQuestion">
                <div class="questionNum">上传图片</div>
            </div>
            <div class="imgUpload">
                <div class="hasImg" v-for="(itemImg,indexImg) in item.feedbackImageLocal">
                    <img :src="itemImg" class="uploadImg">
                    <img src="images/close.png" class="closeImg" @click="deleteImg(index,indexImg)">
                </div>
                <div class="hasImg" @click="afterRead(index)">
                    <img src="images/upload.png" class="uploadImg">
                </div>
            </div>
        </div>

        <div class="applyPart">
            <div class="baseLine selectChoose" @click="showPopup('deptName')" >
                <div>接收部门</div>
                <div>{{deptName?deptName:"请选择"}}</div>
            </div>
        </div>
        <div>
            <van-popup v-model="popupShow" position="bottom">
                <van-picker
                        show-toolbar
                        :columns="popupList"
                        @confirm="onConfirm"
                        @cancel="cancelPopup"
                >
                </van-picker>
            </van-popup>
        </div>
        <div style="height: 80px;"></div>
        <div class="footApply" >
            <div @click="appltBtn">
                提交
            </div>
        </div>
    </div>
</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="./../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/apply.js"></script>
<!-- <script src="../common/js/vConsole.min.js"></script> -->
<script type="text/javascript">
    // var vConsole = new VConsole();
    
    function getUserFinish(){
            initJSSDK(['hideAllNonBaseMenuItem','chooseImage','uploadImage','invoke','closeWindow']);

           wx.ready(function() {
               wx.hideAllNonBaseMenuItem();
               WeixinJSBridge.on('menu:setfont', function() {
                    WeixinJSBridge.invoke('setFontSizeCallback', { 'fontSize' : '0' });
                });

           });
           // 调用水印
           var username = $.parseJSON($.cookie("user")).name;
           __canvasWM({
               content: username
           });
           initFun()
    }
    // initFun()
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>