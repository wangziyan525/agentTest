<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>西安银行</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/index.css?v=2.0">
</head>
<body style="overflow: hidden">
    <div id="app" style="overflow-y: scroll;height: 100%;display:none">

        <div class="tabList">
            <div :class="status==''?'activeTab':''"  @click="chooseTab('')">全部</div>
            <div :class="status=='2'?'activeTab':''"  @click="chooseTab('2')">待确认</div>
            <div :class="status=='1'?'activeTab':''"  @click="chooseTab('1')">已通过</div>
            <div :class="status=='0'?'activeTab':''"  @click="chooseTab('0')">已驳回</div>
        </div>

        <div v-if="list.length>0">
            <div class="listContent" v-for="item in list" @click="goDetail(item.employeeMisconductChecklistId)">
                
                <div class="listLine">
                    <div>员工姓名：{{item.userName}}</div>
                </div>
                <div class="listLine">
                    <div>提交时间：{{item.createTime}}</div>
                </div>
                <div :class="['statusList', 'status'+item.status]">
                    {{statusOpt[item.status]}}
                </div>
            </div>
        </div>
        <div v-else class="nodate">
            <div class="noMessage">
                <img src="images/noMessage.png">
            </div>
            暂无数据
        </div>
        
    </div>
</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="./../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/list.js?v=2"></script>
<!-- <script src="../common/js/vConsole.min.js"></script> -->
<script type="text/javascript">
    // var vConsole = new VConsole();

    //ios页面回退不刷新
    window.addEventListener('pageshow',function (e) {
        if(e.persisted){
            location.reload();
        }
    });
    function getUserFinish(){
            initJSSDK(['hideAllNonBaseMenuItem','invoke','closeWindow']);

           wx.ready(function() {
               wx.hideAllNonBaseMenuItem();
               WeixinJSBridge.on('menu:setfont', function() {
                    WeixinJSBridge.invoke('setFontSizeCallback', { 'fontSize' : '0' });
                });

           });
           
           // 调用水印
           var username = $.parseJSON($.cookie("user")).name;
           __canvasWM({
               content: username
           });
           initFun()
    }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>