.container {
    /* background-color: #fff; */
}

.section_container {
    /* padding: 0 12px 12px; */
    position: sticky;
    z-index: 2;
    overflow: hidden;
    border-radius: 10px 10px 0px 0px;
}

.section_container_item {
    padding: 0 12px;
    background-color: #fff;
    margin-bottom: 12px;
}

.slide_header {
    padding: 12px 0;
}

.slide_content {
    background-color: #f5f6f7;
    border-radius: 6px;
    padding: 10px;
}

.slide_content_item {
    padding: 5px 0;
}

._slide_content_item {
    padding: 10px 0;
    margin-top: 5px;
    border-top: 1px solid #ddd;
}

._slide_content_item >.view_left {
    padding-bottom: 5px;
}

.photo_container {
    display: flex;
    flex-wrap: wrap;
    margin: -5px;
}

.photo_container >div {
    width: calc(25% - 10px);
    height: 20vw;
    background-color: #fff;
    margin: 5px;
    position: relative;
    overflow: hidden;
    border-radius: 4px;
}

.photo_container >div > div {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 20px;
    background-color: rgba(0, 0, 0, .6);
    color: #fff;
    display: flex;
    flex: 1;
    justify-content: center;
    align-items: center;
}

.photo_container >div img {
    width: 100%;
}

.header_fiexd_container {
    position: relative;
    z-index: 1;
}

.header_fiexd_container .header_content {
    position: absolute;
    background-color: #3975C6;
    height: 147px;
    width: 100%;
    left: 0;
    top: 0;
}

.header_container {
    padding: 24px 15px;
    position: sticky;
    z-index: 2;
    color: #fff;
}

.icon_img {
    width: 20px;
    height: 20px;
    margin-right: 6px;
}

.icon_img img {
    width: 100%;
}

.header_container_text {
    padding-left: 26px;
    margin-top: 1px;
    font-weight: 400;
}


.popup_bottom_container {
    padding: 0 12px;
    background-color: #f6f6f6;
}

.popup_bottom_header {
    height: 62px;
    position: relative;
}

.popup_bottom_header_title {
    width: 100%;
    display: flex;
    height: 62px;
    justify-content: center;
    align-items: center;
}
.cancel_container {
    position: absolute;
    right: 0;
    top: 20px;
    color: #1482FF;
}

.popup_bottom_footer {
    padding: 20px 10px;
}


.popup_bottom_footer > div {
    background: #267EF0;
    color: #fff;
    border: 1px solid #267EF0;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
}
