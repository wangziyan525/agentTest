

[v-cloak]{
  display: none!important;
}
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background-color: #f5f5f5;
    min-height: 100vh;
  }

  #app {
    min-height: 100vh;
    padding-bottom: 80px;
  }

  /* 搜索区域 */
  .search-wrapper {
    background: #fff;
    padding: 12px 16px;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 20px;
    padding: 8px 12px;
  }

  .search-box .van-icon {
    color: #999;
    margin-right: 8px;
  }

  .search-box input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 14px;
    outline: none;
    color: #333;
  }

  .search-box input::placeholder {
    color: #999;
  }

  .search-btn {
    background: #4A90E2;
    color: #fff;
    border: none;
    border-radius: 16px;
    padding: 6px 16px;
    font-size: 14px;
    margin-left: 10px;
    cursor: pointer;
  }

  /* Tab 切换 */
  .tab-wrapper {
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  .tabs {
    display: flex;
  }

  .tab-item {
    flex: 1;
    text-align: center;
    padding: 14px 0;
    font-size: 16px;
    color: #333;
    position: relative;
    cursor: pointer;
    transition: color 0.3s;
  }

  .tab-item.active {
    color: #4A90E2;
    font-weight: 500;
  }

  .tab-item.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 3px;
    background: #4A90E2;
    border-radius: 2px;
  }

  /* 列表区域 */
  .list-wrapper {
    padding: 12px;
    /* min-height: calc(100vh-180px); */
    padding-bottom: 90px;
  }

  /* 卡片样式 */
  .customer-card {
    background: #fff;
    border-radius: 8px;
    margin-bottom: 12px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 16px 0px 16px;
    /* border-bottom: 1px solid #f5f5f5; */
  }

  .card-header .name {
    font-size: 16px;
    font-weight: 600;
    color: #333;
    flex: 1;
  }

  .card-header .arrow {
    color: #ccc;
    font-size: 16px;
  }

  .card-header .status {
    font-size: 14px;
    margin-right: 4px;
  }

  .card-header .status.pending {
    color: #4A90E2;
  }

  .card-header .status.connected {
    color: #4A90E2;
  }

  .card-header .status.rejected {
    color: #F56C6C;
  }

  .card-header .status.approved {
    color: #67C23A;
  }

  .card-body {
    padding: 12px 16px;
  }

  .info-row {
    display: flex;
    font-size: 14px;
    line-height: 1.8;
    color: #666;
  }

  .info-row .label {
    color: #999;
    width: 90px;
    flex-shrink: 0;
  }

  .info-row .value {
    color: #666;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-top: 1px solid #f5f5f5;
  }

  .phone-info {
    font-size: 14px;
    color: #666;
    flex:1
  }

  .phone-info .label {
    color: #999;
  }
  .assign{
    background: #267EF0;
  border-radius: 6px;
  font-family: PingFangSC-Regular;
  font-size: 14px;
  color: #FFFFFF;
  text-align: center;
  font-weight: 400;
  padding: 5px 30px;
  }
  .assign-btn {
    background: #4A90E2;
    color: #fff;
    border: none;
    border-radius: 20px;
    padding: 8px 28px;
    font-size: 14px;
    cursor: pointer;
  }

  /* 底部固定按钮 */
  .bottom-btn-wrapper {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px 20px;
    background: #fff;
  }

  .bottom-btn {
    width: 100%;
    background: #4A90E2;
    color: #fff;
    border: none;
    border-radius: 24px;
    padding: 14px 0;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .bottom-btn .van-icon {
    margin-right: 6px;
    font-size: 18px;
  }

  /* 空状态 */
  .empty-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 0;
    color: #999;
    min-height: 400px;
  }

  .empty-icon {
    width: 120px;
    height: 120px;
    margin-bottom: 20px;
  }

  .empty-icon svg {
    width: 100%;
    height: 100%;
  }

  .empty-text {
    font-size: 16px;
    color: #999;
  }
  .status.success {
    color: #52C41A;
  }

  .status.processing {
    color: #1890FF;
  }

  .status.warning {
    color: #FA8C16;
  }
  .status.fail {
    color: #FF4D4F;
  }
  .managerIcon{
    height: 16px;
    width: 14px;
    margin-right: 5px
  }