<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>农户建档</title>
    <link rel="stylesheet" href="../common/css/vant-2.12.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/weui.min.css">
    <link rel="stylesheet" href="../common/css/jquery-weui.min.css">
    <link rel="stylesheet" href="css/index.css?v=4.0">
</head>
<body style="overflow: hidden">
    <div id="app" style="overflow-y: scroll;height: 100%;display:none">
        <div v-if="page=='page0'">
            <div class="contentPart">
                <div class="contentLine contentLineRight selectChoose" @click="toPage('page1')">
                    <div>家庭基本信息</div>
                    <div v-if="ifView1=='全部待填写'" style="color: #4675C9;">{{ifView1}}</div>
                    <div v-else>{{ifView1}}</div>
                </div>
                <div class="contentLine contentLineRight selectChoose" @click="toPage('page2')">
                    <div>融资需求与负债</div>
                    <div v-if="ifView2=='全部待填写'" style="color: #4675C9;">{{ifView2}}</div>
                    <div v-else>{{ifView2}}</div>
                </div>
                <div class="contentLine contentLineRight selectChoose" @click="toPage('page3')">
                    <div>经营情况</div>
                    <div v-if="ifView3=='全部待填写'" style="color: #4675C9;">{{ifView3}}</div>
                    <div v-else>{{ifView3}}</div>
                </div>
            </div>
            <div class="contentPart">
                <div class="contentChoose">
                    <div class="chooseTitle">客户需求<span class="warnSpan">*</span></div>
                    <div class="choosePart">
                        <div class="chooseOne" style="width: 50%;"  v-for="item in chooseList1" @click="multipleChoose('AcctMrk',item.value)">
                            <img :src="detail.AcctMrk && detail.AcctMrk.indexOf(item.value)!==-1?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    <div class="textAreaPart" v-if="detail.AcctMrk && detail.AcctMrk.indexOf('4')!==-1">
                        <van-field type="textarea" @blur="localStrongFun()" v-model="detail.AcctMrkDsc" rows="2" autosize placeholder="如客户有工资代发、信用卡、贵金属等需求，不少于10个汉字才可申报有效" maxlength="100"></van-field>
                    </div>
                </div>
            </div>
            <div class="contentPart">
                <div class="contentChoose">
                    <div class="chooseTitle">备注</div>
                    <div class="textAreaPart">
                        <van-field type="textarea" @blur="localStrongFun()" v-model="detail.Rak" rows="4" autosize placeholder="请输入其他情况，如征信情况、我行账户开立情况等" maxlength="150"></van-field>
                    </div>
                </div>
                <div style="position: relative;">
                    <div class="record">
                        <div @click="showRecorddiv('Rak')">
                            <img src="images/voice.png" class="voice">
                        </div>
                    </div>
                    <div class="recodeblock" @click="startRecord()">
                        <img src="images/luyin.gif"> <div start="no" class="luyinbtn">开始说话</div>
                    </div>
                </div>
            </div>
    
            
            <div v-if="ifAdd=='1'">
                <div class="applyButton"  @click="submits">
                    <div >提交</div>
                </div>
                <div class="cancelButton"  @click="resetBut">
                    <div >重新建档</div>
                </div>
            </div>
            <div class="toSubmit" v-else>
                <div @click="deletes">删除</div>
                <div @click="submits">提交</div>
            </div>
            <div class="warnText">
                <div>1、建档提交后除了定位信息，其余仍可进行修改。</div>
                <div>2、*号内容为建档阶段必须采集字段。</div>
                <div>3、有效建档客户认定标准：</div>
                <div>
                    <div>（1）建档过程中“基本信息”及“经营情况”两部分收集字段不少于60%。</div>
                    <div>（2）建档过程中“客户需求”必须勾选，若选择为“其他”，需输⼊客户对其他⾦融产品的需求，不少于10个汉字。</div>
                    <div>（3）建档过程中必须收集到农户的经营地址、经营场所照⽚、联系⼈电话。
                        上述三个要求均满⾜，才可算有效建档客户。</div>
                </div>
            </div>
        </div>

        <div v-if="page=='page1'">
            <div class="contentPart">
                <div class="contentChoose borderLine">
                    <div class="chooseTitle regetAddress">
                        <div>家庭地址<span  class="warnSpan">*</span></div>
                        <div class="getAddress" @click="getAdess" v-if="!ifreadonly">重新定位</div>
                    </div>
                    <div class="textAreaPart">
                        <van-field type="textarea" @blur="localStrongFun()"  v-model="detail.EntpCorpAdr" readonly rows="2" autosize placeholder="请输入" maxlength="150"></van-field>
                    </div>
                </div>
                <div class="contentLine">
                    <div class="textTitle">所属村镇<span class="warnSpan">*</span></div>
                    <div class="inputLine">                        
                        <van-field  @blur="localStrongFun()" v-model="detail.AtchRural"  rows="1" readonly placeholder="请输入" maxlength="100" center></van-field>
                    </div>
                </div>
                
                
            </div>
            <!-- <div class="contentPart">
                <div class="contentLine selectChoose">
                    <div class="chooseTitle">省市区<span class="warnSpan">*</span></div>
                    <div v-if="detail.Province"  style="color:#000">{{detail.Province}}-{{detail.City}}-{{detail.District}}</div>
                </div>
            </div>
            <van-popup v-model="showAreaPicker" position="bottom">
                <van-area
                        title="选择省市区"
                        :area-list="areaList"
                        value="610100"
                        @confirm="areaConfirm"
                        @cancel="showAreaPicker=false"
                >
                </van-area>
            </van-popup> -->
            <div class="contentPart">
                <div class="contentChoose borderLine">
                    <div class="chooseTitle imgWarn">经营照片<span class="imgWarnSpan">（拍摄种植、养殖等主业经营照片）</span></div>
                    <div class="imgUpload">
                        <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal1">
                            <img :src="itemImg" class="uploadImg">
                            <img src="images/close.png" class="closeImg" @click="deleteImg(indexImg,'1')">
                        </div>
                        <div class="hasImg" @click="afterRead('1')" v-if="imageLocal1.length<1">
                            <img src="images/upload.png" class="uploadImg">
                        </div>
                    </div>
                </div>
                <div class="contentChoose">
                    <div class="chooseTitle imgWarn">房屋照片<span class="imgWarnSpan">（房屋全貌、门头门牌号、入户院子照片等）</span></div>
                    <div class="imgUpload">
                        <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal2">
                            <img :src="itemImg" class="uploadImg">
                            <img src="images/close.png" class="closeImg" @click="deleteImg(indexImg,'2')">
                        </div>
                        <div class="hasImg" @click="afterRead('2')" v-if="imageLocal2.length<1">
                            <img src="images/upload.png" class="uploadImg">
                        </div>
                    </div>
                </div>

                <!-- <div class="contentChoose">
                    <div class="chooseTitle imgWarn">双人合照<span class="warnSpan">*</span><span class="imgWarnSpan">（被访谈人与访谈员工半身合照；最多一张）</span></div>
                    <div class="imgUpload">
                        <div class="hasImg" v-for="(itemImg,indexImg) in imageLocal3">
                            <img :src="itemImg" class="uploadImg">
                            <img src="images/close.png" class="closeImg" @click="deleteImg(indexImg,'3')">
                        </div>
                        <div class="hasImg" @click="afterRead('3')" v-if="imageLocal3.length<1">
                            <img src="images/upload.png" class="uploadImg">
                        </div>
                    </div>
                </div> -->
                
            </div>

            <div class="contentPart">
                <div class="contentLine">
                    <div class="textTitle">户主姓名<span class="warnSpan">*</span></div>
                    <div class="inputLine">                        
                        <van-field  @blur="localStrongFun()" v-model="detail.EntpCtcManNm" rows="1" placeholder="请输入" maxlength="6" center></van-field>
                    </div>
                </div>
                <div class="contentLine">
                    <div class="textTitle">身份证号码 </div>
                    <div class="inputLine">                        
                        <van-field  @blur="checkInput('EstbDocManIdentNum')" v-model="detail.EstbDocManIdentNum" rows="1" placeholder="请输入" maxlength="18" center></van-field>
                    </div>
                </div>
                <div class="contentLine">
                    <div class="textTitle">户主联系方式</div>
                    <div class="inputLine">                        
                        <van-field type="tel"  @blur="checkInput('EntpCtcManTelNum')" v-model="detail.EntpCtcManTelNum" rows="1" placeholder="请输入" maxlength="11" center></van-field>
                    </div>
                </div>
                <div class="contentLine">
                    <div class="textTitle">家庭常住人口（人）</div>
                    <div class="inputLine">                        
                        <van-field type="digit"   @blur="localStrongFun()" v-model="detail.FamNrlRsdnPpn" rows="1" placeholder="请输入" maxlength="10" center></van-field>
                    </div>
                </div>
                <div class="contentLine">
                    <div class="textTitle">家庭劳动力（人）</div>
                    <div class="inputLine">                        
                        <van-field type="digit"  @blur="localStrongFun()" v-model="detail.FamWrkPpn" rows="1" placeholder="请输入" maxlength="10" center></van-field>
                    </div>
                </div>
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">主要务农人员年龄</div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList143" @click="singChoose('MainRfrFrmPsnlAge',item.value)">
                            <img :src="item.value==detail.MainRfrFrmPsnlAge?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                </div>
                <div class="contentChoose borderLine">
                    <div class="chooseTitle imgWarn">职务<span class="imgWarnSpan">（多选）</span></div>
                    <div class="choosePart">
                        <div class="chooseOne" style="width: 50%;" v-for="item in chooseList153" @click="multipleChoose('Pstn',item.value)">
                            <img :src="detail.Pstn && detail.Pstn.indexOf(item.value)!==-1?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    
                </div>
                <!-- <div class="contentChoose">
                    <div class="chooseTitle">是否光伏户</div>
                    <div class="choosePart">
                        <div class="choosePart">
                            <div class="chooseOne" v-for="item in chooseList19" @click="singChoose('MANAGERNO',item.value)">
                                <img :src="item.value==detail.MANAGERNO?'images/choose.png':'images/unchoose.png'">
                                <div>{{item.text}}</div>
                            </div>
                        </div>
                    </div>
                </div> -->
               
            </div>

            <div class="contentPart">
                <div class="contentLine">
                    <div class="textTitle">推荐人姓名</div>
                    <div class="inputLine">                        
                        <van-field  @blur="localStrongFun()" v-model="detail.RecManNm" rows="1" placeholder="请输入" maxlength="6" center></van-field>
                    </div>
                </div>
                <div class="contentLine">
                    <div class="textTitle">推荐人联系方式</div>
                    <div class="inputLine">                        
                        <van-field type="tel"   @blur="checkInput('RecManCtcWay')" v-model="detail.RecManCtcWay" rows="1" placeholder="请输入" maxlength="11" center></van-field>
                    </div>
                </div>
            </div>
            
            <div class="applyButton" @click="toPage('page0')">
                <div>返回</div>
            </div>
        </div>

        <div v-if="page=='page2'">
            <div class="contentPart">
                <div class="contentChoose borderLine">
                    <div class="chooseTitle imgWarn">资金用途<span class="imgWarnSpan">（多选）</span></div>
                    <div class="choosePart">
                        <div class="chooseOne" style="width: 50%;"  v-for="item in chooseList43" @click="multipleChoose('TchPps',item.value)">
                            <img :src="detail.TchPps && detail.TchPps.indexOf(item.value)!==-1?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    <div class="textAreaPart" v-if="detail.TchPps && detail.TchPps.indexOf('10')!==-1">
                        <van-field type="textarea" @blur="localStrongFun()" v-model="detail.TchPpsDsc" rows="1" autosize placeholder="请输入所属行业描述" maxlength="100"></van-field>
                    </div>
                </div>
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">希望多久可以拿到贷款</div>
                    <div class="choosePart">
                        <div class="choosePart">
                            <div class="chooseOne" v-for="item in chooseList5" @click="singChoose('ExpcTrm',item.value)">
                                <img :src="item.value==detail.ExpcTrm?'images/choose.png':'images/unchoose.png'">
                                <div>{{item.text}}</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">利率接受范围</div>
                    <div class="choosePart">
                        <div class="choosePart">
                            <div class="chooseOne" v-for="item in chooseList6" @click="singChoose('IntRtAcptScop',item.value)">
                                <img :src="item.value==detail.IntRtAcptScop?'images/choose.png':'images/unchoose.png'">
                                <div>{{item.text}}</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="contentChoose">
                    <div class="chooseTitle">期望额度</div>
                    <div class="choosePart">
                        <div class="choosePart">
                            <div class="chooseOne" v-for="item in chooseList73" @click="singChoose('ExptLmt',item.value)">
                                <img :src="item.value==detail.ExptLmt?'images/choose.png':'images/unchoose.png'">
                                <div>{{item.text}}</div>
                            </div>
                        </div>
                    </div>
                </div>
               
            </div>
            <div class="contentPart">
                <!-- <div class="contentLine">
                    <div class="textTitle">法定代表人持股比例</div>
                    <div class="inputLine">                        
                        <van-field  @blur="localStrongFun()" v-model="detail.LglRprsShrhldRto" rows="1" placeholder="请输入" maxlength="10" center></van-field>
                    </div>
                </div>
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">法定代表人负债情况</div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList8" @click="singChoose('LglRprsLbyCcst',item.value)">
                            <img :src="item.value==detail.LglRprsLbyCcst?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    
                </div> -->
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">负债情况</div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList102" @click="singChoose('LglRprsLbyCcst',item.value)">
                            <img :src="item.value==detail.LglRprsLbyCcst?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    
                </div>
                <div class="contentChoose ">
                    <div class="chooseTitle imgWarn">负债类型<span class="imgWarnSpan">（多选）</span></div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList93" @click="multipleChoose('LglRprsLbyTp',item.value)">
                            <img :src="detail.LglRprsLbyTp && detail.LglRprsLbyTp.indexOf(item.value)!==-1?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    
                </div>
                
            </div>

            <div class="applyButton" @click="toPage('page0')">
                <div>返回</div>
            </div>
        </div>

        <div v-if="page=='page3'">
            <div class="contentPart">
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">主业类型</div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList163" @click="singChoose('MainBsnTp',item.value)">
                            <img :src="item.value==detail.MainBsnTp?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    <div class="textAreaPart" v-if="detail.MainBsnTp=='5'">
                        <van-field type="textarea" @blur="localStrongFun()" v-model="detail.OthrDsc" rows="1" autosize placeholder="请输入所属行业描述" maxlength="150"></van-field>
                    </div>
                </div>

                <div v-if="detail.MainBsnTp=='1'">
                    <div class="contentLine">
                        <div class="textTitle">种植主品种</div>
                        <div class="inputLine">                        
                            <van-field  @blur="localStrongFun()" v-model="detail.PltMainVry" rows="1" placeholder="请输入" maxlength="50" center></van-field>
                        </div>
                    </div>
                    <div class="contentLine">
                        <div class="textTitle">种植年收入（元）</div>
                        <div class="inputLine">                        
                            <van-field  type="number" @blur="localStrongFun()" v-model="detail.PltYrIncm" rows="1" placeholder="请输入" maxlength="12" center></van-field>
                        </div>
                    </div>
                    <div class="contentLine">
                        <div class="textTitle">种植面积</div>
                        <div class="inputLine">                        
                            <van-field  type="number" @blur="localStrongFun()" v-model="detail.PltArea" rows="1" placeholder="请输入" maxlength="12" center></van-field>
                        </div>
                    </div>
                </div>

                <div v-if="detail.MainBsnTp=='2'">
                    <div class="contentLine">
                        <div class="textTitle">养殖种类</div>
                        <div class="inputLine">                        
                            <van-field  @blur="localStrongFun()" v-model="detail.BredVrty" rows="1" placeholder="请输入" maxlength="50" center></van-field>
                        </div>
                    </div>
                    <div class="contentLine">
                        <div class="textTitle">养殖年收入（元）</div>
                        <div class="inputLine">                        
                            <van-field  type="number"  @blur="localStrongFun()" v-model="detail.BredYrIncm" rows="1" placeholder="请输入" maxlength="12" center></van-field>
                        </div>
                    </div>
                    <div class="contentLine">
                        <div class="textTitle">养殖数量</div>
                        <div class="inputLine">                        
                            <van-field  type="digit" @blur="localStrongFun()" v-model="detail.BredQnty" rows="1" placeholder="请输入" maxlength="12" center></van-field>
                        </div>
                    </div>
                </div>

                
               
                
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">合作模式</div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList173" @click="singChoose('CoOprtMod',item.value)">
                            <img :src="item.value==detail.CoOprtMod?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    
                </div>
                <div class="contentChoose borderLine">
                    <div class="chooseTitle">销售渠道</div>
                    <div class="choosePart">
                        <div class="chooseOne" v-for="item in chooseList183" @click="singChoose('SaleCnl',item.value)">
                            <img :src="item.value==detail.SaleCnl?'images/choose.png':'images/unchoose.png'">
                            <div>{{item.text}}</div>
                        </div>
                    </div>
                    
                </div>
                
            </div>
            <div class="applyButton" @click="toPage('page0')">
                <div>返回</div>
            </div>
        </div>
    </div>
</body>
<script src="../common/js/vue.min.js"></script>
<script src="../common/js/vant-2.12.min.js"></script>
<script type="text/javascript" src="../common/js/base.js?v=202110220"></script>
<script type="text/javascript" src="../common/js/jquery-2.1.3.min.js"></script>
<script type="text/javascript" src="../common/js/jquery-weui.min.js"></script>
<script type="text/javascript" src="../common/js/jquery.cookie_jq.js"></script>
<script src="../common/js/watermark.js"></script>
<script type="text/javascript" src="../common/js/jssdk.js"></script>
<script src="./../common/js/server.js?v=20211022"></script>
<script type="text/javascript" src="js/dataJson.js"></script>
<script type="text/javascript" src="js/idCardCheck.js"></script>
<script type="text/javascript" src="js/city.js"></script>
<script type="text/javascript" src="https://webapi.amap.com/maps?v=1.4.1&key=39943d0dc65e4472c2f4430a0e281682"></script>
<script type="text/javascript" src="js/farmerDetail.js?v=5.1"></script>

<!-- <script src="../common/js/vConsole.min.js"></script> -->
<script type="text/javascript">
    // var vConsole = new VConsole();
    
    function getUserFinish(){
        initJSSDK(['hideAllNonBaseMenuItem','chooseImage','uploadImage',"stopRecord","startRecord","translateVoice",'invoke','closeWindow']);

           wx.ready(function() {
               wx.hideAllNonBaseMenuItem();
               WeixinJSBridge.on('menu:setfont', function() {
                    WeixinJSBridge.invoke('setFontSizeCallback', { 'fontSize' : '0' });
                });

           });
           // 调用水印
           var username = $.parseJSON($.cookie("user")).name;
           __canvasWM({
               content: username
           });
           initFun()
    }
</script>
<script type="text/javascript" src="../common/js/getUserInfo.js"></script>
</html>