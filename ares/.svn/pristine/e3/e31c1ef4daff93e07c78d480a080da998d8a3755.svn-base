[v-cloak]{
  display: none;
}
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  min-height: 100vh;
  overflow-x: hidden;
}

/* 顶部导航 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88px;
  background: linear-gradient(to right, #1989fa, #47a7ff);
  padding-top: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.nav-back {
  position: absolute;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  margin-top: 22px;
  color: #fff;
  font-size: 20px;
}

.nav-title {
  color: #fff;
  font-size: 17px;
  font-weight: 500;
}

/* 内容区域 */
.content {
  /* padding-top: 88px; */
}

/* 分隔条 */
.section-gap {
  height: 10px;
  background-color: #f5f5f5;
}

/* 区块样式 */
.section-block {
  background-color: #fff;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #eee;
}

.section-header.no-toggle {
  justify-content: flex-start;
}

.section-title {
  font-size: 16px;
  color: #272727;
  font-weight: 500;
}

.section-toggle {
  display: flex;
  align-items: center;
  gap: 4px;
  color: #1989fa;
  font-size: 14px;
}

.section-toggle img {
  width: 14px;
  height: 14px;
}

/* 信息行 */
.section-content {
  padding: 0 16px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #eee;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 14px;
  color: #333;
}

.info-value {
  font-size: 14px;
  color: #333;
}

/* 限额详情卡片 */
.limit-card {
  padding: 0 16px 16px;
}

.limit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background-color: #f5f5f5;
  border-radius: 8px;
  margin-bottom: 10px;
}

.limit-row:last-child {
  margin-bottom: 0;
}

.limit-label {
  font-size: 14px;
  color: #333;
}

.limit-value {
  font-size: 14px;
  color: #FF353B;
  font-weight: 500;
}

/* 补充材料 */
.material-section {
  padding: 0 16px 16px;
}

.material-title {
  font-size: 14px;
  color: #333;
  padding: 14px 0;
  border-bottom: 1px solid #eee;
}

.material-list {
  display: flex;
  gap: 16px;
  padding-top: 16px;
  flex-wrap: wrap;
}

.material-item-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.material-item {
  width: 80px;
  height: 80px;
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}

.material-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.material-view {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 12px;
  text-align: center;
  padding: 4px 0;
}

.material-name {
  font-size: 12px;
  color: #999;
  margin-top: 6px;
}

/* 底部占位 */
.bottom-space {
  height: 100px;
  background-color: #f5f5f5;
}

/* 底部按钮 */
.bottom-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  background-color: #fff;
  display: flex;
  gap: 12px;
}

.btn-refuse,
.btn-reject,
.btn-approve {
  flex: 1;
  height: 44px;
  border-radius: 22px;
  font-size: 15px;
  cursor: pointer;
}

.btn-refuse {
  background-color: #fff;
  color: #1989fa;
  border: 1px solid #1989fa;
}

.btn-reject {
  background-color: #fff;
  color: #1989fa;
  border: 1px solid #1989fa;
}

.btn-approve {
  background-color: #1989fa;
  color: #fff;
  border: none;
}

.btn-refuse:active,
.btn-reject:active,
.btn-approve:active {
  opacity: 0.8;
}

/* 底部弹窗遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

/* 底部弹窗 */
.popup-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  border-radius: 16px 16px 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
}

.popup-wrap.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16px;
  position: relative;
}

.popup-title {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.popup-cancel {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 15px;
  color: #1989fa;
}

.popup-content {
  padding: 0 16px;
}

.popup-input {
  width: 100%;
  padding: 0 16px;
  border: none;
  background-color: #f5f5f5;
  border-radius: 8px;
  font-size: 15px;
  color: #333;
  outline: none;
}

.popup-input::placeholder {
  color: #999;
}

.popup-footer {
  padding: 20px 16px 34px;
}

.popup-btn {
  width: 100%;
  height: 48px;
  background-color: #1989fa;
  border: none;
  border-radius: 24px;
  font-size: 16px;
  color: #fff;
  cursor: pointer;
}

.popup-btn:active {
  opacity: 0.8;
}
.borderNone{
  border-bottom:none
}