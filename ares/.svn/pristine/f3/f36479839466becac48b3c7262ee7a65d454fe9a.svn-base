}
.ssabmTitle{
    width: 92%;
    padding: 10px;
    box-sizing: border-box;
    font-size: 15px;
    color: #267EF0;
    font-weight: 400;
    padding: 10px 10px 0 10px;
}
.stationList{
    width: 94%;
    position: relative;
    background: #FFFFFF;
    border-radius: 4px;
    margin: 10px auto;
    padding: 0 10px;
    box-sizing: border-box;
}
.firstTopLine{
    position: relative;
    padding-right: 20px;
    font-size: 16px;
    color: #000000;
    font-weight: 600;
    padding: 10px 20px 10px 0;
    border-bottom: 1px solid  #E6E7E8;
}
.firstTopLineNew{
    position: relative;
    padding-right: 20px;
    font-size: 16px;
    color: #000000;
    font-weight: 600;
    padding: 10px 20px 10px 0;
    border-bottom: 1px solid  #E6E7E8;
}
.firstTopLine:after{
    content: " ";
    display: inline-block;
    height: 6px;
    width: 6px;
