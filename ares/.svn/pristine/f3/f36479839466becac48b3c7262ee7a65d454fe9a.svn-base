}
.chooseSsbm{
    color: #267EF0 !important;
    background: #EFF6FF !important;
    border: 1px solid rgba(38,126,240,1) !important;
}
::-webkit-scrollbar{
    display: none;
}
.rankList{
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #fff;
    margin-top: 10px;
}
.rankList>div{
    overflow-x: scroll;
}
.rankPart{
    position: relative;
    width: 530px;
    padding: 10px;
    box-sizing: border-box;
    text-align: center;
    display: flex;
    font-size: 15px;
    color: #333333;
    font-weight: 400;
    align-items: center;
}
.rankPartNew{
    width: 820px;
}
.rankTitle{
    font-size: 15px;
    color: #9B9B9B;
    font-weight: 400;
}
.rankContent{
    border-top: 1px solid rgba(235,235,235,1);
    border-bottom: 1px solid rgba(235,235,235,1);
    width: 530px;
}
.rankContentNew{
    width: 820px;
}
.rankIndex{
    width: 50px;
}
.ssabmName{
    width: 120px;
}
.ssabmName>div:nth-of-type(1){
    font-size: 12px;
    color: #9B9B9B;
}
.ssabmName>div:nth-of-type(2){
    color: #333333;
}
.jdTotal{
    width: 120px;
}
.validNum{
    width: 120px;
}
.validRate{
    width: 160px;
    
}
.numberText{
    font-size:16px ;
}
.userType{
    width: 100px;
}

.moreText{
    text-align:center;
    color:#888;
    font-size: 13px;
    padding: 10px 0;
}
.moreText>div{
    position: relative;
    display: inline-block;
}
.moreText>div:after{
    content: " ";
    display: inline-block;
    height: 6px;
    width: 6px;
    border-width: 0 2px 2px 0;
    border-color: #c8c8cd;
    border-style: solid;
    -webkit-transform: matrix(.71,.71,-.71,.71,0,0);
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: -2px;
    position: absolute;
    top: 50%;
    margin-top: -6px;
    right: -16px;
}
.rank2decoration{
