* {
    font-family: "Arial", "Microsoft YaHei", sans-serif;
}
html,body {
    padding: 0;
    margin: 0;
    /*list-style-type: none;*/
    /*-webkit-overflow-scrolling:touch;*/
    /*-webkit-tap-highlight-color: rgba(0,0,0,0);*/
    width: 100%;
    overflow-x: hidden;
    min-height: 100vh;
    font-size: 15px;
    list-style-type: none;
    background: #F5F6F7;
}
[v-cloak]{
    display: none;
}
.van-picker-column__item--selected, .van-picker-column__item--selected .van-ellipsis {
    color: #267EF0 !important;
}
.van-dialog__confirm, .van-dialog__confirm:active {
    color: #267EF0;
}
.van-dialog__header--isolated {
    padding: 32px 12px;
}
.weui-dialog__hd {
    padding: 2.3em 1.6em 2em;
}
.weui-dialog__btn{
    color: #267EF0 !important;
}
.van-picker__confirm {
    color: #267EF0;
}
.color999 {
    color: #999 !important;
}
/* 
::-webkit-input-placeholder {
    color:  #999 !important;
    font-size: 17px;
}

::-moz-placeholder {
    color:  #999 !important;
    font-size: 17px;
}

::-moz-placeholder {
    color:  #999 !important;
    font-size: 17px;
}

:-ms-input-placeholder {
    color:  #999 !important;
    font-size: 17px;
} */
::placeholder {
    color: #9DA0A3 !important;
    font-size: 17px;
}
.van-cell {
    padding: 0;
    font-size: 17px;
}
.van-field__control{
    text-align: right;
    overflow: hidden;
}
.van-field__control:disabled{
    -webkit-text-fill-color:#000 !important;
}
.van-field__control[type=search] {
    text-align: left !important;
}
.van-search__action>div:nth-of-type(1){
    background: #267EF0;
    border-radius: 4px;
    font-size: 15px;
    font-family: PingFangSC-Regular,PingFang SC;
    font-weight: 400;
    color: rgba(255,255,255,1);
    padding: 0 10px;
}
.van-dialog{
    border-radius:6px;
}
.indexOne{
    position: relative;
    width: 94%;
    margin: 16px auto;
    padding: 20px 20px 20px 20px;
    background: rgba(255,255,255,0.90);
    border-radius: 8px;
    font-size: 17px;
    color: #000000;
    font-weight: 400;
    display: flex;
    box-sizing: border-box;
    align-items: center;
}
.indexOne>img{
    width:44px;
    height: 44px;
    margin-right: 12px;
}
.footTab{
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: #FFFFFF;
    padding-bottom: constant(safe-area-inset-bottom);
    padding-bottom: env(safe-area-inset-bottom);
    box-sizing: border-box;
    display: flex;
    padding: 6px 0;
    padding-bottom: 20px;
}
.footOne{
    flex: 1;
    text-align: center;
    font-size: 10px;
    color: #383B43;
    text-align: center;
    font-weight: 400;

}
.footOne>img{
    width: 21px;
    vertical-align: middle;
    padding: 4px 0;
}
.choosetab{
    font-size: 10px;
    color: #267EF0;
}
.dataList{
    position: relative;
    background-image: linear-gradient(180deg, rgba(255,255,255,0.90) 0%, #FFFFFF 100%);
    border-radius: 8px;
    width: 94%;
    background: #fff;
    padding: 16px 10px;
    box-sizing: border-box;
    margin: 10px auto;
}
.dataTitle{
    font-size: 16px;
    color: #000000;
    font-weight: 600;
}
.gradeChoose{
    position: relative;
    width: 100%;
    display: flex;
    border-bottom: 1px solid #e1e1e1;
    margin: 0 -6px;
}
.gradeChoose>div{
    background: #F6F6F6;
    border-radius: 3px;
    font-size: 15px;
    color: #626262;
    font-weight: 400;
    margin: 10px 6px;
    text-align: center;
    padding: 2px 6px;
    border: 1px solid #F6F6F6 !important;
}
.chooseItem{
    color: #267EF0 !important;
    background: #EFF6FF !important;
    border: 1px solid rgba(38,126,240,1) !important;
    border-radius: 6px !important;
}
.chooseItems{
    background: #267EF0 !important; 
    color: #FFFFFF !important;
}
.chooseDateLine{
    font-size: 12px;
    color: #9DA0A3;
    font-weight: 400;
    margin: 10px 0;
}
.indexOne:after{
    content: " ";
    display: inline-block;
    height: 6px;
    width: 6px;
    border-width: 2px 2px 0 0;
    border-color: #c8c8cd;
    border-style: solid;
    -webkit-transform: matrix(.71,.71,-.71,.71,0,0);
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: -2px;
    position: absolute;
    top: 50%;
    margin-top: -4px;
    right: 16px;
}
.page{
    display: none;
}
.footApply{
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: #FFFFFF;
    padding-bottom: constant(safe-area-inset-bottom);
    padding-bottom: env(safe-area-inset-bottom);
    box-sizing: border-box;
    padding-bottom: 20px;
}
.footApply>div{
    background: #267EF0;
    border-radius: 6px;
    width: 92%;
    margin: 10px auto;
    display: flex;
    align-items: center;
    padding: 8px;
    justify-content: center;
    box-sizing: border-box;
    color: #fff;
    font-size: 17px;
}
.applyEdit{
    width: 16px;
    margin-right: 10px;
}
.listTopPart{
    position: relative;
    width: 100%;
    background: #fff;
    padding: 10px 10px 0;
    box-sizing: border-box;
}
.listOneLine{
    background: #F5F6F7;
    border-radius: 20px;
    padding: 6px 10px;
    display: flex;
    align-items: center;
}
.dataContent{
    background: #F2FBFF;
    border-radius: 8px;
    padding: 10px;
    box-sizing: border-box;
}
.totalNum{
    font-size: 15px;
    color: #000000;
    font-weight: 400;
    padding-bottom: 10px;
    border-bottom: 1px solid #e1e1e1;
}
.totalNum>span{
    font-size: 22px;
    color: #267EF0;
    font-weight: 600;
    margin-right: 4px;
}
.dataDetail{
    position: relative;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    padding-top: 4px;
}
.dataDetailOne{
    flex: 1;
    border-right: 1px solid #e1e1e1;
    margin: 10px 0;
    margin-right: 12px;
}
.dataDetail>.dataDetailOne:nth-last-of-type(1){
    border-right: 0;
}
.dataIcon{
    display: flex;
    color: #000000;
    font-weight: 500;
    font-size: 16px;
    align-items: center;
    margin: 6px 0;
}
.dataIcon>img{
    width:15px;
    margin-right: 4px;
}
.dataNum{
    font-size: 14px;
    color: #9598A0;
    line-height: 17px;
    font-weight: 400;
}
.dataNum>span{
    margin-left: 4px;
    color: #267EF0;
}
.listOneLine>img{
    width: 14px;
    height: 14px;
    padding-left: 8px;
}
.keyInput{
    flex: 1;
    margin: 0 10px;
    font-size: 15px;

}
.keySearchBtn{
    background: #3975C6;
    border-radius: 24px;
    font-size: 15px;
    color: #FFFFFF;
    text-align: center;
    font-weight: 400;
    padding: 2px 12px;
}
.keyInput .van-field__control{
    text-align: left;
    overflow: hidden;
    background: #F5F6F7;
    color: #000;
    font-size: 15px;

}
.keyInput ::placeholder {
    color: #B4B4B4 !important;
    font-size: 15px;
}
.scrollPart{
    position: relative;
    height: calc(100vh - 100px);
    overflow-y: auto;
    margin-top: 191px;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    box-sizing: border-box;
    touch-action: pan-y;
    width: 100%;
}
.tabList{
    position: relative;
    background: #FFFFFF;
    width: 100%;
    display:flex;
    padding: 12px 0 10px 0;
    box-sizing: border-box;
}
.tabList>div{
    flex: 1;
    font-size: 17px;
    color: #000000;
    font-weight: 400;
    text-align: center;
}
.tabList>div>span{
    font-size: 13px;
    padding-left: 4px;
}
.activeTab{
    font-size: 17px !important;
    color: #4675C9 !important;
    font-weight: 500 !important;
    position: relative;
}
.activeTab:after{
    content: " ";
    position: absolute;
    width: 50%;
    left: 25%;
    bottom: -10px;
    right: 0;
    height: 1px;
    border-bottom: 3px solid #4675C9;
    color:#4675C9;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(.5);
    transform: scaleY(.5);
}

.nodate{
    text-align: center;
    margin: 20px auto;
    font-size: 15px;
    color: #999999;
}
.noMessage{
    width:160px;
    margin: 50px auto 10px;
}
.noMessage>img{
    width:100%;
}
.listContent{
    background-image: linear-gradient(180deg, rgba(255,255,255,0.90) 0%, #FFFFFF 100%);
    border-radius: 8px;
    padding:15px;
    position: relative;
    box-sizing: border-box;
    width: 94%;
    margin: 10px auto;
    font-size: 16px;
    color: #000000;
    font-weight: 400;
    padding-right: 20px;
}
.listContent:after{
    content: " ";
    display: inline-block;
    height: 6px;
    width: 6px;
    border-width: 2px 2px 0 0;
    border-color: #c8c8cd;
    border-style: solid;
    -webkit-transform: matrix(.71,.71,-.71,.71,0,0);
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: -2px;
    position: absolute;
    top: 50%;
    margin-top: -4px;
    right: 16px;
}
.contentPart{
    position: relative;
    background: #fff;
    margin: 10px auto;
    box-sizing: border-box;
    width: 100%;
    padding: 0px 10px;
}
.contentPart>.contentLine:nth-last-of-type(1){
    border-bottom: 0;
}
.contentPart>.phDetailcontentPart:nth-last-of-type(1){
    border-bottom: 0;
}
.contentLine{
    padding: 12px 0px;
    display: flex;
    border-bottom: 1px solid #e1e1e1;
    align-items: center;
    font-size: 17px;
}
.contentLineSec{
    border: 0;
    padding: 0;
}
.contentLineNew{
    border-bottom: 1px solid #e1e1e1;
    padding: 12px 0px;
}
.phDetailcontentPartNew>div{
    font-size: 16px !important;
}
.phDetailcontentPartNew .van-cell {
    font-size: 16px !important;
}
.selectChoose{
    position: relative;
    padding-right: 30px;
}
.selectChoose:after{
    content: " ";
    display: inline-block;
    height: 6px;
    width: 6px;
    border-width: 2px 2px 0 0;
    border-color: #c8c8cd;
    border-style: solid;
    -webkit-transform: matrix(.71,.71,-.71,.71,0,0);
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: -2px;
    position: absolute;
    top: 50%;
    margin-top: -4px;
    right: 16px;
}
.selectChooseNew{
    position: relative;
    padding-right: 20px;
}
.selectChooseNew:after{
    content: " ";
    display: inline-block;
    height: 6px;
    width: 6px;
    border-width: 2px 2px 0 0;
    border-color: #c8c8cd;
    border-style: solid;
    -webkit-transform: matrix(.71,.71,-.71,.71,0,0);
    transform: matrix(.71,.71,-.71,.71,0,0);
    position: relative;
    top: -2px;
    position: absolute;
    top: 50%;
    margin-top: -4px;
    right: 6px;
}
.contentLine>div:nth-of-type(1){
    font-size: 17px;
    color: #000000;
    font-weight: 400;
    min-width: 35%;
}
.contentLine>div:nth-of-type(2){
    /* color: #44C966; */
    text-align: right;
    font-weight: 400;
    flex: 1;
}
.contentLineRight>div:nth-of-type(2){
    font-size: 14px;
    color: #44C966;
}
.contentChoose{
    padding: 12px 0px;
    position: relative;
}
.chooseTitle{
    font-size: 17px;
    color: #000000;
    font-weight: 400;
}
.regetAddress{
    display: flex;
}
.getAddress{
    flex: 1;
    text-align: right;
    color:#267EF0;
    font-size: 15px;
}
