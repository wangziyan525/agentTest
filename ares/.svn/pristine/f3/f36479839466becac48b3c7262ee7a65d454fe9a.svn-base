}
.flexChooseNew>div{
    flex: 1;
}
.detailCard{
    width: 100%;
    position: relative;
    padding: 12px 16px;
    box-sizing: border-box;
    background: #fff;
    
}
.detailTop{
    margin: 10px 0;
}
.detailtopLine{
    border-top: 1px solid #e1e1e1;
    margin-top: 10px;
    padding-top: 10px;
}
.detailcompanyNameLine{
    margin: 10px auto 0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    
}
.detailcompanyNameLine>div:nth-of-type(1){
    font-size: 16px;
    color: #000000;
    font-weight: 600;
    max-width: 70%;
}

.detailBusiness{
    position: relative;
    width: 100%;
    background: #fff;
    padding: 10px;
    box-sizing: border-box;
}
.businessLine{
    padding: 4px 0;
    box-sizing: border-box;
    display: flex;
    align-self: center;
}
.businessLineleft{
    font-size: 15px;
    color: #666666;
    font-weight: 400;
    flex: 1;
    min-width: 60%;
}
.businessLine>div:nth-of-type(2){
    font-size: 15px;
    
    text-align: right;
    font-weight: 400;
}
.businessLineright0{
    color: #B3B3B3;
}
.businessLineright1{
    color: #44C966;
}
.businessLineright9{
    color: #FA0909;
}
.addRecord{
    position: relative;
    width: 100%;
    padding: 10px 0;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: #267EF0;
    text-align: center;
    font-weight: 400;
    background: #fff;
    margin-top: -10px;
    border-top: 1px solid #e1e1e1;
}
.addRecord>img{
    width: 16px;
    height: 16px;
    margin: 0 10px;
}
.recordList{
    width: 100%;
    position: relative;
    background: #fff;
    box-sizing: border-box;
    margin-top: 10px;
}
.stepPart{
    padding: 0 0 0 32px;
}
.stepOne{
    display: block;
    float: none;
    padding: 10px 10px 10px 4px;
    position: relative;
    box-sizing: border-box;

}
.stepText>div:nth-of-type(1){
    font-size: 15px;
    color: #000000;
    font-weight: 400;

}
.stepText>div:nth-of-type(2){
    font-size: 14px;
    color: #B1B1B1;
    font-weight: 400;

}

.stepCircle{
    position: absolute;
    top:16px;
    left: -15px;
    z-index: 1;
    display: block;
    width: 10px;
    height: 10px;
    background: #E7E7E7;
    border-radius: 50%;

}
.stepLine{
    top: 20px;
    left: -11px;
    height: 100%;
    position: absolute;
    border-left: 1px dashed #E7E7E7;
    
}
.stepPart>.stepOne:nth-last-of-type(1)>.stepLine{
    height: 0;
}
.popouTitle{
    text-align: center;
    margin-bottom: 10px;
}
.copyImg{
    width: 15px;
    height: 15px;
    margin-bottom: -2px;
}
.text_justify{
    /* word-break: break-all;
    display: inline-block;
    text-align: left; */
}
.phDetailBox>.borderLine:nth-last-of-type(1){
    border: 0;

}
.buluBtn{
    width: 100%;
    padding: 10px;
    box-sizing: border-box;
    text-align: center;
    font-size: 15px;
    color: #267EF0;
    font-weight: 400;
    border-top: 1px solid #eee;
}
.buluContentPart{
    width: 90%;
    margin: 20px auto;
    position: relative;
}
.buluInputPart{
    font-size: 17px;
    color: #000000;
    font-weight: 400;
    border-bottom: 1px solid #eee;
    padding: 10px 0;
}
.buluInputPart>div:nth-of-type(2){
    display: flex;
    margin-top: 10px;
}
.buluInputPart>div:nth-of-type(2)>img{
    width: 16px;
    height: 16px;
}
.buluInputPart .van-field__control{
    text-align: left;
}
.buluInputPart .van-cell::after{
    border: 0;
}
.buluTitle{
    font-size: 18px !important;
    color: #272727 !important;
    font-weight: 500 !important;
    
}
.buluTopImg{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
}
.buluTopImg>img{
    width: 100%;
}
.buluTop{
    border: 0;
}




























/****************语音输入开始****************/
.record{
    position: absolute;
    right: 24px;
    top: -40px;
    width: 20px;
    height: 25px;
}
.record>div{
    position: relative;
    display: inline-block;
}
.voice{
    width: 22px;
    height: 22px;
    vertical-align: sub;
    margin-right: 10px;

}
.luyinbtn {
    width: 100px;
    background-color: #fff;
    color: #333;
    height: 36px;
    line-height: 36px;
    border-radius: 8px;
    margin: 6px auto 12px;
    font-size: 15px;
    font-weight: 500;
}

.recodeblock {
   position: fixed;
   width: 140px;
   max-width: 300px;
   top: 45%;
   left: 50%;
   -webkit-transform: translate(-50%, -50%);
   transform: translate(-50%, -50%);
   background: rgba(0, 0, 0, .6);
   text-align: center;
   border-radius: 3px;
   overflow: hidden;
   -webkit-transition-duration: .2s;
   transition-duration: .2s;
   -webkit-transform: translate(-50%, -50%);
   transform: translate(-50%, -50%);
   -webkit-transform-origin: 0 0;
   transform-origin: 0 0;
   margin: 0;
   border-radius: 12px;
   visibility: hidden;
   opacity: 0;
}

.recodeblock.showluyin {
   opacity: 1;
   visibility: visible;
   z-index: 99999;
}

.recodeblock img {
   width: 68%;
   margin: 15px auto 0;
}
.btnDiv{
   display: flex;
}
.luyinline {
   width: 40%;
   height: 34px;
   line-height: 34px;
   border-radius: 50px;
   color: #4273d8;
   border: 1px solid #4273d8;
   text-align: center;
   margin: 10px auto;
   font-size: 15px;
}

.luyinline img {
   height: 20px;
   vertical-align: middle;
   margin-right: 6px;
}

.yuyin-input{
   height: auto;
   padding: 10px 3% 5px 3%;
   border-bottom: 0px;
   flex-direction: column
}
select:invalid{
   color: #999999;
}
option{
   color: #121212;
}
/****************语音输入结束****************/
.van-tabs__line{
    transform: translateX(48px) translateY(-50%);
}

.textAreaPart .van-field__body>textarea{
    background: #F3F4F8;
    border-radius: 4px;
    margin: 10px auto 0;
    text-align: left;
    padding: 10px;
    border: 0;

}

.LseMoRntlPart .van-field__body>input{
    background: #F3F4F8;
    border-radius: 4px;
    margin: 10px auto 0;
    text-align: left;
    padding: 10px;
    border: 0;

}

.gradeChooseNew>div{
    background: #fff ;
   
}

