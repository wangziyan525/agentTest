    font-size: 15px;
    color: #F96060;
    font-weight: 400;
    margin-left: 4px;
} */
.warnSpan{
    font-size: 15px;
    color: #F96060;
    font-weight: 400;
    margin-left: 4px;
}

.choosePart{
    position: relative;
    display: flex;
    justify-content: start;
    margin-top: 10px;
    flex-wrap: wrap;
    font-size: 15px;
    color: #000000;
    font-weight: 400;
    width: 100%;
}
.chooseOne{
    width: 33.33%;
    display: flex;
    margin-bottom: 6px;
    align-items: center;
}
.chooseOne>img{
    width: 18px;
    height: 18px;
    padding-right: 4px;
}
.applyButton{
    background: #267EF0;
    border-radius: 6px;
    width: 92%;
    margin: 20px auto 10px;
    display: flex;
    align-items: center;
    padding: 8px;
    justify-content: center;
    box-sizing: border-box;
    color: #fff;
    font-size: 17px;
    border: 1px solid #267EF0;
    
}
.cancelButton{
    color: #267EF0;
    border: 1px solid #267EF0;
    border-radius: 6px;
    width: 92%;
    margin: 20px auto 10px;
    display: flex;
    align-items: center;
    padding: 8px;
    justify-content: center;
    box-sizing: border-box;
    font-size: 17px;
}
.reNew{
    width: 92%;
    margin:  auto;
    text-align: center;
    font-size: 16px;
    color:#267EF0;
}
.toSubmit{
    width:94%;
    position: relative;
    margin: 20px auto;
    display: flex;
    justify-content:flex-end;
    font-size: 17px;

}
.toSubmit>div:nth-of-type(1){
    color:#267EF0;
    padding:8px 10px;
    text-align: center;
    flex: 1;
    border: 1px solid #267EF0;
    margin: 10px;
    border-radius: 4px;
}
.toSubmit>div:nth-of-type(2){
    color:#fff;
    padding:8px 10px;
    text-align: center;
    flex: 1;
    border: 1px solid #267EF0;
    background: #267EF0;;
    margin: 10px;
    border-radius: 4px;
}

.imgWarnSpan{
    font-size: 13px;
    color: #9DA0A3;
    font-weight: 400;
    margin-left: 4px;
}
.imgUpload{
    position: relative;
    display: flex;
    justify-content: start;
    margin: 0 -6px;
    flex-wrap: wrap;
}
.hasImg{
    position: relative;
    margin: 6px 6px;
    width: 80px;
    height: 80px;
    border-radius: 8px;
}
.uploadImg{
    width: 100%;
    height: 100%;
    border-radius: 8px;
}
.closeImg{
    position: absolute;
    top: 0;
    right: 0;
    width: 20px;
}
.borderLine{
    border-bottom: 1px solid #e1e1e1;
}
.warnTitle{
    font-size: 13px;
    color: #9DA0A3;
}
.inputBorder input{
    border: 0;
}
.warnText{
    width: 94%;
    margin: 20px auto;
    font-size: 15px;
    color:#999;
}

.seachData{
    width: 100%;
    position: fixed;
    background: #fff;
    box-sizing: border-box;
    top: 0;
    left: 0;
    z-index: 10;
}
.searchLine{
    border-bottom: 1px solid rgba(235,235,235,1);
    padding: 5px 0;
}
.seachDataForm{
    display: flex;
    justify-content:center;
    padding: 0 10px;
    box-sizing: border-box;
    margin: 10px 0;
}
.seachDataForm>div{
    flex: 1;
    margin: 0 5px;
    text-align: center;
    padding: 4px 0;
    background: #F5F6F7;
    border-radius: 6px;  
    color: #848484;
    font-size: 14px;
    border: 1px solid #F5F6F7;   
}
.jdData{
    position: relative;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    padding-top: 4px;
}
.jdData>div{
    flex: 1;
    border-right: 1px solid #e1e1e1;
    margin: 10px 0;
    /* margin-right: 12px; */
    text-align: center;
}
.jdData>div:nth-last-of-type(1) {
    border-right: 0;
}
.dataTitle1{
    font-size: 14px;
    color: #848484;
    text-align: center;
    font-weight: 400;
}
.datatotalNum{
    font-size: 20px;
    color: #262626;
    text-align: center;
    font-weight: 600;
}
.tabList{
    position: relative;
    width: 100%;
    display: flex;
    padding: 10px 0;
    text-align: center;
    justify-content: center;
    box-sizing: border-box;
    margin-top: 10px;
    font-size: 17px;
    color: #000000;
    font-weight: 500;
}
.tabList>div{
    flex: 1;
}
.chooseRole{
    color: #4675C9 !important;
    position: relative;
}
.chooseRole:after{
    content: " ";
    position: absolute;
    width: 50%;
    left: 25%;
    bottom: -10px;
    right: 0;
    height: 1px;
    border-bottom: 3px solid #4675C9;
    color:#4675C9;
    -webkit-transform-origin: 0 100%;
    transform-origin: 0 100%;
    -webkit-transform: scaleY(.5);
    transform: scaleY(.5);
}
.seachSsbm{
    padding: 6px 10px;
    box-sizing: border-box;
    margin: 10px 0;
    display: flex;

}
.seachSsbmNew{
    padding: 16px 10px;
    background: #fff;
    border-top: 1px solid #e1e1e1;
    margin-top: 0;
}
.seachSsbm>div{
    margin: 0 5px;
    text-align: center;
    padding: 4px 10px;
    background: #F5F6F7;
    border-radius: 6px;
